{"sections":{"breadcrumbs":{"type":"breadcrumbs","disabled":true,"settings":{}},"main":{"type":"main-contact-page","disabled":true,"settings":{"page_width":100}},"re_hero_banner_pQpbLx":{"type":"re-hero-banner","disabled":true,"name":"Hero Banner","settings":{"desktop_img":"shopify://shop_images/black_upf_lomg_sleeve_swimsuit_sulawesi_ocean_soul_swimwear.jpg","Mobile_img":"shopify://shop_images/black_upf_lomg_sleeve_swimsuit_sulawesi_ocean_soul_swimwear.jpg","title":"","desktop_title_color":"#fff","mobile_title_color":"#fff","dis":"","dis_deskop_color":"#fff","dis_mobile_color":"#fff","bg-color-name":"#000000","text-color-name":"#ffffff","icon-svg-color":"#ffffff","icon-svg-mobile-color":"#ffffff","icon-text-color":"#ffffff","icon-text-mobile-color":"#ffffff","btn_text":"","btn_url":"","desktop_text_align":"center","mobile_text_align":"center","desktop_dis_margin_bottom":45,"tablet_dis_margin_bottom":35,"mobile_dis_margin_bottom":20,"desktop_content_position":"center_left","mobile_content_position":"top_center","desktop_padding_top":150,"desktop_padding_bottom":100,"tablet_padding_top":90,"tablet_padding_bottom":60,"mobile_padding_top":40,"mobile_padding_bottom":0}},"808ac93f-0167-44d0-93f8-869cb3577439":{"type":"slideshow","blocks":{"template--14915046670425__808ac93f-0167-44d0-93f8-869cb3577439-1677890140c16a9835-0":{"type":"image","settings":{"image":"shopify://shop_images/black-long-sleeve-swimsuit-the-sulawesi-midnight.webp","overlay":false,"text_align":"left","caption_horizontal":50,"caption_vertical":50,"mobile_image":"shopify://shop_images/black-long-sleeve-swimsuit-the-sulawesi-midnight.webp","hide_caption_background":false,"caption_below":false,"heading":"Warranty","subheading":"","link":"","button_text":"Button","second_link":"","second_button_text":"Button 2","slide_text_color":"#ffffff","cta_color":"#ffffff","cta_background":"#000000","caption_background":"rgba(0,0,0,0)","caption_background_opacity":10}}},"block_order":["template--14915046670425__808ac93f-0167-44d0-93f8-869cb3577439-1677890140c16a9835-0"],"settings":{"display_wide":true,"no_autoplay":false,"slider_speed":5,"pager":"dots","slideshow_size":"fixed_height","desktop_height":400,"mobile_height":400,"slide_heading_size":36,"subheading_size":14,"cta_size":14,"section_space":"none"}},"4896f815-afa4-4b4d-bb9f-fcc8e71dcf41":{"type":"rich-text","blocks":{"template--15072417874009__4896f815-afa4-4b4d-bb9f-fcc8e71dcf41-text_block-1":{"type":"text_block","settings":{"title":"Our Guarantee to you","title_heading":true,"text":"<p></p><p>Every Ocean Soul Swimwear piece is crafted with the highest quality materials and construction. Should the fabric or construction of your garment let you down, we will repair or replace your item at our discretion.</p><p>Small defects can occasionally occur in stitching, and even though we use the best YKK zips on the market, zips may become faulty. This warranty covers genuine manufacturing faults only. It does not cover damage caused by misuse, neglect, or extreme activities.</p><p>Please note:</p><p>As with any premium fabric, care must be taken to avoid snagging, piling, or abrasion. Rough pool edges, velcro, or abrasive surfaces can pull fibres. These damages cannot be repaired and are not covered by warranty.<br/></p><p>Mesh fabric is a delicate fibre and requires extra care. Tears, pulls, or damage to mesh panels are not covered under warranty.<br/></p><p>Misuse such as washing in hot water, spin drying, hot tub use, or leaving a wet garment in a bag will void the warranty.<br/></p><p>Your Ocean Soul Swimwear is designed to last for years with the right care and mindful handling.</p>","page":"","center":true,"block_width":100}},"text_block_P6J3DB":{"type":"text_block","settings":{"title":"","title_heading":false,"text":"<h2></h2><h2>Care Instructions</h2><p>To preserve the longevity of your garment:</p><p>Wash by hand in cool water using a mild natural soap.<br/></p><p>Avoid bleach, fabric softeners, and strong detergents.<br/></p><p>Do not wring or spin dry.<br/></p><p>Dry flat in the shade — never in direct sunlight.<br/></p><p>Mesh fabric care: </p><p>Mesh is particularly delicate. Avoid pulling, stretching, or snagging against sharp or rough surfaces.</p><p> Handle gently to keep it looking beautiful.</p><p>With the right care, your Ocean Soul Swimwear will stay strong, supportive, and stylish season after season.</p>","page":"","center":true,"block_width":100}}},"block_order":["template--15072417874009__4896f815-afa4-4b4d-bb9f-fcc8e71dcf41-text_block-1","text_block_P6J3DB"],"settings":{"padding":30,"text_color":"#606060","background_color":"#ffffff","comman_data_id":""}},"520334dd-dfcb-4ca5-8bcd-f43b92b4d29f":{"type":"collection-list","blocks":{"template--14915046670425__520334dd-dfcb-4ca5-8bcd-f43b92b4d29f-featured_collection-2":{"type":"featured_collection","settings":{"collection":"surfing-swimsuits"}},"template--14915046670425__520334dd-dfcb-4ca5-8bcd-f43b92b4d29f-featured_collection-1":{"type":"featured_collection","settings":{"collection":"long-sleeve-one-piece-swimsuits"}},"template--14915046670425__520334dd-dfcb-4ca5-8bcd-f43b92b4d29f-featured_collection-3":{"type":"featured_collection","settings":{"collection":"seamless-bikinis"}},"featured_collection_Pd6rjL":{"type":"featured_collection","settings":{"collection":"womens-wetsuit-springsuit"}},"featured_collection_tXwC8e":{"type":"featured_collection","settings":{"collection":"beach-resort-wear"}},"featured_collection_nFtwBm":{"type":"featured_collection","settings":{"collection":"beach-accessories"}}},"block_order":["template--14915046670425__520334dd-dfcb-4ca5-8bcd-f43b92b4d29f-featured_collection-2","template--14915046670425__520334dd-dfcb-4ca5-8bcd-f43b92b4d29f-featured_collection-1","template--14915046670425__520334dd-dfcb-4ca5-8bcd-f43b92b4d29f-featured_collection-3","featured_collection_Pd6rjL","featured_collection_tXwC8e","featured_collection_nFtwBm"],"settings":{"title":"Shop our collections","grid":3,"mobile_1pr"