        "da5688b2-ac81-441f-ad20-d8c5bf5c3484": {
          "type": "accordion_content",
          "settings": {
            "section_class": "section_class",
            "page": "",
            "title": "Product Care",
            "text": "<p>To keep your swimwear happy and healthy, please follow our general care guidelines:<br/><br/>Our suits are happiest when hand-washed separately in cool water so the colours do not bleed. Please avoid traditional washers and abrasive materials like velcro and bleach.  Do not leave wet swimsuit in a bag. Air dry in a shady spot.</p>",
            "default_open_accordion": false
          }
        },
        "a34f6081-2778-463c-8074-6403bf19be80": {
          "type": "accordion_content",
          "settings": {
            "section_class": "section_class",
            "page": "",
            "title": "Shipping, Returns & Warranty",
            "text": "<p>SHIPPING</p><p>Worldwide<strong> </strong>shipping from Bali & Australia. Free EXPRESS Shipping for orders $250+ AUD.</p><p>International Express Shipping will be sent via DHL and will arrive in 2 - 4 days once dispatched.</p><p>Domestic Indonesian & Australian orders will be sent express and arrive in 1 - 3 days.</p><p>Please read more of our Shipping Policy <a href=\"/policies/shipping-policy\" title=\"Shipping Policy\">here.</a></p><p>RETURNS/EXCHANGES</p><p>We accept exchanges or returns for change of mind for a credit note, on full price items only, and as long as it is processed within within 30 days from the date the item was dispatched.</p><p>Sale items cannot be exchanged or refunded.</p><p>See our returns policy here.</p><p>Please follow instructions on our  <a href=\"https://www.oceansoulbali.com/policies/refund-policy\" title=\"https://www.oceansoulbali.com/policies/refund-policy\">Returns </a>page.</p><p>WARRANTY</p><p>We stand by the quality of our swimsuits, they are tailor made with high quality Italian fabric. </p><p>We offer a 12 month warranty from date of purchase, shall the make, material or hardware malfunction.</p><p>Read more about our warranty <a href=\"/pages/warranty\" title=\"Warranty\">here.</a></p>",
            "default_open_accordion": false
          }
        },
        "0f909705-4368-4514-8d5e-71a0ac76a5cb": {
          "type": "accordion_content",
