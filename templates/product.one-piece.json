hop_images\/ikit_agudo-3.jpg","link":"","title_text":"Designed for comfort","text":"<p>Crafted for all-day comfort, the Sulawesi is made from luxurious, Italian sustainable, buttery-soft fabric. Designed with every detail in mind—double-lined with cupless support and smooth seams—it moves with you while keeping you secure in and out of the water.<\/p>","button_text":"Button"}},"167e640a-03e8-48de-b93f-07bbc26e1244":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/laurenlanders-4.jpg","link":"","title_text":"Sustainable Swim","text":"<p>We’re committed to slow fashion, using eco-friendly fabrics and ethical production. Made from regenerated nylon, our swimsuits are designed to last twice as long as a regular suit—reducing waste without compromising on style or performance. Crafted with care in Bali, for a better planet.<\/p>","button_text":"Button"}}},"block_order":["8743bf57-6b1a-4f8c-8988-5e42ae277901","a5eb81f9-4c92-4ecc-bf0a-6c9cf53eb6cf","167e640a-03e8-48de-b93f-07bbc26e1244"],"custom_css":["h3 {padding-top: 20px;}"],"settings":{"title":"","center_align":true,"image_height":"fixed","desktop_fixed_height":350,"mobile_fixed_height":250,"section_space":"top_and_bottom"}},"website_logos_rRnFE6":{"type":"website-logos","blocks":{"text_block_qRfCLU":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/PngItem_171373.png","link":"","text":"","button_text":"Button"}},"text_block_HtHJKy":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/british_vogue.png","link":"","text":"","button_text":"Button"}},"text_block_xUeWeF":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/Herald_Sun_logo_logotype.png","link":"","text":"","button_text":"Button"}},"text_block_wkhcRw":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/surfgirl_2fd2b878-a25c-4248-afde-faa68bc8d31f.png","link":"","text":"","button_text":"Button"}},"text_block_Fe9N6c":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\