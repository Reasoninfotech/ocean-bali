alse}},"da5688b2-ac81-441f-ad20-d8c5bf5c3484":{"type":"accordion_content","settings":{"section_class":"section_class","page":"","title":"Product Care","text":"<p>To keep your swimwear happy and healthy, please follow our general care guidelines:<br\/><br\/>Our suits are happiest when hand-washed separately in cool water so the colours do not bleed. Please avoid traditional washers and abrasive materials like velcro and bleach.  Do not leave wet swimsuit in a bag. Air dry in a shady spot.<\/p>","default_open_accordion":false}},"a34f6081-2778-463c-8074-6403bf19be80":{"type":"accordion_content","settings":{"section_class":"section_class","page":"","title":"Shipping, Returns & Warranty","text":"<p>SHIPPING<\/p><p>Worldwide<strong> <\/strong>shipping from Bali & Australia. Free EXPRESS Shipping for orders $250+ AUD.<\/p><p>International Express Shipping will be sent via DHL and will arrive in 2 - 4 days once dispatched.<\/p><p>Domestic Indonesian & Australian orders will be sent express and arrive in 1 - 3 days.<\/p><p>Please read more of our Shipping Policy <a href=\"\/policies\/shipping-policy\" title=\"Shipping Policy\">here.<\/a><\/p><p>RETURNS\/EXCHANGES<\/p><p>We accept exchanges or returns for change of mind for a credit note, on full price items only, and as long as it is processed within within 30 days from the date the item was dispatched.<\/p><p>Sale items cannot be exchanged or refunded.<\/p><p>See our Returns policy <a href=\"https:\/\/oceansoulbali.com\/policies\/refund-policy\" target=\"_blank\" title=\"https:\/\/oceansoulbali.com\/policies\/refund-policy\">here.<\/a><\/p><p>Please follow instructions on our  <a href=\"https:\/\/www.oceansoulbali.com\/policies\/refund-policy\" title=\"https:\/\/www.oceansoulbali.com\/policies\/refund-policy\">Returns <\/a>page.<\/p><p>WARRANTY<\/p><p>We stand by the quality of our swimsuits, they are tailor made with high quality Italian fabric. <\/p><p>We offer a 12 month warranty from date of purchase, shall the make, material or hardware malfunction.<\/p><p>Read more about our warranty <a href=\"\/pages\/warranty\" title=\"Warranty\">here.<\/a><\/p>","default_open_accordion":false}},"0f909705-4368-4514-8d5e-71a0ac76a5cb":{"type":"accordion_content","settings":{"section_class":"section_class","page":"","title":"Contact Us","text":"<p>Have a question? You can reach us below or on live chat.<\/p><p><a href=\"mailto:customercare@oceansoulbali.com\" target=\"_blank\" title=\"mailto:customercare@oceansoulbali.com\">Email<\/a><\/p><p><a href=\"http:\/\/wa.me\/61407215854\" target=\"_blank\" title=\"http:\/\/wa.me\/61407215854\">Whats App<\/a><\/p><p><\/p>","default_open_accordion":false}}},"block_order":["judge_me_reviews_preview_badge_Uqxx97","product_variants","product_quantity","518bdfc4-e6a0-4562-ad4e-a749a84096b2","onyou_onyou_popup_TnECRw","c76af5a1-ddb2-4df8-a229-edef90940010","7083fa5a-a988-498e-ac51-81c70cca09d2","5a0481c6-7b6b-45dc-99cf-3aca7980daa4","product_buttons","2bee718c-a25a-4b01-996c-9678953bbf0a","text_with_icon_wyyBGB","text_with_icon_4kQwc3","text_with_icon_8iwKWH","876a735f-f0bb-4624-b8cc-8d60db6ba807","ac9f6f7c-33c1-4256-932e-3bd4272452e2","b21287a0-71ea-48e4-95a5-e30b5c121dc2","tabs_name_aDWKrk","bundler_bundler_target_element_qQPFRT","tolstoy_shoppable_video_ugc_stories_block_nkc7Nb","49935d06-a61f-4be4-865c-9762a9f134a3","product_description","7ee2622b-242b-4502-8b12-c152b516c8bb","536f622f-212e-4a9c-a60c-c76fe14abb58","da5688b2-ac81-441f-ad20-d8c5bf5c3484","a34f6081-2778-463c-8074-6403bf19be80","0f909705-4368-4514-8d5e-71a0ac76a5cb"],"custom_css":["h3,h4 {padding-top: 15px; line-height: 1.5;}","p {padding-top: 10px; padding-bottom: 10px;}","h3 {font-size: 17px;}","div.fera-productReviewsSummary-content {padding-bottom: 10px;}","span.js-variant-stock-levels__message {color: #7c031e;}","svg.icon--testament-info {fill: #7c031e;}"],"settings":{"pay_img":"shopify:\/\/shop_images\/Screenshot_4.jpg","product_form_background":"#ffffff","product_page_border":"rgba(0,0,