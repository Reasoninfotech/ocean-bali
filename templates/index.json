:false,"text":"<p>Sustainable Swimwear Designed for Ocean Women</p><p>At Ocean Soul Swimwear, we create sustainable swimwear for women who love the ocean and live actively in and around the water.</p><p>From surf-ready long sleeve swimsuits and rash guards to sculpting one piece swimwear and seamless two piece bikinis, every piece is designed to flatter your shape, support your body, and stay securely in place when you move.</p><p>Crafted from luxurious recycled Italian fabric with UPF 50+ sun protection, our swimwear delivers sculpting comfort, durability, and timeless style - made for surfing, swimming, travel, and long beach days.</p>","page":"","center":true,"block_width":100,"accordion_icon_color":"#000000","accordion_icon_size":20}}},"block_order":["template--14915046867033__b3b87d13-30ab-4118-ad40-e3ad445f1eab-1677649933d239dab1-0","text_block_HQhC8C","text_block_4DEBTw"],"custom_css":["{margin-top: 10px;}","h3 {padding-bottom: 0px; font-size: 20px;}"],"settings":{"padding":30,"text_color":"#606060","background_color":"#ffffff","comman_data_id":""}},"collection_list_8zDcrF":{"type":"collection-list","blocks":{"featured_collection_W6qQJc":{"type":"featured_collection","settings":{"collection":"best-seller"}},"featured_collection_8i38dg":{"type":"featured_collection","settings":{"collection":"surfing-swimsuits"}},"featured_collection_8PDHLG":{"type":"featured_collection","settings":{"collection":"upf-swimwear"}},"featured_collection_QW4ywG":{"type":"featured_collection","settings":{"collection":"one-piece-swimsuit"}},"featured_collection_PJaqkw":{"type":"featured_collection","settings":{"collection":"seamless-bikinis"}},"featured_collection_jzCKWe":{"type":"featured_collection","settings":{"collection":"beach-resort-wear"}}},"block_order":["featured_collection_W6qQJc","featured_collection_8i38dg","featured_collection_8PDHLG","featured_collection_QW4ywG","featured_collection_PJaqkw","featured_collection_jzCKWe"],"name":"Collection list","settings":{"title":"","grid":3,"mobile_1pr":false,"section_space":"none"}},"text_with_icons_f69zUB":{"type":"text-with-icons","blocks":{"block_GLcniC":{"type":"block","settings":{"icon":"messages","image":"shopify://shop_images/UPF_UV_Asset.jpg","text":"UPF PROTECTION","link":""}},"block_FULfFL":{"type":"block","settings":{"icon":"secure","image":"shopify://shop_images/Screenshot_9_cb43dcb6-e4ee-4699-8547-1a44b6b9cbf7.jpg","text":"12 MONTH WARRANTY","link":""}},"block_b9UTMh":{"type":"block","settings":{"icon":"shipping_outline","image":"shopify://shop_images/Sustainable.jpg","text":"SUSTAINABLE","link":""}},"block_mwf6Ct":{"type":"block","settings":{"icon":"bag","image":"shopify://shop_images/Asset_5_4x_5022a477-72f5-44a4-bc3a-93a1e4c7950e.jpg","text":"Durable","link":""}}},"block_order":["block_GLcniC","block_FULfFL","block_b9UTMh","block_mwf6Ct"],"settings":{"color":"","background":"","section_space":"none"}},"image_with_text_w86UPn":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/Long_Sleeve_swimsuit_for_women-ocean-soul-swimwear.webp","image_position":"left","image_size":"medium","image_height":"fixed","desktop_image_height":450,"mobile_image_height":450,"title":"Luxury Sustainable Swimwear for Women","text":"<p>Ocean Soul Swimwear blends luxury swimwear design with sustainable materials, creating pieces that feel as beautiful as they perform.</p><p>Crafted from premium recycled Italian fabric, our swimsuits offer a sculpting fit, UPF 50+ sun protection, and exceptional durability. From long sleeve swimsuits and elegant one piece swimwear to surf-ready bikinis, every design is made to flatter your shape and stay secure through movement.</p><p>Thoughtfully created for women who love the ocean, our luxury sustainable swimwear combines performance, comfort, and timeless coastal style.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"website_logos_A7LRzy":{"type":"website-logos","blocks":{"text_block_4jzPta":{"type":"text_block","settings":{"image":"shopify://shop_images/british_vogue.png","link":"","text":"","button_text":"Button"}},"text_block_MGmtrY":{"type":"text_block","settings":{"image":"shopify://shop_images/PngItem_171373.png","link":"","text":"","button_text":"Button"}},"text_block_YLemrC":{"type":"text_block","settings":{"image":"shopify://shop_images/Herald_Sun_logo_logotype.png","link":"","text":"","button_text":"Button"}},"text_block_Htr3FT":{"type":"text_block","settings":{"image":"shopify://shop_images/surfgirl_2fd2b878-a25c-4248-afde-faa68bc8d31f.png","link":"","text":"","button_text":"Button"}},"text_block_gqDd3Q":{"type":"text_block","settings":{"image":"shopify://shop_images/The_Daily_Telegraph_Australien_logo_1_0fe2f81a-800d-4341-9e86-81b53cadc747.png","link":"","text":"","button_text":"Button"}},"text_block_eYF6LH":{"type":"text_block","settings":{"image":"shopify://shop_images/georgina_monti.png","link":"","text":"","button_text":"Button"}},"text_block_qCATHA":{"type":"text_block","settings":{"image":"shopify://shop_images/honeycombers.png","link":"","text":"","button_text":"Button"}},"text_block_AFr7en":{"type":"text_block","settings":{"image":"shopify://shop_images/acc.png","link":"","text":"","button_text":"Button"}}},"block_order":["text_block_4jzPta","text_block_MGmtrY","text_block_YLemrC","text_block_Htr3FT","text_block_gqDd3Q","text_block_eYF6LH","text_block_qCATHA","text_block_AFr7en"],"custom_css":["@media (max-width: 740px) {.website-logo-section {margin-top: 20px !important; }}"],"settings":{"title":"As seen in","center_align":false,"show_description":true,"image_height":"none","desktop_fixed_height":500,"mobile_fixed_height":200,"section_space":"bottom"}},"image_with_text_RpPR8H":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/long_sleeve_swimsuit_ocan_soul_swimwear.jpg","image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":300,"mobile_image_height":300,"title":"","text":"<h4>Designed for Confidence. Built to Last.</h4><p>Ocean Soul Swimwear blends performance, comfort, and timeless design to create swimwear that feels incredible to wear and empowers you in the water. Every piece is designed to support your body, flatter your shape, and stay secure - so you can move with confidence in and out of the water.</p><p>From the rash guard that keeps you sun-safe to the one piece swimsuit that flatters like a dream - this is swimwear made for surf, sport and real life. </p><p> Ethically produced in Bali using recycled materials and small-batch methods, our pieces are crafted for durability, comfort, and longevity.</p>","button_text":"","link":"shopify://products/long-sleeve-swimwear-sulawesi-white","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"image_with_text_LzHcEq":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/Surf_swimwear_for_women.jpg","image_position":"left","image_size":"medium","image_height":"fixed","desktop_image_height":300,"mobile_image_height":300,"title":"","text":"<h4>Sustainable Women’s Swimwear That Performs</h4><p>Ocean Soul Swimwear is thoughtfully designed for performance in real conditions. Our swimwear is created to move with your body, stay secure through activity, and maintain its shape wear after wear.</p><p>Our collection includes long sleeve bathers, supportive one piece swimwear, secure two piece surf bikinis, rash guards for women, and eco wetsuits.</p><p> Every style is crafted with UPF 50+ sun protection, premium recycled Italian fabric, and intelligent panelling that smooths and shapes without padding or restriction.</p><p>From classic black one piece swimsuits to high performance surf swimwear, each Ocean Soul piece is built for durability and ethically produced in small batches in Bali.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"image_with_text_UJgAYj":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/long-sleeve-swimsuit-women-the-_sulawesi-in-_nautical_-_ocean-soul-swimwear-2.webp","image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":500,"mobile_image_height":450,"title":"","text":"<h4>Designed to Stay On in the Water</h4><p>Most swimwear is designed for lounging - not movement.</p><p>Ocean Soul Swimwear was created for women who want swimsuits that stay secure while surfing, swimming, and exploring the ocean, without sacrificing flattering design.</p><p>Our signature panelled silhouettes sculpt your shape while providing the support and confidence you need for active days in and around the water.</p><p>Explore sustainable swimwear collwction designed for movement, including<a href=\"/collections/long-sleeve-one-piece-swimsuits\" title=\"Long Sleeve Swimsuits\"> long sleeve swimsuits</a>, flattering<a href=\"/collections/one-piece-swimsuit\" title=\"One Piece Swimsuits\"> one piece swimsuits</a>, <a href=\"https://oceansoulbali.com/collections/seamless-bikinis\" title=\"https://oceansoulbali.com/collections/seamless-bikinis\">seamless surf bikinis</a>, <a href=\"/collections/womens-rash-vest\" title=\"Womens Rash Vest\">women’s rash guards</a>, and <a href=\"/collections/womens-wetsuit-springsuit\" title=\"Women's Wetsuits & Springsuits\">limestone neoprene wetsuits</a> - thoughtfully designed to stay on, sculpt your shape, and protect your skin.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"custom_liquid_3xadmt":{"type":"custom-liquid","custom_css":[".yt-wrapper .youtube {background-image: url(https://cdn.shopify.com/s/files/1/0079/2274/5433/files/Soulscapes_Video_2.jpg?v=1722481830) !important; background-size: cover !important; background-position: center !important;}"],"settings":{"liquid":"<div class=\"yt-wrapper\">\n <div class=\"youtube\" data-embed=\"P7BRxJM08_0\" data-width=\"100%\" data-height=\"auto\">\n <div class=\"play-button\"></div>\n </div>\n</div>","display_wide":true}},"rich_text_PUbz6R":{"type":"rich-text","blocks":{"text_block_4ECPbY":{"type":"text_block","settings":{"title":"","title_heading":true,"accordion_enabled":false,"text":"<h3>Designed for water women.  Made for movement. </h3><h3>Luxurious Italian recycled fabric.</h3><h3>UPF 50+ protection. </h3><h3>Sculpting fits. </h3><h3>Sustainable swimwear that feels as good as it looks.</h3>","page":"","center":true,"block_width":100,"accordion_icon_color":"#000000","accordion_icon_size":20}}},"block_order":["text_block_4ECPbY"],"name":"Rich text","settings":{"padding":60,"text_color":"#606060","background_color":"#ffffff","comman_data_id":""}},"image_with_text_qajEaa":{"type":"image-with-text","custom_css":["{margin-top: 0px;}","@media screen and (max-width: 740px) {{margin-top: 0px; }}"],"settings":{"image":"shopify://shop_images/seamless_bikinis_for_women.jpg","image_position":"left","image_size":"medium","image_height":"natural","desktop_image_height":300,"mobile_image_height":300,"title":"","text":"<h4>About Us</h4><p>At Ocean Soul Swimwear, the ocean inspires everything we create. Our swimwear is made using luxurious recycled Italian Econyl fabric, transforming plastic waste into premium, high performance swimwear.</p><p>Every piece reflects our commitment to protecting the ocean while creating swimwear that lasts. Thoughtfully designed, responsibly made, and built to be worn again and again.</p><p><br/></p><p></p>","button_text":"","link":"","center_align":true,"text_color":"#606060","background_color":"#ffffff"}},"e3a92ac8-8141-4776-a2c4-816f55925246":{"type":"editorial-columns","blocks":{"template--14915046867033__e3a92ac8-8141-4776-a2c4-816f55925246-167765439648b2082e-0":{"type":"text_block","settings":{"image":"shopify://shop_images/surf_swimsuit_for_women.jpg","link":"shopify://pages/our-story","title_text":"","text":"<h4>Designed For the water</h4><p>Ocean Soul Swimwear was created by Georgie, an ocean lover who couldn’t find swimwear that truly worked in the water. After years of searching for suits that stayed on, lasted longer, and felt flattering during real movement, Ocean Soul was born.</p><p>Every design is informed by time spent in the ocean, with a focus on comfort, performance, and confidence without compromising on sustainability or style.</p>","button_text":"Our Story"}}},"block_order":["template--14915046867033__e3a92ac8-8141-4776-a2c4-816f55925246-167765439648b2082e-0"],"custom_css":["h3 {padding-top: 10px;}","p {padding: 0px;}","@media (max-width: 575px) {p {padding: 0px; }}"],"settings":{"title":"","center_align":true,"image_height":"fixed","desktop_fixed_height":350,"mobile_fixed_height":250,"section_space":"top_and_bottom"}},"collection_list_f8ATcj":{"type":"collection-list","blocks":{"featured_collection_wejjgw":{"type":"featured_collection","settings":{"collection":"sleeveless-one-piece-swimsuits"}},"featured_collection_YzhdLn":{"type":"featured_collection","settings":{"collection":"womens-wetsuit-springsuit"}},"featured_collection_wDawib":{"type":"featured_collection","settings":{"collection":"long-sleeve-one-piece-swimsuits"}},"featured_collection_FDwkfy":{"type":"featured_collection","settings":{"collection":"womens-rash-vest"}}},"block_order":["featured_collection_wejjgw","featured_collection_YzhdLn","featured_collection_wDawib","featured_collection_FDwkfy"],"custom_css":["@media (max-width: 740px) {.global__section.collection__list-section {margin-top: 25px !important; }}"],"settings":{"title":"EXPLORE OUR SUSTAINABLE SWIMWEAR","grid":4,"mobile_1pr":false,"section_space":"none"}},"map_nd6kTA":{"type":"map","settings":{"heading":"Visit Us in Bali","hours_heading":"","hours":"<p><strong>Monday - Sunday: </strong>9 am · 7pm</p><p><strong>Phone/WA </strong><a href=\"https://www.google.com/search?q=ocean+soul+bali&oq=ocean+soul+bali&gs_lcrp=EgZ