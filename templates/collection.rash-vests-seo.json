    "rich_text_D6cWwi": {
      "type": "rich-text",
      "blocks": {
        "text_block_XKkyTT": {
          "type": "text_block",
          "settings": {
            "title": "Women’s Rash Vests That Flatter, Protect & Move With You",
            "title_heading": true,
            "accordion_enabled": true,
            "text": "<p>Our women’s rash vests are designed for those who love the ocean and live in the sun. Whether you’re paddling out at first light, diving through reef breaks, or lounging between sets, these long sleeve rashguards blend high-performance protection with sleek, sculpting design.</p><p>Made from luxurious Italian recycled fabric, each women’s rash guard offers UPF 50+ sun protection and a buttery-soft feel that moves effortlessly with your body. The fit is feminine yet functional — tailored to flatter, while ensuring the freedom and flexibility you need in the water.</p><p>Unlike standard surf tops, our rash vests are double-lined for comfort and cut to stay in place, even through duck dives and wipeouts. Lightweight, quick-drying, and resistant to salt, sun, and chlorine, they’re built to last — performing season after season.</p>",
            "page": "",
            "center": true,
            "block_width": 100,
            "accordion_icon_color": "#000000",
            "accordion_icon_size": 20
          }
        }
