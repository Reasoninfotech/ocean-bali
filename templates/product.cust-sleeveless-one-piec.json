        "a34f6081-2778-463c-8074-6403bf19be80": {
          "type": "accordion_content",
          "settings": {
            "section_class": "section_class",
            "page": "",
            "title": "Shipping, Returns & Warranty",
            "text": "<p><strong>SHIPPING</strong></p><p>Worldwide<strong> </strong>shipping from Bali & Australia. Free EXPRESS Shipping for orders $250+ AUD.</p><p>International Express Shipping will be sent via DHL and will arrive in 2 - 4 days once dispatched.</p><p>Domestic Indonesian & Australian orders will be sent express and arrive in 1 - 3 days.</p><p>Please read more of our Shipping Policy <a href=\"/policies/shipping-policy\" title=\"Shipping Policy\">here.</a></p><p><strong>RETURNS/EXCHANGES</strong></p><p>We offer returns or exchanges for change of mind on full-price items, issued as a store credit.<br/><br/>Requests must be submitted within 30 days of dispatch.</p><p>Sale items are not eligible for return or exchange.</p><p>View our returns policy <a href=\"https://oceansoulbali.com/policies/refund-policy\" title=\"https://oceansoulbali.com/policies/refund-policy\">here.</a></p><p>Please follow instructions on our  <a href=\"https://www.oceansoulbali.com/policies/refund-policy\" title=\"https://www.oceansoulbali.com/policies/refund-policy\">Returns </a>page.</p><p><strong>WARRANTY</strong></p><p>We stand by the quality of every Ocean Soul swimsuit.</p><p>All pieces are crafted from premium Italian fabric and backed by a 12-month warranty covering materials, construction and hardware.</p><p>Read more about our warranty <a href=\"/pages/warranty\" title=\"Warranty\">here.</a></p>",
            "default_open_accordion": false
          }
        },
        "da5688b2-ac81-441f-ad20-d8c5bf5c3484": {
          "type": "accordion_content",
          "settings": {
            "section_class": "section_class",
            "page": "",
            "title": "Product Care",
            "text": "<p>To keep your long sleeve swimsuit looking its best:</p><p>Hand wash separately in cool water to maintain colour and shape.<br/><br/>Avoid machine washing, tumble drying, bleach and abrasive surfaces.</p><p>Do not leave wet in a bag.<br/><br/>Air dry in the shade - never in direct sun.</p>",
            "default_open_accordion": false
          }
        },
        "1ca9380c-dadf-4fef-ad75-c047058220da": {
