      "blocks": {
        "text_block_WUXzta": {
          "type": "text_block",
          "settings": {
            "title": "Sustainable Triangle Bikinis for Women Who Live in the Water",
            "title_heading": true,
            "accordion_enabled": true,
            "text": "<p>Our triangle bikinis are anything but basic. Designed for women who value style, comfort, and performance, these suits combine a flattering, timeless shape with technical features that make them perfect for active days in and around the water.</p><p>At Ocean Soul Swimwear, we believe a bikini should do more than just look good. That’s why every women’s triangle bikini in our collection is crafted from luxurious Italian recycled fabric - soft against your skin, resistant to chlorine and salt, and built to last season after season. Plus, with UPF 50+ sun protection, you can soak up the sun safely while enjoying a secure, supportive fit.</p>",
            "page": "",
            "center": true,
            "block_width": 100,
            "accordion_icon_color": "#000000",
            "accordion_icon_size": 20
          }
        }
      },
