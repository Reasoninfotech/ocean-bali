{"sections":{"breadcrumbs":{"type":"breadcrumbs","disabled":true,"settings":{}},"main":{"type":"main-page","disabled":true,"settings":{"page_width":100}},"28e89284-67d1-4e8e-961f-d5c1d80f5db2":{"type":"slideshow","blocks":{"template--14916695588953__28e89284-67d1-4e8e-961f-d5c1d80f5db2-1677890140c16a9835-0":{"type":"image","settings":{"image":"shopify://shop_images/Womens_one_piece_swimsuit_the_mentawai.jpg","overlay":false,"text_align":"left","caption_horizontal":50,"caption_vertical":50,"hide_caption_background":false,"caption_below":false,"heading":"Giving Back","subheading":"","link":"","button_text":"Button","second_link":"","second_button_text":"Button 2","slide_text_color":"#ffffff","cta_color":"#ffffff","cta_background":"#000000","caption_background":"rgba(0,0,0,0)","caption_background_opacity":10}}},"block_order":["template--14916695588953__28e89284-67d1-4e8e-961f-d5c1d80f5db2-1677890140c16a9835-0"],"settings":{"display_wide":true,"no_autoplay":false,"slider_speed":5,"pager":"dots","slideshow_size":"fixed_height","desktop_height":400,"mobile_height":400,"slide_heading_size":36,"subheading_size":14,"cta_size":14,"section_space":"none"}},"365af2a2-5b5f-44b4-8851-ecaccb2b9eba":{"type":"rich-text","blocks":{"template--14916695588953__365af2a2-5b5f-44b4-8851-ecaccb2b9eba-167789023800446739-0":{"type":"text_block","settings":{"title":"Why We Give to ROLE FOUNDATION","title_heading":true,"text":"<p><strong>Rivers | Ocean | Land | Environment</strong></p><p>ROLE'S mission centres around empowering individuals and businesses through education to improve their local environment and develop sustainable communities.</p><p></p>","page":"","center":true,"block_width":75}}},"block_order":["template--14916695588953__365af2a2-5b5f-44b4-8851-ecaccb2b9eba-167789023800446739-0"],"custom_css":["h3 {padding-bottom: 15px;}"],"settings":{"padding":30,"text_color":"#606060","background_color":"#ffffff"}},"db984e77-c031-408d-ab52-cf178c1300d6":{"type":"image-with-text","custom_css":[],"settings":{"image":"shopify://shop_images/two-piece-swimsuits.jpg","image_position":"left","image_size":"medium","image_height":"fixed","desktop_image_height":550,"mobile_image_height":450,"title":"","text":"<p>- Inspiring local government, businesses, and households to incorporate zero waste principles into their waste management system through comprehensive waste handling training.</p><p></p><p>- Empowering marginalised women and integrate them back into the economy through skills training.</p><p></p><p>- Developing young children into environmental believers.</p><p>- Researching and developing sustainable businesses and social enterprises that do not harm the environment.<br/></p>","button_text":"Button","link":"","center_align":false,"text_color":"#606060","background_color":"#ffffff"}},"c55e8ee7-878b-4b3f-832f-5bad55369ca7":{"type":"image-with-text","custom_css":["h3 {padding-bottom: 15px; line-height: 1.5;}"],"settings":{"image":"shopify://shop_images/Ocean_Soul_Bali_Sustainable_Swimwear_Giving_Back.jpg","image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":550,"mobile_image_height":450,"title":"","text":"<p>80% of Bali’s economy is supported by tourism.  The impact of tourism combined with local businesses and communities has a devastating impact on the environment.</p><p>We were blessed to connect with the late founder of ROLE many years ago. ROLE's vision and mission perfectly matched Ocean Soul Bali’s desire to protect the Island we all cherish.</p><p>Naturally, it only made sense to partner with an organisation with roots in Bali, to give back to the Island that we all love so much.<br/><br/></p>","button_text":"Button","link":"","center_align":false,"text_color":"#606060","background_color":"#ffffff"}},"e36f275f-305a-41fe-afec-27c9da3283a0":{"type":"slideshow","blocks":{"template--14916695588953__e36f275f-305a-41fe-afec-27c9da3283a0-1677890140c16a9835-0":{"type":"image","settings":{"image":"shopify://shop_images/PC092375-Edit-EditInstagram.jpg","overlay":false,"text_align":"left","caption_horizontal":50,"caption_vertical":50,"hide_caption_background":false,"caption_below":false,"heading":"","subheading":"","link":"","button_text":"Button","second_link":"","second_button_text":"Button 2","slide_text_color":"#000000","cta_color":"#ffffff","cta_background":"#000000","caption_background":"rgba(0,0,0,0)","caption_background_opacity":10}}},"block_order":["template--14916695588953__e36f275f-305a-41fe-afec-27c9da3283a0-1677890140c16a9835-0"],"settings":{"display_wide":true,"no_autoplay":false,"slider_speed":5,"pager":"dots","slideshow_size":"fixed_height","desktop_height":500,"mobile_height":500,"slide_heading_size":22,"subheading_size":14,"cta_size":14,"section_space":"top_and_bottom"}},"4242a6f4-30eb-4de5-87a7-b88256b73174":{"type":"image-with-text","settings":{"image":"shopify://shop_images/LONG_SLEEVE_SWIMSUITS_OCEAN_SOUL_BALI.jpg","image_position":"left","image_size":"medium","image_height":"fixed","desktop_image_height":550,"mobile_image_height":450,"title":"SUSTAINABLE SWIMWEAR THAT MAKES A DIFFERENCE","text":"<p>Our mission commenced when we wanted to create a long sleeve swimsuit that would provide comfort and durability in the water for our retreat clientele. We wanted to be sure we were producing ethical swimwear, that made an impact on everyone involved.</p><p>The team that create Ocean Soul Bali's sustainable swimwear, put so much time and effort into the production: even hand-printing sleeves with eco-friendly ink, along with their artisan-made, intricate sustainable accessories.</p><p>Ethical swimwear that supports a beautiful culture of artisans and sustainably sourced fabrics.<br/></p>","button_text":"Button","link":"","center_align":false,"text_color":"#606060","background_color":"#ffffff"}},"fb159bcb-b97d-4a3d-a069-cf625b402520":{"type":"image-with-text","custom_css":["div {padding-bottom: 15px;}"],"settings":{"image":"shopify://shop_images/DSC09086.jpg","image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":550,"mobile_image_height":450,"title":"","text":"<p>How fortunate we are as a mission-driven company to be able to donate a portion of the profit from our sustainable swimwear line towards an impactful purpose.<br/><br/>Your purchase of a sustainable bathing suit or hand made accessories helps support the community and environment in Bali.<br/><br/>It’s a powerful initiative we’re proud and honoured to support through our store.</p>","button_text":"Button","link":"","center_align":false,"text_color":"#606060","background_color":"#ffffff"}},"bf7851d2-1b6c-428a-a52f-d9ff0b5eab48":{"type":"collection-list","blocks":{"template--14916695588953__bf7851d2-1b6c-428a-a52f-d9ff0b5eab48-featured_collection-1":{"type":"featured_collection","settings":{"collection":"long-sleeve-one-piece-swimsuits"}},"template--14916695588953__bf7851d2-1b6c-428a-a52f-d9ff0b5eab48-featured_collection-2":{"type":"featured_collection","settings":{"collection":"surfing-swimsuits"}},"template--14916695588953__bf7851d2-1b6c-428a-a52f-d9ff0b5eab48-featured_collection-3":{"type":"featured_collection","settings":{"collection":"beach-accessories"}}},"block_order":["template--14916695588953__bf7851d2-1b6c-428a-a52f-d9ff0b5eab48-featured_collection-1","template--14916695588953__bf7851d2-1b6c-428a-a52f-d9ff0b5eab48-featured_collection-2","template--14916695588953__bf7851d2-1b6c-428a-a52f-d9ff0b5eab48-featured_collection-3"],"settings":{"title":"Shop our collections","grid":3,"mobile_1pr":false,"section_space":"top_and_bottom"}},"featured_blog_yePDaH":{"type":"featured-blog","name":"Blog posts","settings":{"title":"Blog posts","blog":"news","grid":3,"post_limit":3,"show_date":false,"show_author":false,"show_tags":false,"show_button":true,"section_space":"top_and_bottom"}}},"order":["breadcrumbs","main","28e89284-67d1-4e8e-961f-d5c1d80f5db2","365af2a2-5b5f-44b4-8851-ecaccb2b9eba","db984e77-c031-408d-ab52-cf178c1300d6","c55e8ee7-878b-4b3f-832f-5bad55369ca7","e36f275f-305a-41fe-afec-27c9da3283a0","4242a6f4-30eb-4de5-87a7-b88256b73174","fb159bcb-b97d-4a3d-a069-cf625b402520","bf7851d2-1b6c-428a-a52f-d9ff0b5eab48","featured_blog_yePDaH"]}