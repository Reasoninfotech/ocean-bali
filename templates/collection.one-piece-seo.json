        "text_block_3MBCdB": {
          "type": "text_block",
          "settings": {
            "title": "",
            "title_heading": false,
            "text": "<h4>Thoughtfully Made in Bali</h4><p>All Ocean Soul Swimwear is made ethically in Bali, where we produce in small batches to reduce waste and maintain quality. Every suit is cut, sewn, and inspected by hand to ensure it meets our high standards – and yours.</p><p>By choosing Ocean Soul, you're supporting fair wages, sustainable production, and slow fashion values that put people and the planet first.</p>",
            "page": "",
            "center": true,
            "block_width": 100
          }
        }
