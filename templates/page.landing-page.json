{"sections":{"breadcrumbs":{"type":"breadcrumbs","disabled":true,"settings":{}},"custom_liquid_FKheJf":{"type":"custom-liquid","name":"Custom liquid","settings":{"liquid":"<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap\" rel=\"stylesheet\">\n<style>\n/* ============================================================\n   OSB LANDING PAGE v2\n   Header/accent:  #77A5C8\n   CTA buttons:    #2E6688  (white text)\n   Body text:      #606060\n   Bg:             #ffffff / #f4f8fb / #eaf2f8\n   Font:           Montserrat\n   ============================================================ */\n\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n:root {\n  --osb-header:   #77A5C8;\n  --osb-cta:      #2E6688;\n  --osb-cta-hover:#245578;\n  --osb-light:    #eaf2f8;\n  --osb-mid:      #c5dcea;\n  --osb-pale:     #f4f8fb;\n  --osb-body:     #606060;\n  --osb-dark:     #2a2a2a;\n  --osb-muted:    #909090;\n  --osb-white:         #ffffff;\n  --osb-border:        #d6e6f0;\n  --osb-font:          'Montserrat', sans-serif;\n}\n\nbody { font-family: var(--osb-font); background: var(--osb-white); color: var(--osb-body); line-height: 1.6; font-size: 14px; }\nimg { max-width: 100%; display: block; }\na { text-decoration: none; }\n\n/* ===== ANNOUNCEMENT ===== */\n.osb-ann {\n  background: var(--osb-cta); color: white;\n  padding: 0.75rem 1rem;\n  display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap;\n  font-size: 12px; font-weight: 500; letter-spacing: 0.06em;\n}\n.osb-cd { display: flex; gap: 4px; align-items: center; }\n.osb-cd-u {\n  background: rgba(255,255,255,0.2); padding: 2px 8px; border-radius: 3px;\n  font-size: 16px; font-weight: 700; min-width: 34px; text-align: center;\n}\n.osb-cd-l { font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; display: block; text-align: center; font-weight: 400; }\n.osb-cd-sep { opacity: 0.6; }\n\n/* ===== HERO ===== */\n.osb-hero {\n  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;\n  max-width: 1200px; margin: 0 auto; padding: 4rem 5%;\n}\n.osb-stars-row { display: flex; align-items: center; gap: 8px; margin-bottom: 1.2rem; }\n.osb-stars { color: var(--osb-header); font-size: 16px; letter-spacing: 2px; }\n.osb-rc { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--osb-muted); }\n.osb-h1 { font-size: clamp(26px, 3.5vw, 42px); font-weight: 700; line-height: 1.15; color: var(--osb-header); margin-bottom: 1rem; letter-spacing: -0.01em; }\n.osb-sub { font-size: 14px; font-weight: 400; color: var(--osb-body); line-height: 1.8; margin-bottom: 1.5rem; max-width: 440px; }\n\n.osb-list { list-style: none; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.6rem; }\n.osb-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; font-weight: 400; color: var(--osb-body); line-height: 1.5; }\n.osb-check { width: 18px; height: 18px; background: var(--osb-header); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }\n.osb-check svg { width: 10px; height: 10px; stroke: white; fill: none; stroke-width: 2.5; }\n\n.osb-btn {\n  display: inline-block; background: var(--osb-cta); color: var(--osb-white);\n  font-family: var(--osb-font); font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;\n  padding: 16px 36px; border: none; cursor: pointer; transition: background 0.2s;\n  border-radius: 3px; text-align: center; width: 100%; max-width: 340px;\n}\n.osb-btn:hover { background: var(--osb-cta-hover); }\n\n.osb-code {\n  font-size: 11px; color: var(--osb-muted); text-align: center; margin-top: 0.6rem;\n  max-width: 340px; border: 1px dashed var(--osb-mid); padding: 7px 14px; border-radius: 3px;\n}\n\n.osb-usps { display: flex; gap: 1.2rem; margin-top: 1.8rem; flex-wrap: wrap; }\n.osb-usp { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; min-width: 80px; }\n.osb-usp-icon {\n  width: 44px; height: 44px; border: 1.5px solid var(--osb-mid); border-radius: 50%;\n  display: flex; align-items: center; justify-content: center; background: var(--osb-pale);\n}\n.osb-usp-icon svg { width: 18px; height: 18px; stroke: var(--osb-cta); fill: none; stroke-width: 1.5; }\n.osb-usp-lbl { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--osb-muted); text-align: center; }\n\n.osb-media {\n  background: var(--osb-light); aspect-ratio: 4/5; display: flex; align-items: center;\n  justify-content: center; border-radius: 4px; overflow: hidden;\n}\n.osb-media img { width: 100%; height: 100%; object-fit: cover; }\n.osb-ph { font-size: 13px; font-style: italic; color: var(--osb-mid); text-align: center; padding: 2rem; line-height: 1.8; }\n\n/* ===== PR STRIP ===== */\n.osb-pr { background: var(--osb-pale); padding: 2rem 5%; border-top: 1px solid var(--osb-border); border-bottom: 1px solid var(--osb-border); }\n.osb-pr-lbl { text-align: center; font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--osb-muted); margin-bottom: 1.5rem; }\n.osb-pr-grid { display: flex; justify-content: center; align-items: center; gap: 1.2rem; flex-wrap: wrap; max-width: 900px; margin: 0 auto; }\n.osb-pr-logo {\n  background: var(--osb-white); border: 1px solid var(--osb-border); width: 130px; height: 54px;\n  display: flex; align-items: center; justify-content: center; opacity: 0.6; transition: opacity 0.2s;\n  font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--osb-muted); font-weight: 600; border-radius: 3px;\n}\n.osb-pr-logo:hover { opacity: 0.9; }\n\n/* ===== SECTION HELPERS ===== */\n.osb-2col {\n  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;\n  max-width: 1200px; margin: 0 auto; padding: 5rem 5%;\n}\n.osb-2col.osb-flip > .osb-media { order: -1; }\n.osb-sec-h { font-size: clamp(20px, 2.8vw, 32px); font-weight: 700; line-height: 1.25; color: var(--osb-header); margin-bottom: 1.2rem; letter-spacing: -0.01em; }\n.osb-sec-p { font-size: 13px; font-weight: 400; color: var(--osb-body); line-height: 1.85; margin-bottom: 1.2rem; }\n.osb-sec-title { text-align: center; font-size: clamp(22px, 2.8vw, 32px); font-weight: 700; color: var(--osb-header); margin-bottom: 3rem; letter-spacing: -0.01em; }\n\n/* ===== UGC GRID ===== */\n.osb-ugc { background: var(--osb-pale); padding: 3rem 5%; border-top: 1px solid var(--osb-border); }\n.osb-ugc-h { text-align: center; font-size: 22px; font-weight: 700; color: var(--osb-header); margin-bottom: 2rem; }\n.osb-ugc-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; max-width: 1200px; margin: 0 auto; }\n.osb-ugc-item { aspect-ratio: 1; background: var(--osb-light); overflow: hidden; border-radius: 3px; }\n.osb-ugc-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }\n.osb-ugc-item:hover img { transform: scale(1.04); }\n\n/* ===== REVIEWS ===== */\n.osb-reviews { background: var(--osb-white); padding: 5rem 5%; }\n.osb-rev-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto; }\n.osb-rev-card { border: 1px solid var(--osb-border); padding: 2rem; border-radius: 6px; display: flex; flex-direction: column; gap: 1rem; }\n.osb-rev-stars { color: var(--osb-header); font-size: 14px; letter-spacing: 2px; text-align: center; }\n.osb-rev-text { font-size: 13px; font-style: italic; color: var(--osb-body); line-height: 1.8; text-align: center; }\n.osb-rev-auth { text-align: center; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--osb-dark); }\n.osb-rev-ver { font-size: 11px; font-style: italic; color: var(--osb-header); text-transform: none; letter-spacing: 0; font-weight: 400; display: block; }\n\n/* ===== HOW IT WORKS ===== */\n.osb-how { background: var(--osb-pale); padding: 5rem 5%; border-top: 1px solid var(--osb-border); }\n.osb-vid {\n  background: var(--osb-light); max-width: 800px; margin: 0 auto 3rem;\n  aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;\n  border-radius: 6px; border: 1px solid var(--osb-border); cursor: pointer;\n}\n.osb-play { width: 64px; height: 64px; border: 2px solid var(--osb-cta); border-radius: 50%; display: flex; align-items: center; justify-content: center; background: white; transition: background 0.2s; }\n.osb-vid:hover .osb-play { background: var(--osb-cta); }\n.osb-vid:hover .osb-play svg { stroke: white; }\n.osb-play svg { width: 22px; height: 22px; stroke: var(--osb-cta); fill: none; stroke-width: 1.5; margin-left: 3px; }\n.osb-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto; }\n.osb-step { background: var(--osb-white); border: 1px solid var(--osb-border); overflow: hidden; border-radius: 6px; }\n.osb-step-img { background: var(--osb-light); aspect-ratio: 4/3; }\n.osb-step-img img { width: 100%; height: 100%; object-fit: cover; }\n.osb-step-body { padding: 1.2rem 1.4rem 1.6rem; }\n.osb-step-n { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--osb-header); margin-bottom: 0.35rem; }\n.osb-step-t { font-size: 15px; font-weight: 700; color: var(--osb-dark); margin-bottom: 0.5rem; }\n.osb-step-d { font-size: 13px; color: var(--osb-body); line-height: 1.7; }\n\n/* ===== ICON STRIP ===== */\n.osb-icons { background: var(--osb-white); padding: 2rem 5%; border-top: 1px solid var(--osb-border); border-bottom: 1px solid var(--osb-border); }\n.osb-icon-lbl { text-align: center; font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--osb-muted); margin-bottom: 1.5rem; }\n.osb-icon-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }\n.osb-icon-scroll::-webkit-scrollbar { display: none; }\n.osb-icon-track { display: flex; gap: 10px; padding: 4px 0 8px; width: max-content; margin: 0 auto; }\n.osb-chip { background: var(--osb-pale); border: 1px solid var(--osb-border); padding: 0.8rem 1.2rem; display: flex; flex-direction: column; align-items: center; gap: 6px; min-width: 96px; border-radius: 4px; }\n.osb-chip svg { width: 20px; height: 20px; stroke: var(--osb-cta); fill: none; stroke-width: 1.5; }\n.osb-chip-lbl { font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--osb-body); text-align: center; line-height: 1.4; }\n\n/* ===== WHY US ===== */\n.osb-why { background: var(--osb-white); padding: 5rem 5%; }\n.osb-why-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; max-width: 1200px; margin: 0 auto; }\n.osb-why-h { font-size: clamp(22px, 2.8vw, 34px); font-weight: 700; color: var(--osb-header); margin-bottom: 0.8rem; letter-spacing: -0.01em; }\n.osb-why-p { font-size: 13px; color: var(--osb-body); line-height: 1.8; margin-bottom: 1.8rem; }\n.osb-acc { border-top: 1px solid var(--osb-border); }\n.osb-acc-item { border-bottom: 1px solid var(--osb-border); }\n.osb-acc-btn { width: 100%; background: none; border: none; padding: 1.1rem 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; text-align: left; gap: 1rem; font-family: var(--osb-font); }\n.osb-acc-txt { font-size: 13px; font-weight: 600; color: var(--osb-dark); }\n.osb-acc-arr { width: 26px; height: 26px; background: var(--osb-cta); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.25s; }\n.osb-acc-arr svg { width: 13px; height: 13px; stroke: white; fill: none; stroke-width: 2; }\n.osb-acc-item.open .osb-acc-arr { transform: rotate(180deg); }\n.osb-acc-body { display: none; padding: 0 0 1.2rem; font-size: 13px; color: var(--osb-body); line-height: 1.8; }\n.osb-acc-item.open .osb-acc-body { display: block; }\n.osb-why-img { background: var(--osb-light); aspect-ratio: 3/4; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 4px; }\n.osb-why-img img { width: 100%; height: 100%; object-fit: cover; }\n\n/* ===== COMPARE ===== */\n.osb-cmp { background: var(--osb-pale); padding: 5rem 5%; border-top: 1px solid var(--osb-border); }\n.osb-cmp-hd { display: grid; grid-template-columns: 1fr 100px 100px; gap: 1rem; padding: 0 1rem 0.8rem; border-bottom: 2px solid var(--osb-header); max-width: 900px; margin: 0 auto 0; align-items: center; }\n.osb-cmp-brand { display: flex; align-items: center; gap: 10px; }\n.osb-logo-mark { width: 28px; height: 28px; background: var(--osb-cta); border-radius: 50%; display: flex; align-items: center; justify-content: center; }\n.osb-logo-mark svg { width: 14px; height: 14px; fill: white; }\n.osb-cmp-brand span { font-size: 13px; font-weight: 700; color: var(--osb-dark); }\n.osb-cmp-col { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--osb-muted); text-align: center; }\n.osb-cmp-col.us { color: var(--osb-cta); }\n.osb-cmp-rows { max-width: 900px; margin: 0 auto; }\n.osb-cmp-row { display: grid; grid-template-columns: 1fr 100px 100px; align-items: center; padding: 0.85rem 1rem; gap: 1rem; }\n.osb-cmp-row:nth-child(odd) { background: var(--osb-white); border-radius: 3px; }\n.osb-cmp-txt { font-size: 13px; color: var(--osb-body); }\n.osb-cmp-tick { text-align: center; font-size: 16px; font-weight: 700; }\n.osb-tick { color: var(--osb-cta); }\n.osb-cross { color: #c8c8c8; }\n\n/* ===== EXPERT ===== */\n.osb-expert { background: var(--osb-white); padding: 5rem 5%; text-align: center; border-top: 1px solid var(--osb-border); }\n.osb-circles { display: flex; justify-content: center; margin-bottom: 2rem; }\n.osb-circle { width: 90px; height: 90px; border-radius: 50%; background: var(--osb-light); border: 3px solid var(--osb-white); box-shadow: 0 0 0 1px var(--osb-border); overflow: hidden; margin-left: -16px; }\n.osb-circle:first-child { margin-left: 0; }\n.osb-exp-h { font-size: clamp(20px, 2.8vw, 32px); font-weight: 700; color: var(--osb-header); margin-bottom: 1rem; letter-spacing: -0.01em; }\n.osb-exp-p { font-size: 13px; color: var(--osb-body); max-width: 580px; margin: 0 auto 2rem; line-height: 1.85; }\n\n/* ===== FAQ ===== */\n.osb-faq { background: var(--osb-pale); padding: 5rem 5%; border-top: 1px solid var(--osb-border); }\n.osb-faq-inner { max-width: 760px; margin: 0 auto; }\n.osb-faq-h { font-size: clamp(22px, 2.8vw, 32px); font-weight: 700; color: var(--osb-dark); margin-bottom: 2.5rem; text-align: center; letter-spacing: -0.01em; }\n.osb-faq-item { border-bottom: 1px solid var(--osb-border); }\n.osb-faq-btn { width: 100%; background: none; border: none; padding: 1.2rem 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; text-align: left; gap: 1rem; font-family: var(--osb-font); }\n.osb-faq-q { font-size: 13px; font-weight: 600; color: var(--osb-dark); }\n.osb-faq-ico { width: 24px; height: 24px; border: 1.5px solid var(--osb-cta); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s, transform 0.25s; }\n.osb-faq-ico svg { width: 12px; height: 12px; stroke: var(--osb-cta); fill: none; stroke-width: 2.5; }\n.osb-faq-item.open .osb-faq-ico { background: var(--osb-cta); transform: rotate(45deg); }\n.osb-faq-item.open .osb-faq-ico svg { stroke: white; }\n.osb-faq-ans { display: none; padding: 0 0 1.2rem; font-size: 13px; color: var(--osb-body); line-height: 1.85; }\n.osb-faq-item.open .osb-faq-ans { display: block; }\n\n/* ===== FINAL CTA ===== */\n.osb-cta-strip { background: var(--osb-cta); padding: 4.5rem 5%; text-align: center; }\n.osb-cta-h { font-size: clamp(24px, 3.5vw, 42px); font-weight: 700; color: white; margin-bottom: 0.6rem; letter-spacing: -0.01em; }\n.osb-cta-sub { font-size: 14px; font-weight: 400; color: rgba(255,255,255,0.7); margin-bottom: 2rem; }\n.osb-btn-wht { display: inline-block; background: white; color: var(--osb-cta); font-family: var(--osb-font); font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 16px 48px; border-radius: 3px; transition: background 0.2s; }\n.osb-btn-wht:hover { background: var(--osb-pale); }\n.osb-ship { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 1.2rem; }\n\n/* ===== RESPONSIVE ===== */\n@media (max-width: 768px) {\n  .osb-hero, .osb-2col, .osb-why-inner { grid-template-columns: 1fr; gap: 2rem; }\n  .osb-2col.osb-flip > .osb-media { order: 0; }\n  .osb-rev-grid, .osb-steps { grid-template-columns: 1fr; }\n  .osb-ugc-grid { grid-template-columns: repeat(3, 1fr); }\n  .osb-cmp-hd, .osb-cmp-row { grid-template-columns: 1fr 70px 70px; }\n}\n</style>\n\n<!-- OSB SECTION 1: HERO + ANNOUNCEMENT BAR + PR LOGOS -->\n\n<section class=\"osb-ann\">\n  <div class=\"osb-cd\">\n    <div><div class=\"osb-cd-u\" id=\"cd-h\">04</div><span class=\"osb-cd-l\">Hours</span></div>\n    <span class=\"osb-cd-sep\">:</span>\n    <div><div class=\"osb-cd-u\" id=\"cd-m\">47</div><span class=\"osb-cd-l\">Mins</span></div>\n    <span class=\"osb-cd-sep\">:</span>\n    <div><div class=\"osb-cd-u\" id=\"cd-s\">59</div><span class=\"osb-cd-l\">Secs</span></div>\n  </div>\n  <span>Offer ends soon - get <strong>$20 off</strong> your first order with code <strong>FB20</strong></span>\n</section>\n\n<div style=\"background:var(--osb-white);\">\n  <div class=\"osb-hero\">\n    <div>\n      <div class=\"osb-stars-row\">\n        <span class=\"osb-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</span>\n        <span class=\"osb-rc\">800+ Five-Star Reviews</span>\n      </div>\n      <h1 class=\"osb-h1\">Finally - a swimsuit that actually stays on in the ocean.</h1>\n      <p class=\"osb-sub\">No adjusting. No pulling. No second-guessing.<br>The Sulawesi is built for movement - from duck dives to long swims - so you can focus on the water, not your suit.</p>\n      <ul class=\"osb-list\">\n        <li><span class=\"osb-check\"><svg viewBox=\"0 0 12 9\" xmlns=\"http://www.w3.org/2000/svg\"><polyline points=\"1,4.5 4,8 11,1\" fill=\"none\" stroke=\"white\" stroke-width=\"2\"/></svg></span>Stays secure through surf, dives, and waves</li>\n        <li><span class=\"osb-check\"><svg viewBox=\"0 0 12 9\" xmlns=\"http://www.w3.org/2000/svg\"><polyline points=\"1,4.5 4,8 11,1\" fill=\"none\" stroke=\"white\" stroke-width=\"2\"/></svg></span>Sculpting fit that holds you in (without digging in)</li>\n        <li><span class=\"osb-check\"><svg viewBox=\"0 0 12 9\" xmlns=\"http://www.w3.org/2000/svg\"><polyline points=\"1,4.5 4,8 11,1\" fill=\"none\" stroke=\"white\" stroke-width=\"2\"/></svg></span>Designed for real movement - not just how it looks</li>\n      </ul>\n      <a href=\"#\" class=\"osb-btn\">Shop The Sulawesi &rarr;</a>\n      <p class=\"osb-code\">Get <strong>$20 off</strong> your first order with code <strong>FB20</strong></p>\n      <div class=\"osb-usps\">\n        <div class=\"osb-usp\">\n          <div class=\"osb-usp-icon\"><svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" stroke-width=\"1.5\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg></div>\n          <span class=\"osb-usp-lbl\">UPF 50+</span>\n        </div>\n        <div class=\"osb-usp\">\n          <div class=\"osb-usp-icon\"><svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" stroke-width=\"1.5\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg></div>\n          <span class=\"osb-usp-lbl\">Ethically Made</span>\n        </div>\n        <div class=\"osb-usp\">\n          <div class=\"osb-usp-icon\"><svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" stroke-width=\"1.5\"><polyline points=\"23 6 13.5 15.5 8.5 10.5 1 18\"/><polyline points=\"17 6 23 6 23 12\"/></svg></div>\n          <span class=\"osb-usp-lbl\">Eco Fabric</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"osb-media\">\n      <!-- REPLACE with your product image: -->\n      <!-- <img src=\"{{ 'your-image.jpg' | asset_url }}\" alt=\"The Sulawesi long sleeve swimsuit\"> -->\n      <p class=\"osb-ph\">Add your product image or video here</p>\n    </div>\n  </div>\n</div>\n\n<section class=\"osb-pr\">\n  <p class=\"osb-pr-lbl\">As Seen In</p>\n  <div class=\"osb-pr-grid\">\n    <!-- REPLACE with your publication logos: <img src=\"{{ 'logo.png' | asset_url }}\" alt=\"Publication\"> -->\n    <div class=\"osb-pr-logo\">Vogue Australia</div>\n    <div class=\"osb-pr-logo\">Broadsheet</div>\n    <div class=\"osb-pr-logo\">Who Magazine</div>\n    <div class=\"osb-pr-logo\">Body + Soul</div>\n    <div class=\"osb-pr-logo\">Surf Life</div>\n    <div class=\"osb-pr-logo\">Eco Warrior</div>\n  </div>\n</section>\n\n<script>\n(function(){\n  var end=new Date();\n  end.setHours(end.getHours()+4,end.getMinutes()+47,end.getSeconds()+59);\n  function pad(n){return String(n).padStart(2,'0');}\n  function tick(){\n    var d=Math.max(0,end-new Date());\n    var hE=document.getElementById('cd-h'),mE=document.getElementById('cd-m'),sE=document.getElementById('cd-s');\n    if(hE)hE.textContent=pad(Math.floor(d/3600000));\n    if(mE)mE.textContent=pad(Math.floor((d%3600000)/60000));\n    if(sE)sE.textContent=pad(Math.floor((d%60000)/1000));\n    if(d>0)setTimeout(tick,1000);\n  }\n  tick();\n})();\n</script>","display_wide":false}},"main":{"type":"main-contact-page","disabled":true,"settings":{"page_width":100}},"image_with_text_xM64ak":{"type":"image-with-text","name":"Image with text","settings":{"image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":550,"mobile_image_height":450,"title":"Finally - a swimsuit that actually stays on.","text":"<p>⭐ ⭐ ⭐ ⭐ ⭐ 800+ Five-Star Reviews </p><p>Sun-safe, sculpting, and made to move. The Sulawesi goes from surf session to sunset without slipping, sagging, or letting you down.</p><ul><li>UPF 50+ full-sleeve sun protection — all day in the water</li><li>Sculpting panelled fit with cinched waist — holds you in perfectly</li><li>Recycled Italian ECONYL® fabric — soft, chlorine-resistant, lasts 2× longer</li></ul>","button_text":"Button","link":"","center_align":false,"text_color":"#606060","background_color":"#f7f7f7"}}},"order":["breadcrumbs","custom_liquid_FKheJf","main","image_with_text_xM64ak"]}