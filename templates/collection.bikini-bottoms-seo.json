      "type": "image-with-text",
      "name": "Image with text",
      "settings": {
        "image": "shopify://shop_images/Ocean-Soul-3_merry_amber_copy.jpg",
        "image_position": "left",
        "image_size": "medium",
        "image_height": "fixed",
        "desktop_image_height": 450,
        "mobile_image_height": 450,
        "title": "How to Style Your Bikini Bottoms",
        "text": "<p>Mix and match across our collections to create your perfect set:</p><p>Pair a high waisted bottom with a triangle bikini top for classic balance.<br/></p><p>Team a low rise bikini bottom with a surf bikini top for athletic appeal.<br/></p><p>Style a string bikini bottom with a one shoulder bikini top for modern femininity.<br/></p><p>Layer your seamless bikini bottoms under a long sleeve rashguard for extra sun protection.<br/></p><p>Add a resort sarong, wide-leg lounge pants, or bamboo clutch for an easy beach-to-brunch transition.</p>",
        "button_text": "Button",
