ck_qkVtaG","text_block_QdG4zM","text_block_p9jfUa","text_block_xDnJR3","text_block_FKexVK","text_block_w4KLhb"],"settings":{"title":"As seen in","center_align":false,"show_description":true,"image_height":"none","desktop_fixed_height":500,"mobile_fixed_height":250,"section_space":"top_and_bottom"}},"product-content":{"type":"main-product-content","blocks":{"28dd0a33-d199-4642-860b-b3860292a2ba":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/ugc_media_grid\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{}}},"block_order":["28dd0a33-d199-4642-860b-b3860292a2ba"],"disabled":true,"settings":{"background":"#f9f9f9","allow_multiple":false}},"1706838275a57a97e2":{"type":"apps","blocks":{"judge_me_reviews_review_widget_dnn9wA":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/review_widget\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{"review_data":"sample_data","max_width":1200,"show_shop_reviews":false,"empty_state":"empty_widget"}},"judge_me_reviews_all_reviews_text_AFWeEb":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/all_reviews_text\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","disabled":true,"settings":{}}},"block_order":["judge_me_reviews_review_widget_dnn9wA","judge_me_reviews_all_reviews_text_AFWeEb"],"settings":{"display_wide":false}},"product-recommendations":{"type":"product-recommendations","disabled":true,"custom_css":["div {padding-bottom: 10px;}"],"settings":{"product_recommendations_heading":"You may also like","per_row":4,"limit":8}},"ffd7507a-dce2-40e6-af87-0e8a295f7ef6":{"type":"editorial-columns","blocks":{"8743bf57-6b1a-4f8c-8988-5e42ae277901":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/Untitled_f9ddb395-843c-4ce9-8df6-f4d27f3560a4.jpg","link":"","title_text":"The Perfect one piece","text":"<p>Our two piece bikinis are made with  a luxurious sustainable buttery soft fabric. <br\/>They are the perfect intersection of sporty and fashionable.  With a comfortable seamless design, both functional and flattering paired with a tailored feminine design that is suitable for leisure or athletic activities.<\/p>","button_text":"Button"}},"a5eb81f9-4c92-4ecc-bf0a-6c9cf53eb6cf":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/Square_naut.png","link":"","title_text":"Designed for comfort","text":"<p>We’ve designed our swimsuits for comfort right down to the smallest detail.  The luxuriously soft fabric, double lined, with innovative cupless support and smooth seams will hold you in and support you, with all your water activities.<\/p>","button_text":"Button"}},"167e640a-03e8-48de-b93f-07bbc26e1244":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/Ocean_Soul_Bali_Sustainable_Swimwear_Sustainable_Fabric.jpg","link":"","title_text":"Sustainable Swim","text":"<p>We value slow fashion over fast with a focus on sustainable fabrics and ethical production. Crafted from regenerated nylon that is designed to last twice as long as your regular swimsuit. Our swimwear is designed & made in Bali with love, with 10% of each sale donated to those in need through our Giving Back initiative. <\/p>","button_text":"Button"}}},"block_order":["8743bf57-6b1a-4f8c-8988-5e42ae277901","a5eb81f9-4c92-4ecc-bf0a-6c9cf53eb6cf","167e640a-03e8-48de-b93f-07bbc26e1244"],"disabled":true,"custom_css":["h3 {padding-top: 20px;}"],"settings":{"title":"","center_align":true,"image_height":"fixed","desktop_fixed_height":350,"mobile_fixed_height":250,"section_space":"top_and_bottom"}},"accordion_K3YKGe":{"type":"accordion","blocks":{"accordion_pane_m6HGAA":{"type":"accordion_pane","disabled":true,"settings":{"title":"Does the white one piece swimsuit get transparent when wet?","content":"<p>We line all our white one piece swimsuits with a beige econyl sustainable fabric, to prevent them from becoming transparent.<\/p>"}},"accordion_pane_zwBQPA":{"type":"accordion_pane","disabled":true,"settings":{"title":"Are black one piece swimsuits flattering?","content":"<p>Black one piece swimsuits are known for there slimming properties. The dark colour creates an illusion of a more streamlined silhouette by minimising the appearance of bulges and creating a sleeker overall look.<\/p><p><\/p>"}},"accordion_pane_cYX4Eg":{"type":"accordion_pane","disabled":true,"settings":{"title":"What can I wear over a one piece swimsuit?","content":"<p>You can pair them with anything your heart desires!  If looking for a chic resort feel, they look great with the Sunday Pant or the Jogger.  For a more casual look you can pair with a saronf<\/p>"}},"accordion_pane_Py7J3k":{"type":"accordion_pane","disabled":true,"settings":{"title":"How does the low back design enhance the look of the swimsuit?","content":"<p>The low back design of our black one-piece swimwear adds a touch of elegance and allure to the overall look. It creates a flattering silhouette while showcasing just the right amount of skin, making it both chic and sophisticated.<\/p>"}},"accordion_pane_ArMU9p":{"type":"accordion_pane","disabled":true,"settings":{"title":"Can I wear this swimsuit for both lounging and swimming?","content":"<p>Absolutely! Our black one-piece swimwear with a low back is versatile enough to be worn for lounging by the pool or beach as well as for swimming. The high-quality materials and secure fit provide both comfort and functionality, allowing you to enjoy any water activity with confidence.<\/p>"}},"accordion_pane_QVTBMM":{"type":"accordion_pane","disabled":true,"settings":{"title":"Is the low back design supportive enough for all-day wear?","content":"<p>Absolutely! Despite its elegant low back design, our black one-piece swimsuit offers ample support and comfort for extended wear. The carefully engineered construction ensures a secure and flattering fit, allowing you to move with confidence.<\/p>"}}},"block_order":["accordion_pane_m6HGAA","accordion_pane_zwBQPA","accordion_pane_cYX4Eg","accordion_pane_Py7J3k","accordion_pane_ArMU9p","accordion_pane_QVTBMM"],"disabled":true,"settings":{"ti