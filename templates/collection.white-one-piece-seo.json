    "image_with_text_k8yAFW": {
      "type": "image-with-text",
      "name": "Image with text",
      "settings": {
        "image": "shopify://shop_images/Ag_4.jpg",
        "image_position": "right",
        "image_size": "medium",
        "image_height": "fixed",
        "desktop_image_height": 300,
        "mobile_image_height": 300,
        "title": "Why Choose a White One Piece Swimsuit?",
        "text": "<p>Not Just White - White That Flatters, Supports & Stays Put.</p><p>White swimwear is notoriously tricky - but we’ve solved the common pain points. Ocean Soul’s white one piece swimsuits are:</p><p>Double-lined for full opacity (not see-through when wet)</p><p>Seamless for a smooth, second-skin feel</p><p>Made from high-quality Italian eco-fabric that sculpts and holds</p><p>Whether you're diving under waves or lounging in the sun, these suits give you confidence in and out of the water.</p>",
        "button_text": "Button",
        "link": "",
        "center_align": true,
        "text_color": "#504e4e",
        "background_color": "#f7f7f7"
      }
    },
    "image_with_text_rfjCAy": {
      "type": "image-with-text",
      "name": "Image with text",
      "settings": {
        "image": "shopify://shop_images/agnesnicolee_2nd_collab1_1_5a50f82e-1762-42b2-8dd3-6aac0d5ba2e7.jpg",
        "image_position": "left",
        "image_size": "medium",
        "image_height": "fixed",
        "desktop_image_height": 300,
        "mobile_image_height": 300,
        "title": "Designed for Movement & Built to Stay On",
        "text": "<p>Every swimsuit in this collection is performance-tested by women who surf, freedive, paddle, and move. Our long sleeve white swimsuits offer enhanced sun protection and stay secure through every duck dive. Our sleeveless one pieces are perfect for lap swimming or pairing with resortwear for a beach-to-bar look.</p><p>This is swimwear that stays on, no matter the activity - and makes you feel amazing while doing it.</p>",
        "button_text": "Button",
        "link": "",
        "center_align": true,
        "text_color": "#606060",
        "background_color": "#f7f7f7"
      }
    },
