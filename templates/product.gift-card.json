    "5a8ae58c-582e-47f6-b743-c942aae4345c": {
      "type": "editorial-columns",
      "blocks": {
        "template--14915046834265__5a8ae58c-582e-47f6-b743-c942aae4345c-16779008892c1eca16-0": {
          "type": "text_block",
          "settings": {
            "image": "shopify://shop_images/nomadbythesea-bikini1_Product_Page_-_Shopify_Size-17.jpg",
            "link": "",
            "title_text": "Perfect two piece cut",
            "text": "<p>Our two piece bikinis are made with  a luxurious sustainable buttery soft fabric. <br/>They are the perfect intersection of sporty and fashionable.  With a comfortable seamless design, both functional and flattering and a tailored feminine design that is suitable for leisure or athletic activities.</p>",
            "button_text": "Button"
          }
        },
        "template--14915046834265__5a8ae58c-582e-47f6-b743-c942aae4345c-16779008892c1eca16-1": {
          "type": "text_block",
          "settings": {
            "image": "shopify://shop_images/aq222493_tahliabourke_by_clementinebourke_Product_Page_-_Shopify_Size-244.jpg",
            "link": "",
            "title_text": "Designed for comfort",
            "text": "<p>We’ve designed our swimsuits for comfort right down to the smallest detail.  The luxuriously soft fabric, double lined, with innovative cupless support and smooth seams will hold you in and support you, with all your water activities.</p>",
            "button_text": "Button"
          }
        },
        "template--14915046834265__5a8ae58c-582e-47f6-b743-c942aae4345c-16779008892c1eca16-2": {
          "type": "text_block",
          "settings": {
            "image": "shopify://shop_images/aq222287_tahliabourke_by_clementinebourke_Product_Page_-_Shopify_Size-241.jpg",
            "link": "",
            "title_text": "Sustainable Swim",
            "text": "<p>We value slow fashion over fast with a focus on sustainable fabrics and ethical production. Crafted from regenerated nylon that is designed to last twice as long as your regular swimsuit. Our swimwear is designed & made in Bali with love, with 10% of each sale donated to those in need through our Giving Back initiative. </p>",
            "button_text": "Button"
          }
        }
      },
