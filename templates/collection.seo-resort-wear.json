    "rich_text_tP7fVH": {
      "type": "rich-text",
      "blocks": {
        "text_block_4hibpw": {
          "type": "text_block",
          "settings": {
            "title": "",
            "title_heading": false,
            "accordion_enabled": false,
            "text": "<p>Each garment in our resort wear range is made from eco-conscious fabrics that are soft, quick-drying, and built to last. Designed for warm climates and active lifestyles, they keep you cool in the heat and comfortable throughout the day. Whether you’re exploring the coastline, lounging by the pool, or enjoying lunch with friends, our styles move with you.</p><p>Complete your look with our curated accessories - a tote wet bag to carry your essentials, or a chic bamboo clutch that transitions beautifully from day to night. Every detail in this collection reflects our commitment to quality, sustainability, and effortless elegance.</p>",
            "page": "",
            "center": true,
            "block_width": 100,
            "accordion_icon_color": "#000000",
            "accordion_icon_size": 20
          }
        }
      },
