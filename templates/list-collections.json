    "slideshow_MFWW6B": {
      "type": "slideshow",
      "blocks": {
        "image_6dWrjG": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/khat.mandu_by_fabianmunozhumeres-9.jpg",
            "overlay": false,
            "text_align": "left",
            "caption_horizontal": 50,
            "caption_vertical": 50,
            "mobile_image": "shopify://shop_images/khat.mandu_by_fabianmunozhumeres-9.jpg",
            "hide_caption_background": false,
            "caption_below": false,
            "heading": "",
            "subheading": "<p>Our <a href=\"/collections/one-piece-swimsuit\" title=\"One Piece Swimsuits\">one piece swimwear</a> is made to sculpt and stay in place — no matter how you move. From sleek sleeveless silhouettes to high-performance long sleeve bathers, each suit is double-lined for support (without padding), ethically crafted, and made from eco-conscious fabrics. </p><p></p>",
