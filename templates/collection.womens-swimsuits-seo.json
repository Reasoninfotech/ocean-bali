with_text","disabled":true,"settings":{"rating":5,"title":"Helpful support team","text":"<p>Add a few sentences of text from a customer testimonial to your store.</p>","author":"A. Customer","button_text":"Button","link":""}}},"block_order":["template--14915046801497__9326baf0-7c60-406b-a886-d60675c97f4f-product-1","template--14915046801497__9326baf0-7c60-406b-a886-d60675c97f4f-image_with_text-1"],"settings":{"image_position":"left","text_color":"#606060","star_color":"#dbaf59","background_color":"#f7f7f7"}},"website_logos_Fdgq3w":{"type":"website-logos","blocks":{"text_block_rgYDwn":{"type":"text_block","settings":{"image":"shopify://shop_images/british_vogue.png","link":"","text":"","button_text":"Button"}},"text_block_Pgbg7k":{"type":"text_block","settings":{"image":"shopify://shop_images/PngItem_171373.png","link":"","text":"","button_text":"Button"}},"text_block_h34JYb":{"type":"text_block","settings":{"image":"shopify://shop_images/Herald_Sun_logo_logotype.png","link":"","text":"","button_text":"Button"}},"text_block_FbREtW":{"type":"text_block","settings":{"image":"shopify://shop_images/surfgirl_2fd2b878-a25c-4248-afde-faa68bc8d31f.png","link":"","text":"","button_text":"Button"}},"text_block_qGjLjn":{"type":"text_block","settings":{"image":"shopify://shop_images/The_Daily_Telegraph_Australien_logo.png","link":"","text":"","button_text":"Button"}},"text_block_LJJwcM":{"type":"text_block","settings":{"image":"shopify://shop_images/georgina_monti.png","link":"","text":"","button_text":"Button"}},"text_block_ymMRPp":{"type":"text_block","settings":{"image":"shopify://shop_images/honeycombers.svg","link":"","text":"","button_text":"Button"}},"text_block_r4jTA4":{"type":"text_block","settings":{"image":"shopify://shop_images/acc.png","link":"","text":"","button_text":"Button"}}},"block_order":["text_block_rgYDwn","text_block_Pgbg7k","text_block_h34JYb","text_block_FbREtW","text_block_qGjLjn","text_block_LJJwcM","text_block_ymMRPp","text_block_r4jTA4"],"settings":{"title":"As seen in","center_align":true,"show_description":false,"image_height":"none","desktop_fixed_height":550,"mobile_fixed_height":400,"section_space":"top"}},"image_with_text_hXwG7k":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/black_one_piece_swimsuit_The_Mentawai.jpg","image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":300,"mobile_image_height":300,"title":"Long Sleeve & One Piece Swimsuits for Women","text":"<p>Flatter your figure and protect your skin with our sculpting long sleeve and one piece swimsuits - thoughtfully designed for sun safety, style, and secure movement. Whether you're surfing, swimming, or relaxing under the sun, these suits offer UPF 50+ protection, sleek silhouettes, and all-day confidence.</p><p>Our women’s one piece swimwear stays put through every wave and is crafted with buttery-soft recycled fabric that smooths and supports without the need for padding. With a focus on fit, function, and timeless design, these swimsuits are made to move with you - and last season after season.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"image_with_text_DWq78t":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/Two_piece_surf_swimsuit_The_Aceh.jpg","image_position":"left","image_size":"medium","image_height":"fixed","desktop_image_height":300,"mobile_image_height":300,"title":"Two Piece Swimwear & Surf Bikinis","text":"<p>Our <a href=\"/collections/seamless-bikinis\" title=\"Seamless Bikinis & Two Pieces\">two piece swimwear</a> is built for comfort, movement, and confidence. Seamless and double-lined, our surf bikinis are designed to stay in place through every duck dive. Whether you're chasing waves or chasing kids, these sets won't let you down.</p><p>Choose from high-waisted bikini bottoms, minimalist string bikini tops, or sculpting crop tops - all made from recycled eco-fabric that feels as good as it looks.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"image_with_text_m83PkX":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/Ocean_soul_-_2023_-_wetsuit_-_26_047554da-e1ff-4f6f-821f-e218696706c1.jpg","image_position":"right","image_size":"medium","image_height":"fixed","desktop_image_height":300,"mobile_image_height":300,"title":"Eco-Conscious Women’s Wetsuits","text":"<p>Our <a href=\"/collections/womens-wetsuit-springsuit\" title=\"Women's Wetsuits\">women’s wetsuits</a> are made from limestone-based neoprene, offering thermal insulation without petroleum-based materials. Designed with the same sculpting panel details as our swimsuits, they hug your body while offering warmth, comfort, and flexibility.</p><p>Ideal for transitional weather and cold-water surf, our womens wetsuits prove that performance and sustainability can absolutely go hand in hand.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"f26cc161-299a-4e72-b685-5f171aefa332":{"type":"collection-list","blocks":{"template--14915046801497__f26cc161-299a-4e72-b685-5f171aefa332-1686291657b52ade79-1":{"type":"featured_collection","settings":{"collection":"one-piece-swimsuit"}},"template--14915046801497__f26cc161-299a-4e72-b685-5f171aefa332-1686291657b52ade79-0":{"type":"featured_collection","settings":{"collection":"beach-resort-wear"}},"0f2747bb-2657-4f85-bf78-ad91229e7931":{"type":"featured_collection","settings":{"collection":"womens-bikinis"}},"template--14915046801497__f26cc161-299a-4e72-b685-5f171aefa332-1686291657b52ade79-2":{"type":"featured_collection","settings":{"collection":"beach-accessories"}}},"block_order":["template--14915046801497__f26cc161-299a-4e72-b685-5f171aefa332-1686291657b52ade79-1","template--14915046801497__f26cc161-299a-4e72-b685-5f171aefa332-1686291657b52ade79-0","0f2747bb-2657-4f85-bf78-ad91229e7931","template--14915046801497__f26cc161-299a-4e72-b685-5f171aefa332-1686291657b52ade79-2"],"disabled":true,"settings":{"title":"SHOP OUR SUSTAINABLE SWIM & ACCESSORIES","grid":4,"mobile_1pr":false,"section_space":"top_and_bottom"}},"image_with_text_WjV37j":{"type":"image-with-text","name":"Image with text","settings":{"image":"shopify://shop_images/Triangle_string_bikini_green.png","image_position":"left","image_size":"medium","image_height":"fixed","desktop_image_height":400,"mobile_image_height":450,"title":"","text":"<h2>Not Just Swimwear – A Lifestyle Choice</h2><p>Ocean Soul Swimwear isn’t just about what you wear - it’s about how it makes you feel. Confident. Supported. Free. Every style is created for women who want to move freely, protect their skin, and honour the planet.</p><p>Whether you're new to sustainable swimwear or ready to upgrade your entire collection, this is where style, support, and sustainability unite.</p>","button_text":"Button","link":"","center_align":true,"text_color":"#606060","background_color":"#f7f7f7"}},"collage_D9WKVT":{"type":"collage","blocks":{"image_Ra3p8G":{"type":"image","disabled":true,"settings":{"image":"shopify://shop_images/Triangle_string_bikini_green.png","image_size":"none","link":"","column_size":3}},"text_hGrcaw":{"type":"text","settings":{"title_text":"","text":"<h2>Not Just Swimwear – A Lifestyle Choice</h2><p>Ocean Soul Swimwear isn’t just about what you wear — it’s about how it makes you feel. Confident. Supported. Free. Every style is created for women who want to move freely, protect their skin, and honour the planet.</p><p>Whether you're new to sustainable swimwear or ready to upgrade your entire collection, this is where style, support, and sustainability unite.</p><p>Explore the full collection now and find the suit that fits your life — and your values.</p>","center_align":true,"column_size":3}},"image_HyTRDn":{"type":"image","disabled":true,"settings":{"image":"shopify://shop_images/white_long_sleeve_one_piece_swimsuit.jpg","image_size":"none","link":"","column_size":2}}},"block_order":["image_Ra3p8G","text_hGrcaw","image_HyTRDn"],"disabled":true,"name":"Collage","settings":{"display_wide":true,"no_space":true,"section_space":"top_and_bottom"}},"1711706852d17457ff":{"type":"apps","blocks":{"judge_me_reviews_all_reviews_text_3pLhrc":{"type":"shopify://apps/judge-me-reviews/blocks/all_reviews_text/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","disabled":true,"settings":{}}},"block_order":["judge_me_reviews_all_reviews_text_3pLhrc"],"settings":{"display_wide":false}},"instafeed_pz7EeE":{"type":"instafeed","disabled":true,"settings":{"heading_size":20,"feed_width":100,"html_area":""}},"jdgm_widget_code_UGEwGM":{"type":"jdgm-widget-code","name":"UGC code","settings":{}},"richtext_editorial_columns_JaR6JN":{"type":"richtext-editorial-columns","blocks":{"text_block_6mWbN9":{"type":"text_block","settings":{"title":"Why Women Around the World Choose Ocean Soul Swimwear","title_heading":true,"text":"<h3></h3><p>Flattering Sculpting Fit - Seamless construction, waist-defining panels, and smoothing fabric designed to flatter without padding.<br/><br/>Stays On in Surf & Movement - Built and tested for active water sports. Surf, dive, swim - no slips, sags, or shifting.<br/><br/>Sun Protection - All long sleeve swimwear and rash guards are UPF 50+.<br/><br/>Sustainable & Ethical - Made with ECONYL® recycled yarn and manufactured in small batches in Bali.<br/><br/>Stylish, Timeless, and Functional - Our colour palette and cuts are designed to last season after season.</p>","page":"","center":true,"block_width":100}}},"block_order":["text_block_6mWbN9"],"name":"Richtext Editorial","settings":{"padding":30,"text_color":"#606060","background_color":"#ffffff","title":"","center_align":true,"image_height":"none","desktop_fixed_height":500,"mobile_fixed_height":250,"section_space":"none"}},"collection_list_FzREhh":{"type":"collection-list","bl