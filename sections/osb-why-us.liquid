{% comment %}
  OSB - Why Us Accordion Section
  Section: osb-why-us.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-why-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_mobile }}px 5% {{ section.settings.padding_bottom_mobile }}px;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-why-{{ section.id }} .osb-why-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }

  .osb-why-{{ section.id }} .osb-why-h {
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 0.8rem;
    letter-spacing: -0.01em;
  }

  .osb-why-{{ section.id }} .osb-why-p {
    font-size: 13px;
    color: #606060;
    line-height: 1.8;
    margin-bottom: 1.8rem;
  }

  .osb-why-{{ section.id }} .osb-acc {
    border-top: 1px solid #d6e6f0;
  }

  .osb-why-{{ section.id }} .osb-acc-item {
    border-bottom: 1px solid #d6e6f0;
  }

  .osb-why-{{ section.id }} .osb-acc-btn {
    width: 100%;
    background: none;
    border: none;
    padding: 1.1rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    text-align: left;
    gap: 1rem;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-why-{{ section.id }} .osb-acc-txt {
    font-size: 13px;
    font-weight: 600;
    color: #2a2a2a;
  }

  .osb-why-{{ section.id }} .osb-acc-arr {
    width: 26px;
    height: 26px;
    background: {{ section.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.25s;
  }

  .osb-why-{{ section.id }} .osb-acc-arr svg {
    width: 13px;
    height: 13px;
    stroke: white;
    fill: none;
    stroke-width: 2;
  }

  .osb-why-{{ section.id }} .osb-acc-item.open .osb-acc-arr {
    transform: rotate(180deg);
  }

  .osb-why-{{ section.id }} .osb-acc-body {
    display: none;
    padding: 0 0 1.2rem;
    font-size: 13px;
    color: #606060;
    line-height: 1.8;
  }

  .osb-why-{{ section.id }} .osb-acc-item.open .osb-acc-body {
    display: block;
  }

  .osb-why-{{ section.id }} .osb-why-img {
    background: #eaf2f8;
    aspect-ratio: {{ section.settings.image_ratio }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
  }

  .osb-why-{{ section.id }} .osb-why-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .osb-why-{{ section.id }} {
      padding: {{ section.settings.padding_top_tablet }}px 5% {{ section.settings.padding_bottom_tablet }}px;
    }
    .osb-why-{{ section.id }} .osb-why-h {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-why-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px 5% {{ section.settings.padding_bottom_desktop }}px;
    }
    .osb-why-{{ section.id }} .osb-why-inner {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .osb-why-{{ section.id }} .osb-why-h {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-why-{{ section.id }}">
  <div class="osb-why-inner">
    <div>
      <h2 class="osb-why-h">{{ section.settings.heading }}</h2>
      {% if section.settings.body_1 != blank %}
      <p class="osb-why-p">{{ section.settings.body_1 }}</p>
      {% endif %}
      {% if section.settings.body_2 != blank %}
      <p class="osb-why-p" style="font-weight:600;color:#2a2a2a;">{{ section.settings.body_2 }}</p>
      {% endif %}

      <div class="osb-acc">
        {% for block in section.blocks %}
          {% if block.type == 'accordion' %}
          <div class="osb-acc-item{% if forloop.first %} open{% endif %}" {{ block.shopify_attributes }}>
            <button class="osb-acc-btn">
              <span class="osb-acc-txt">{{ block.settings.question }}</span>
              <span class="osb-acc-arr">
                <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </button>
            <div class="osb-acc-body">{{ block.settings.answer }}</div>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="osb-why-img">
      {% if section.settings.section_image != blank %}
        {%- capture why_us_image_src -%}
          {% render 'imagekit', src: section.settings.section_image | image_url: width: 800 %}
        {%- endcapture -%}
        <img src="{{ why_us_image_src | strip }}" loading="lazy" alt="{{ section.settings.section_image.alt | escape }}">
      {% else %}
        <p style="font-size:13px;font-style:italic;color:#c5dcea;text-align:center;padding:2rem;line-height:1.8;">Upload product lifestyle image</p>
      {% endif %}
    </div>
  </div>
</section>

<script>
(function(){
  var accs = document.querySelectorAll('.osb-why-{{ section.id }} .osb-acc-btn');
  accs.forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = btn.closest('.osb-acc-item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.osb-why-{{ section.id }} .osb-acc-item').forEach(function(x){ x.classList.remove('open'); });
      if(!isOpen) item.classList.add('open');
    });
  });
})();
</script>
{% endif %}

{% schema %}
{
  "name": "OSB Why Us Accordion",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What makes it different?"
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Body Text 1",
      "default": "Most swimwear is designed to look good standing still. The Sulawesi is designed for what actually happens in the water."
    },
    {
      "type": "text",
      "id": "body_2",
      "label": "Bold Closing Line",
      "default": "That's the difference."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Section Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "3/4", "label": "Tall (3:4)" },
        { "value": "4/5", "label": "Portrait (4:5)" },
        { "value": "1/1", "label": "Square (1:1)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 16,
      "step": 1,
      "label": "Image Border Radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#77A5C8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accordion Arrow Color",
      "default": "#2E6688"
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 36,
      "step": 1,
      "label": "Heading Size (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Mobile)",
      "default": 48
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 20,
      "max": 40,
      "step": 1,
      "label": "Heading Size (Tablet)",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Tablet)",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Tablet)",
      "default": 56
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 22,
      "max": 44,
      "step": 1,
      "label": "Heading Size (Desktop)",
      "default": 34
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Bottom Padding (Desktop)",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question / Title",
          "default": "It actually stays on - even in big surf"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer / Body",
          "default": "The Sulawesi uses structured panelling and a secure, snug cut that grips your body without digging in."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OSB Why Us Accordion",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "question": "It actually stays on - even in big surf",
            "answer": "The Sulawesi uses structured panelling and a secure, snug cut that grips your body without digging in. Engineered to move with you through waves, dives, and bodysurf sessions."
          }
        },
        {
          "type": "accordion",
          "settings": {
            "question": "UPF 50+ sun protection all day long",
            "answer": "The long-sleeve design and darker colourways offer maximum UPF 50+ block-out. Spend all day in the water without worrying about UV damage to your arms, shoulders, and chest."
          }
        },
        {
          "type": "accordion",
          "settings": {
            "question": "Recycled Italian ECONYL® - luxury with a conscience",
            "answer": "ECONYL® is regenerated nylon made from ocean waste like discarded fishing nets. Buttery-soft, lasts twice as long as regular swimwear, and fully recyclable at end of life."
          }
        },
        {
          "type": "accordion",
          "settings": {
            "question": "Ethically made in Bali - fair wages, small batches",
            "answer": "Every Sulawesi is handmade in our Canggu studio by skilled local makers with fair pay and safe conditions. Small-batch production means higher quality on every single piece."
          }
        },
        {
          "type": "accordion",
          "settings": {
            "question": "12-month warranty and easy returns",
            "answer": "We stand behind every suit. If the fabric, make, or hardware fails within 12 months, we'll replace it - no questions asked. Returns and exchanges on full-price items are simple."
          }
        }
      ]
    }
  ]
}
{% endschema %}
