{% comment %}
  OSB - PR / Press Logos Strip
  Section: osb-pr-logos.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-pr-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_mobile }}px 5%;
    border-top: 1px solid #d6e6f0;
    border-bottom: 1px solid #d6e6f0;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-pr-{{ section.id }} .osb-pr-lbl {
    text-align: center;
    font-size: {{ section.settings.label_size_mobile }}px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #909090;
    margin-bottom: 1.5rem;
  }

  .osb-pr-{{ section.id }} .osb-pr-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    max-width: 900px;
    margin: 0 auto;
  }

  .osb-pr-{{ section.id }} .osb-pr-logo {
    background: {{ section.settings.logo_bg }};
    border: 1px solid #d6e6f0;
    width: {{ section.settings.logo_width_mobile }}px;
    height: {{ section.settings.logo_height_mobile }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
    transition: opacity 0.2s;
    border-radius: 3px;
    overflow: hidden;
  }

  .osb-pr-{{ section.id }} .osb-pr-logo:hover {
    opacity: 0.9;
  }

  .osb-pr-{{ section.id }} .osb-pr-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8px;
  }

  .osb-pr-{{ section.id }} .osb-pr-logo-text {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #909090;
    font-weight: 600;
    text-align: center;
    padding: 0 8px;
  }

  @media (min-width: 768px) {
    .osb-pr-{{ section.id }} {
      padding: {{ section.settings.padding_tablet }}px 5%;
    }
    .osb-pr-{{ section.id }} .osb-pr-lbl {
      font-size: {{ section.settings.label_size_tablet }}px;
    }
    .osb-pr-{{ section.id }} .osb-pr-logo {
      width: {{ section.settings.logo_width_tablet }}px;
      height: {{ section.settings.logo_height_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-pr-{{ section.id }} {
      padding: {{ section.settings.padding_desktop }}px 5%;
    }
    .osb-pr-{{ section.id }} .osb-pr-lbl {
      font-size: {{ section.settings.label_size_desktop }}px;
    }
    .osb-pr-{{ section.id }} .osb-pr-logo {
      width: {{ section.settings.logo_width_desktop }}px;
      height: {{ section.settings.logo_height_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-pr-{{ section.id }}">
  <p class="osb-pr-lbl">{{ section.settings.label_text }}</p>
  <div class="osb-pr-grid">
    {% for block in section.blocks %}
      {% if block.type == 'logo' %}
      <div class="osb-pr-logo" {{ block.shopify_attributes }}>
        {% if block.settings.logo_image != blank %}
          {%- capture logo_src -%}
            {% render 'imagekit', src: block.settings.logo_image | image_url: width: 260 %}
          {%- endcapture -%}
          <img src="{{ logo_src | strip }}" loading="lazy" alt="{{ block.settings.logo_name | escape }}">
        {% else %}
          <span class="osb-pr-logo-text">{{ block.settings.logo_name }}</span>
        {% endif %}
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "OSB PR Logos Strip",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Section Label",
      "default": "As Seen In"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f8fb"
    },
    {
      "type": "color",
      "id": "logo_bg",
      "label": "Logo Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "min": 30,
      "max": 100,
      "step": 5,
      "label": "Logo Opacity (%)",
      "default": 60
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "min": 16,
      "max": 60,
      "step": 4,
      "label": "Vertical Padding (Mobile)",
      "default": 28
    },
    {
      "type": "range",
      "id": "label_size_mobile",
      "min": 8,
      "max": 14,
      "step": 1,
      "label": "Label Font Size (Mobile)",
      "default": 10
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "min": 80,
      "max": 160,
      "step": 5,
      "label": "Logo Width (Mobile)",
      "default": 100
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "min": 36,
      "max": 70,
      "step": 2,
      "label": "Logo Height (Mobile)",
      "default": 46
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "padding_tablet",
      "min": 16,
      "max": 60,
      "step": 4,
      "label": "Vertical Padding (Tablet)",
      "default": 32
    },
    {
      "type": "range",
      "id": "label_size_tablet",
      "min": 8,
      "max": 14,
      "step": 1,
      "label": "Label Font Size (Tablet)",
      "default": 10
    },
    {
      "type": "range",
      "id": "logo_width_tablet",
      "min": 100,
      "max": 180,
      "step": 5,
      "label": "Logo Width (Tablet)",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_height_tablet",
      "min": 40,
      "max": 80,
      "step": 2,
      "label": "Logo Height (Tablet)",
      "default": 52
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "min": 20,
      "max": 80,
      "step": 4,
      "label": "Vertical Padding (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "label_size_desktop",
      "min": 8,
      "max": 14,
      "step": 1,
      "label": "Label Font Size (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "min": 110,
      "max": 200,
      "step": 5,
      "label": "Logo Width (Desktop)",
      "default": 130
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "min": 44,
      "max": 80,
      "step": 2,
      "label": "Logo Height (Desktop)",
      "default": 54
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image",
          "info": "Please upload your logo image. Image is required and will be given first priority."
        },
        {
          "type": "text",
          "id": "logo_name",
          "label": "Logo Name (fallback text)",
          "default": "Publication Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OSB PR Logos Strip",
      "blocks": [
        { "type": "logo", "settings": { "logo_name": "Vogue Australia" } },
        { "type": "logo", "settings": { "logo_name": "Broadsheet" } },
        { "type": "logo", "settings": { "logo_name": "Who Magazine" } },
        { "type": "logo", "settings": { "logo_name": "Body + Soul" } },
        { "type": "logo", "settings": { "logo_name": "Surf Life" } },
        { "type": "logo", "settings": { "logo_name": "Eco Warrior" } }
      ]
    }
  ]
}
{% endschema %}
