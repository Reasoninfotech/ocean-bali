{%- liquid
  assign hd_locale_selector = false
  assign hd_currency_selector = false

  if section.settings.show_country_selector and localization.available_countries.size > 1
    assign hd_currency_selector = true
  endif

  if section.settings.show_locale_selector and localization.available_languages.size > 1
    assign hd_locale_selector = true
  endif

  if section.settings.announcement_text != blank or section.blocks.size > 0
    assign announcement = true
  endif

  if section.settings.full_width_header
    assign is_full_width = true
  endif
-%}

{% if hd_locale_selector or hd_currency_selector %}
  {{ 'component-header-disclosures.css' | asset_url | stylesheet_tag }}
{% endif %}

<header
  class="announcement__bar-section js-top-bar"
  data-section-id="{{ section.id }}"
  data-section-type="announcement-bar-section"
>
  {% if is_full_width %}
    <div class="gridlock-fluid">
  {% endif %}
  <div class="row grid__wrapper" id="upper-content">
    {%- liquid
      if announcement
        assign side_grid = 'span-1'
        assign grid_class = 'span-10'
      else
        assign side_grid = 'span-6'
        assign grid_class = 'span-12'
      endif
    -%}
    
    {%- render 'social-icons',
      wrapper: '.announcement__bar-section',
      fill_color: 'var(--announcement-text)',
      hover_color: 'var(--announcement-text)',
      social_grid: side_grid | append: ' auto sm-hide v-center'
    -%}

    {% if announcement %}
      <div
        id="hello"
        class="{{ grid_class }} auto sm-span-12 v-center"
        style="display: flex; flex-direction: column; align-items: center; justify-content: center;"
      >
        <div id="announcement-bar" style="text-align: center; width: 100%; padding-bottom: 5px; overflow: hidden; min-height: 40px; display: flex; flex-direction: column; justify-content: center;">
          {%- liquid
            assign base_target_1 = section.settings.target_1_amount | default: 100
            assign target_1_amount = base_target_1 | times: 100
            assign tier_1_default = 'FREE EXPRESS SHIPPING ON ORDERS OVER [target_1]!'
            assign tier_1_text = section.settings.tier_1_text | default: tier_1_default
          -%}

          <div id="announcement-text-container" style="overflow: hidden; width: 100%;">
            <div class="{% if section.settings.enable_scrolling %}announcement-marquee__inner{% else %}announcement-static__wrapper{% endif %}" style="display: flex; align-items: center; width: 100%;">
              
              {% capture dynamic_message %}
                <span class="js-dynamic-announcement" style="white-space: nowrap; color: rgb(46, 102, 136);">
                  {% capture formatted_target_1 %}
                    <span class="format-money" data-amount="{{ target_1_amount }}">{{ target_1_amount | money }}</span>
                  {% endcapture %}
                  {{ tier_1_text | replace: '[target_1]', formatted_target_1 | replace: '[TARGET_1]', formatted_target_1 | replace: '[amount]', formatted_target_1 | replace: '[AMOUNT]', formatted_target_1 }}
                </span>
              {% endcapture %}

              {% if section.settings.enable_scrolling %}
                {% for i in (1..10) %}
                  {{ dynamic_message }}
                  <span class="separator"></span>
                  {% for block in section.blocks %}
                    <span class="announcement-marquee__item" {{ block.shopify_attributes }} style="display: inline-flex; align-items: center; gap: 8px;">
                      {% if block.settings.image_before != blank %}
                        {% assign img_url = block.settings.image_before | img_url: '100x' %}
                        <img src="{{ img_url }}" alt="{{ block.settings.image_before.alt }}" style="max-width: {{ block.settings.image_max_width_before }}px; height: auto; flex-shrink: 0;" loading="lazy">
                      {% endif %}
                      
                      {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" style="color: inherit; text-decoration: none;">{% endif %}
                      {{ block.settings.text }}
                      {% if block.settings.link != blank %}</a>{% endif %}

                      {% if block.settings.image_after != blank %}
                        {% assign img_url = block.settings.image_after | img_url: '100x' %}
                        <img src="{{ img_url }}" alt="{{ block.settings.image_after.alt }}" style="max-width: {{ block.settings.image_max_width_after }}px; height: auto; flex-shrink: 0;" loading="lazy">
                      {% endif %}
                    </span>
                    <span class="separator"></span>
                  {% endfor %}
                {% endfor %}
              {% else %}
                <div style="display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 20px; width: 100%;">
                   <p style="margin: 0; font-size: var(--announcement-text-size); line-height: 1.5; letter-spacing: 0.5px; display: flex; align-items: center;">
                    {{ dynamic_message }}
                  </p>
                  {% for block in section.blocks %}
                    <span class="announcement-item" {{ block.shopify_attributes }} style="font-size: var(--announcement-text-size); display: inline-flex; align-items: center; gap: 8px;">
                      {% if block.settings.image_before != blank %}
                        {% assign img_url = block.settings.image_before | img_url: '100x' %}
                        <img src="{{ img_url }}" alt="{{ block.settings.image_before.alt }}" style="max-width: {{ block.settings.image_max_width_before }}px; height: auto; flex-shrink: 0;" loading="lazy">
                      {% endif %}
                      
                      {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" style="color: inherit; text-decoration: none;">{% endif %}
                      {{ block.settings.text }}
                      {% if block.settings.link != blank %}</a>{% endif %}

                      {% if block.settings.image_after != blank %}
                        {% assign img_url = block.settings.image_after | img_url: '100x' %}
                        <img src="{{ img_url }}" alt="{{ block.settings.image_after.alt }}" style="max-width: {{ block.settings.image_max_width_after }}px; height: auto; flex-shrink: 0;" loading="lazy">
                      {% endif %}
                    </span>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="progress-bar-container"
            style="background-color: #ededed; border-radius: 10px; height: 8px; max-width: 300px; margin: 8px auto 0; overflow: hidden;"
          >
            <div
              id="announcement-progress-fill"
              style="width: 0%; background-color: #2e6688; height: 100%; transition: width 0.3s ease;"
            ></div>
          </div>
        </div>

        <script>
          document.addEventListener("DOMContentLoaded", function () {
              let target1Set = {{ section.settings.target_1_amount | default: 100 | json }};
              let target2Set = {{ section.settings.target_2_amount | default: 150 | json }};
              let target3Set = {{ section.settings.target_3_amount | default: 250 | json }};

              const baseTarget1Amount = (isNaN(target1Set) || target1Set <= 0 ? 100 : target1Set) * 100;
              const baseTarget2Amount = (isNaN(target2Set) || target2Set <= 0 ? 150 : target2Set) * 100;
              const baseTarget3Amount = (isNaN(target3Set) || target3Set <= 0 ? 250 : target3Set) * 100;

              let activeTarget1Amount = baseTarget1Amount;
              let activeTarget2Amount = baseTarget2Amount;
              let activeTarget3Amount = baseTarget3Amount;

              const textTier1 = {{ section.settings.tier_1_text | default: "FREE EXPRESS SHIPPING ON ORDERS OVER [target_1]!" | json }};
              const textTier2 = {{ section.settings.tier_2_text | default: "YOU ARE ONLY [remaining_1] AWAY FROM FREE EXPRESS SHIPPING!" | json }};
              const textTier3 = {{ section.settings.tier_3_text | default: "YOU GOT FREE SHIPPING! SPEND [remaining_2] MORE FOR A FREE VISOR!" | json }};
              const textTier4 = {{ section.settings.tier_4_text | default: "YOU GOT FREE SHIPPING & VISOR! SPEND [remaining_3] MORE FOR A FREE SARONG!" | json }};
              const textTier5 = {{ section.settings.tier_5_text | default: "YOUR ORDER QUALIFIES FOR FREE EXPRESS SHIPPING, FREE VISOR & FREE SARONG!" | json }};

              let activeCurrency = 'AUD';
              if (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) {
                  activeCurrency = window.Shopify.currency.active;
              }

              function formatMoneyElements() {
                  const elements = document.querySelectorAll(".format-money");
                  elements.forEach(function (el) {
                      let amountInCents = parseInt(el.dataset.amount);
                      if (!isNaN(amountInCents)) {
                          try {
                              const formatter = new Intl.NumberFormat(undefined, {
                                  style: 'currency',
                                  currency: activeCurrency,
                                  currencyDisplay: 'narrowSymbol',
                                  minimumFractionDigits: 2
                              });
                              el.innerText = formatter.format(amountInCents / 100);
                          } catch (e) {
                              if (window.Shopify && window.Shopify.formatMoney) {
                                  el.innerText = window.Shopify.formatMoney(amountInCents);
                              } else {
                                  el.innerText = '$' + (amountInCents / 100).toFixed(2);
                              }
                          }
                      }
                  });
              }

              function updateAnnouncementBar(cartTotalCents) {
                  const containers = document.querySelectorAll(".js-dynamic-announcement");
                  const fillBar = document.getElementById("announcement-progress-fill");
                  if (!containers.length || !fillBar) return;

                  let progress = (cartTotalCents / activeTarget3Amount) * 100;
                  if (progress > 100) progress = 100;
                  fillBar.style.width = progress + '%';

                  let html = '';
                  let fTarget1 = '<span class="format-money" data-amount="' + activeTarget1Amount + '"></span>';
                  let fTarget2 = '<span class="format-money" data-amount="' + activeTarget2Amount + '"></span>';
                  let fTarget3 = '<span class="format-money" data-amount="' + activeTarget3Amount + '"></span>';

                  if (cartTotalCents === 0) {
                      html = textTier1.replace(/\[target_1\]/gi, fTarget1).replace(/\[amount\]/gi, fTarget1);
                  } else if (cartTotalCents < activeTarget1Amount) {
                      let remaining = activeTarget1Amount - cartTotalCents;
                      let fRemaining = '<span class="format-money" data-amount="' + remaining + '"></span>';
                      html = textTier2.replace(/\[target_1\]/gi, fTarget1).replace(/\[amount\]/gi, fTarget1).replace(/\[remaining_1\]/gi, fRemaining).replace(/\[remaining\]/gi, fRemaining);
                  } else if (cartTotalCents < activeTarget2Amount) {
                      let remaining = activeTarget2Amount - cartTotalCents;
                      let fRemaining = '<span class="format-money" data-amount="' + remaining + '"></span>';
                      html = textTier3.replace(/\[target_2\]/gi, fTarget2).replace(/\[remaining_2\]/gi, fRemaining);
                  } else if (cartTotalCents < activeTarget3Amount) {
                      let remaining = activeTarget3Amount - cartTotalCents;
                      let fRemaining = '<span class="format-money" data-amount="' + remaining + '"></span>';
                      html = textTier4.replace(/\[target_3\]/gi, fTarget3).replace(/\[remaining_3\]/gi, fRemaining);
                  } else {
                      html = textTier5;
                  }

                  containers.forEach(container => {
                      container.innerHTML = html;
                  });
                  formatMoneyElements();
              }

              function loadCartAndUpdate() {
                  fetch('/cart.js', { cache: 'no-store' })
                      .then(response => response.json())
                      .then(cart => {
                          updateAnnouncementBar(cart.total_price);
                      })
                      .catch(e => console.error("Error fetching cart data:", e));
              }

              // ⚡ KEY FIX: Instant render - no wave loader, no blank screen
              function initialize() {
                  updateAnnouncementBar(0); // Instantly show Tier 1 text

                  if (activeCurrency === 'AUD') {
                      loadCartAndUpdate();
                  } else if (window.Shopify && window.Shopify.currency && window.Shopify.currency.rate) {
                      activeTarget1Amount = Math.round(baseTarget1Amount * window.Shopify.currency.rate);
                      activeTarget2Amount = Math.round(baseTarget2Amount * window.Shopify.currency.rate);
                      activeTarget3Amount = Math.round(baseTarget3Amount * window.Shopify.currency.rate);
                      loadCartAndUpdate();
                  } else {
                      fetch('https://open.er-api.com/v6/latest/AUD')
                          .then(res => res.json())
                          .then(data => {
                              if (data && data.rates && data.rates[activeCurrency]) {
                                  activeTarget1Amount = Math.round(baseTarget1Amount * data.rates[activeCurrency]);
                                  activeTarget2Amount = Math.round(baseTarget2Amount * data.rates[activeCurrency]);
                                  activeTarget3Amount = Math.round(baseTarget3Amount * data.rates[activeCurrency]);
                              }
                              loadCartAndUpdate();
                          })
                          .catch(e => {
                              loadCartAndUpdate();
                          });
                  }
              }

              initialize();

              // System Interceptors for AJAX Carts
              const originalFetch = window.fetch;
              window.fetch = function () {
                  return originalFetch.apply(this, arguments).then(function (res) {
                      const url = res.url || "";
                      if (url.includes('/cart/add') || url.includes('/cart/change') || url.includes('/cart/update') || url.includes('/cart/clear')) {
                          setTimeout(loadCartAndUpdate, 400);
                      }
                      return res;
                  });
              };

              const originalXHR = window.XMLHttpRequest.prototype.open;
              window.XMLHttpRequest.prototype.open = function () {
                  this.addEventListener('load', function () {
                      const url = this.responseURL || "";
                      if (url.includes('/cart/add') || url.includes('/cart/change') || url.includes('/cart/update') || url.includes('/cart/clear')) {
                          setTimeout(loadCartAndUpdate, 400);
                      }
                  });
                  originalXHR.apply(this, arguments);
              };

              document.addEventListener('cart:updated', loadCartAndUpdate);
              document.addEventListener('cart:refresh', loadCartAndUpdate);
          });
        </script>
      </div>
    {% endif %}

    <ul class="cart-links__wrapper {{ side_grid }} auto sm-hide v-center a-right">
      {%- if hd_locale_selector -%}
        <li class="lang-selector">
          <div class="selectors-form__item">
            <noscript>
              {%- form 'localization', id: 'HeaderLanguageFormNoScript', class: 'localization-form selectors-form', data-disclosure-form: '' -%}
                <h2 class="visually-hidden" id="HeaderLanguageLabelNoScript">{{ 'general.currency.dropdown_label' | t }}</h2>
                <div class="selectors-form__select">
                  <select name="locale_code" class="localization-selector button" aria-labelledby="HeaderLanguageLabelNoScript">
                    <option value="" disabled>{{ 'general.language.dropdown_label' | t }}</option>
                    {%- for language in localization.available_languages -%}
                      <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {%- if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                        {{ language.endonym_name | capitalize }}
                      </option>
                    {%- endfor -%}
                  </select>
                  {% render 'snip-icons', type: 'apollo', icon: 'down-carrot', size: '8px', fill: 'var(--announcement-text)', hover: 'var(--announcement-background)' %}
                </div>
                <button class="localization-form__noscript-btn">
                  {% render 'snip-icons', type: 'apollo', icon: 'checkmark', size: '12px', fill: 'var(--announcement-text)', hover: 'var(--announcement-background)' %}
                </button>
              {%- endform -%}
            </noscript>
            {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form selectors-form', data-disclosure-form: '' -%}
              <div class="disclosure" data-disclosure-locale>
                <div class="no-js-hidden">
                  <h2 class="visually-hidden" id="HeaderLanguageLabel">{{ 'general.language.dropdown_label' | t }}</h2>
                  <button type="button" class="disclosure__toggle" aria-expanded="false" aria-controls="HeaderLanguageList" aria-describedby="HeaderLanguageLabel" data-disclosure-toggle>
                    {{ localization.language.endonym_name | capitalize }}
                    {% render 'snip-icons', type: 'apollo', icon: 'down-carrot', size: '8px', fill: 'var(--announcement-text)', hover: 'var(--announcement-background)' %}
                  </button>
                  <ul id="HeaderLanguageList" class="disclosure-list" data-disclosure-list>
                    {%- for language in localization.available_languages -%}
                      <li class="disclosure-list__item {% if language.iso_code == localization.language.iso_code %}disclosure-list__item--current{% endif %}">
                        <a class="disclosure-list__option" href="#" title="{{ locale.endonym_name }}" lang="{{ locale.iso_code }}" {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %} data-value="{{ language.iso_code | capitalize }}" data-disclosure-option>
                          {{ language.endonym_name | capitalize }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                  <input type="hidden" name="locale_code" id="LocaleSelector" value="{{ localization.language.iso_code }}" data-disclosure-input>
                </div>
              </div>
            {%- endform -%}
          </div>
        </li>
      {%- endif -%}
      {%- if hd_currency_selector -%}
        <li class="curr-selector">
          <div class="selectors-form__item">
            <noscript>
              {%- form 'localization', id: 'HeaderCountryFormNoScript', class: 'localization-form selectors-form', data-disclosure-form: '' -%}
                <h2 class="visually-hidden" id="HeaderCountryLabelNoScript">{{ 'general.currency.dropdown_label' | t }}</h2>
                <div class="selectors-form__select">
                  <select class="localization-selector button" name="country_code" aria-labelledby="HeaderCountryLabelNoScript">
                    <option value="" disabled>{{ 'general.currency.dropdown_label' | t }}</option>
                    {%- for country in localization.available_countries -%}
                      <option value="{{ country.iso_code }}" {%- if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                        {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                      </option>
                    {%- endfor -%}
                  </select>
                  {% render 'snip-icons', type: 'apollo', icon: 'down-carrot', size: '8px', fill: 'var(--announcement-text)', hover: 'var(--announcement-text)' %}
                </div>
                <button class="localization-form__noscript-btn">
                  {% render 'snip-icons', type: 'apollo', icon: 'checkmark', size: '12px', fill: 'var(--announcement-text)', hover: 'var(--announcement-background)' %}
                </button>
              {% endform %}
            </noscript>
            {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form selectors-form', data-disclosure-form: '' -%}
              <div class="disclosure" data-disclosure-country>
                <div class="no-js-hidden">
                  <h2 class="visually-hidden" id="HeaderCountryLabel">{{ 'general.currency.dropdown_label' | t }}</h2>
                  <button type="button" class="disclosure__toggle" aria-expanded="false" aria-controls="HeaderCountryList" aria-describedby="HeaderCountryLabel" data-disclosure-toggle>
                    ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})
                    {% render 'snip-icons', type: 'apollo', icon: 'down-carrot', size: '8px', fill: 'var(--announcement-text)', hover: 'var(--announcement-text)' %}
                  </button>
                  <ul id="HeaderCountryList" class="disclosure-list" data-disclosure-list>
                    {% assign printed_currencies = '' %}
                    {% for country in localization.available_countries %}
                      {% assign currency_info = country.currency.iso_code | append: ' ' | append: country.currency.symbol %}
                      {% if printed_currencies contains currency_info %}{% continue %}{% endif %}
                      {% assign printed_currencies = printed_currencies | append: ',' | append: currency_info %}
                      <li class="disclosure-list__item {% if country.iso_code == localization.country.iso_code %}disclosure-list__item--current{% endif %}">
                        <a class="disclosure-list__option" href="#" title="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %} data-value="{{ country.iso_code }}" data-disclosure-option>
                          <span class="localization-form__currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                  <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}" data-disclosure-input>
                </div>
              </div>
            {%- endform -%}
          </div>
        </li>
      {%- endif -%}
    </ul>
  </div>

  {% if is_full_width %}
    </div>
  {% endif %}

  <style>
    :root {
      --announcement-text-size: {{ section.settings.announcement_text_size }}px;
    }
    #announcement-text-container p, 
    #announcement-text-container .format-money,
    .announcement-marquee__item {
      color: rgb(46, 102, 136);
    }
    .announcement-marquee__inner {
      display: flex;
      white-space: nowrap;
      width: max-content;
      min-width: 100%;
      animation: scroll-announcement {{ section.settings.scrolling_speed | default: 60 }}s linear infinite;
    }
    .announcement-marquee__inner:hover {
      animation-play-state: paused;
    }
    .js-dynamic-announcement, .announcement-marquee__item {
      padding: 0 40px;
      font-size: var(--announcement-text-size);
      flex-shrink: 0;
      display: inline-block;
    }
    .announcement-item {
      font-size: var(--announcement-text-size);
      color: rgb(46, 102, 136);
    }
    .announcement-marquee__inner .separator {
      display: inline-block;
      width: 6px;
      height: 6px;
      background: #2e6688;
      border-radius: 50%;
      flex-shrink: 0;
      opacity: 0.5;
    }
    @keyframes scroll-announcement {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .announcement__bar-section .gridlock-fluid .grid__wrapper { max-width: 100%; }
    .announcement__bar-section button, 
    .announcement__bar-section .disclosure-list__option {
      font-size: {{ section.settings.announcement_text_size }}px;
    }
    @media (max-width: 740px) {
      :root {
        --announcement-text-size: calc({{ section.settings.announcement_text_size }}px * 0.85);
      }
    }
  </style>
</header>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width_header",
      "label": "Full width"
    },
    {
      "type": "header",
      "content": "Scrolling Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_scrolling",
      "label": "Enable scrolling",
      "default": true
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "min": 2,
      "max": 200,
      "step": 2,
      "unit": "s",
      "label": "Scrolling speed (Seconds)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "richtext",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "<p>Share a shop announcement or message</p>"
    },
    {
      "type": "range",
      "id": "announcement_text_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Dynamic Goal Bar Targets"
    },
    {
      "type": "number",
      "id": "target_1_amount",
      "label": "Target 1 (Free Delivery)",
      "default": 100
    },
    {
      "type": "number",
      "id": "target_2_amount",
      "label": "Target 2 (+ Visor)",
      "default": 150
    },
    {
      "type": "number",
      "id": "target_3_amount",
      "label": "Target 3 (+ Sarong)",
      "default": 250
    },
    {
      "type": "header",
      "content": "Dynamic Goal Bar Texts"
    },
    {
      "type": "textarea",
      "id": "tier_1_text",
      "label": "Tier 1 Text (Cart Empty)",
      "default": "FREE EXPRESS SHIPPING ON ORDERS OVER [target_1]!",
      "info": "Use [target_1] to show the 100$ equivalent."
    },
    {
      "type": "textarea",
      "id": "tier_2_text",
      "label": "Tier 2 Text (Cart < Target 1)",
      "default": "YOU ARE ONLY [remaining_1] AWAY FROM FREE EXPRESS SHIPPING!",
      "info": "Use [remaining_1] to show the amount left to 100$."
    },
    {
      "type": "textarea",
      "id": "tier_3_text",
      "label": "Tier 3 Text (Cart >= Target 1)",
      "default": "YOU GOT FREE SHIPPING! SPEND [remaining_2] MORE FOR A FREE VISOR!",
      "info": "Use [remaining_2] to show the amount left to 150$."
    },
    {
      "type": "textarea",
      "id": "tier_4_text",
      "label": "Tier 4 Text (Cart >= Target 2)",
      "default": "YOU GOT FREE SHIPPING & VISOR! SPEND [remaining_3] MORE FOR A FREE SARONG!",
      "info": "Use [remaining_3] to show the amount left to 250$."
    },
    {
      "type": "textarea",
      "id": "tier_5_text",
      "label": "Tier 5 Text (Cart >= Target 3)",
      "default": "YOUR ORDER QUALIFIES FOR FREE EXPRESS SHIPPING, FREE VISOR & FREE SARONG!"
    },
    {
      "type": "header",
      "content": "Language Selector",
      "info": "To add a language, go to your [language settings.](/admin/settings/languages)"
    },
    { "type": "checkbox", "id": "show_locale_selector", "label": "Show language selector", "default": true },
    {
      "type": "header",
      "content": "Country/Region Selector",
