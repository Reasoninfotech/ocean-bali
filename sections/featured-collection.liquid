{%- liquid
  assign section_space = section.settings.section_space
  assign section_space_class = ''
  if section_space == 'top'
    assign section_space_class = ' pb0'
  elsif section_space == 'bottom'
    assign section_space_class = ' mt0'
  elsif section_space == 'none'
    assign section_space_class = ' mt0 pb0'
  endif
  assign section_heading_classes = ''
  if settings.section_titles == 'lines'
    assign section_heading_classes = 'lines'
  elsif settings.section_titles == 'btm_border'
    assign section_heading_classes = 'btm_border'
  endif
  assign collection = collections[section.settings.collection]
  if section.settings.carousel
   assign is_carousel = true
  endif
  assign prod_limit = section.settings.limit
  assign grid = section.settings.grid
  case section.settings.grid
    when 2
      assign prod_grid = 'span-6'
    when 3
      assign prod_grid = 'span-4'
    when 4
      assign prod_grid = 'span-3'
    when 5
      assign prod_grid = 'span-one-fifth'
  endcase
  assign mobile_1pr = false
  if section.settings.mobile_1pr
    assign mobile_1pr = true
  endif
  assign enough_to_wrap = true
  if collection.products.size <= grid
    assign enough_to_wrap = false
  endif
  if prod_limit <= grid
    assign enough_to_wrap = false
  endif
  assign margin_offset = grid | minus: 1 | times: 20
-%}
<section
  class="global__section{{ section_space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="homepage-products"
>
    {% if section.settings.title != blank %}
      <div class="grid__wrapper row rg0">
        <div class="section-title {{ section_heading_classes }} span-12 auto">
          <h2>{{ section.settings.title | escape }}</h2>
        </div>
      </div>
    {% endif %}
    {% capture slideshow_config %}{
      "wrapAround":{{ enough_to_wrap }},
      "cellAlign": "left",
      "contain": {{ enough_to_wrap }},
      "dragThreshold":{{ enough_to_wrap }},
      "pauseAutoPlayOnHover":false,
      "prevNextButtons":{{ enough_to_wrap }},
      "pageDots": {{ enough_to_wrap }}
   }{% endcapture %}
    <div id="featured_collection--{{ section.id }}" class="row product-loop featured__collection{% if is_carousel %}-carousel flickity__section js-carousel{% else %} grid__wrapper {% if section.settings.grid == 5 %} five--columns{% endif %}{% endif %}" {% if is_carousel %} data-flickity-config='{{ slideshow_config }}' data-product-count="{{ collection.products.size }}" {% endif %} data-slideout-ignore >
      {% if section.settings.collection == blank %}
        {% render 'onboard-product',
          prod_limit: prod_limit,
          grid: grid,
          is_carousel: is_carousel,
          prod_grid: prod_grid,
          mobile_1pr: mobile_1pr
        %}
      {% else %}
        {% for product in collection.products limit: prod_limit %}
          {% unless product.handle contains 'navidium' %}
        <div class="featured__collection-product product-index js-product-listing{% if mobile_1pr %} mob--single{% endif %}{% unless is_carousel %} {{ prod_grid }}{% if mobile_1pr %} sm-span-12{% else %} sm-span-6{% endif %} auto{% endunless %}" id="product-listing-{{ product.id }}" data-product-id="{{ product.id }}" data-alpha="{{ product.title }}" data-price="{{ product.price }}" >
          {% render 'product-listing',
             product: product,
             collection: collection %}
        </div>
            {% endunless %}
        {% endfor %}
      {% endif %}
    </div>
    {% if section.settings.show_view_all %}
      <div class="grid__wrapper row rg0">
        <div class="section-title span-12 auto">
          <a href="{{ collection.url }}" class="view--all_link collection_view_all_btn">
            {% if section.settings.show_view_all_label != blank %}
              {{ section.settings.show_view_all_label | escape }}
            {% else %}
              {{ 'collections.general.view_collection' | t }}
            {% endif %}
          </a>
        </div>
      </div>
    {% endif %}
  <style>
  {% if is_carousel %}
    #featured_collection--{{ section.id }}.featured__collection-carousel .featured__collection-product {
      width: calc((100% - {{ margin_offset }}px)/{{ grid }});
      margin-right: 20px;
    }
  {% endif %}
  </style>
</section>
<div class="clear"></div>
{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "id": "collection",
      "type": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 30,
      "step": 1,
      "label": "Products shown",
      "default": 12
    },
    {
      "type": "range",
      "id": "grid",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Product grid",
      "default": 4
    },
    {
      "id": "carousel",
      "type": "checkbox",
      "label": "Display in carousel"
    },
    {
      "type": "checkbox",
      "id": "mobile_1pr",
      "label": "1 per row on mobile",
      "default":false
    },
    {
      "id": "show_view_all",
      "type": "checkbox",
      "label": "Show view all link",
      "default":true
    },
    {
      "id": "show_view_all_label",
      "type": "text",
      "label": "View All Link Label"
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section spacing",
      "default": "top_and_bottom",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "top_and_bottom",
          "label": "Top and bottom"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ],
  "templates": [
    "404",
    "article",
    "blog",
    "cart",
    "collection",
    "list-collections",
    "index",
    "page",
    "product",
    "search",
    "customers/account"
  ]
}
{% endschema %}