<section class="global__section rich__text-section--{{ section.id }} mt0" data-section-id="{{ section.id }}" {% if section.settings.comman_data_id != blank %} data-section-scroll="{{ section.settings.comman_data_id }}" {% endif %}>
  <div class="row">
    <div class="rich__text-container desktop-12 tablet-6 mobile-3 padded">
      <div class="rich__text-content">
        {% for block in section.blocks %}
          {% assign page = pages[block.settings.page] %}
          <div class="rich__text-column{% if block.settings.center %} center{% endif %} block-{{ block.id }}">
            {% if block.settings.title != blank %}
              {% if block.settings.title_heading %}
                <h1>{{ block.settings.title | escape }}</h1>
              {% else %}
                <h3>{{ block.settings.title | escape }}</h3>
              {% endif %}
              <div class="clear"></div>
            {% endif %}
            {% if page != blank %}
              {{ page.content }}
            {% else %}
            <div class="rte">
              {{ block.settings.text }}
            </div>
            {% endif %}

            {%- liquid

              assign width = block.settings.block_width
              case block.settings.block_width
                when 25
                  assign span = 'span_1'
                when 50
                  assign span = 'span_2'
                when 75
                  assign span = 'span_3'
                when 100
                  assign span = 'span_4'
              endcase

            -%}

            <style>
              .rich__text-column.block-{{ block.id }} {
                {% if section.blocks.size == 1 %}
                width: {{ width }}%;
                justify-self: center;
                {% else %}
                grid-column: auto / {{ span | replace: '_', ' ' }};
                {% endif %}
              }
            </style>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
  <style>
    {% if section.blocks.size > 1 %}
    .rich__text-section--{{ section.id }} .rich__text-content {
      grid-template-columns:repeat(4, 1fr);
      justify-content: center;
    }
    {% endif %}
    .rich__text-section--{{ section.id }} {
      padding: {{ section.settings.padding }}px 0;
    }
    .rich__text-section--{{ section.id }} {
      background: {{ section.settings.background_color }};
    }
    .rich__text-section--{{ section.id }} h3,
    .rich__text-section--{{ section.id }} p,
    .rich__text-section--{{ section.id }} a {
      color: {{ section.settings.text_color }};
    }
  </style>
</section>

{% style %}
  .row.custom-liquid{
    max-width:1024px;
  }
{% endstyle %}

<section
  id="custom-liquid--{{ section.id }}"
  class="{% unless section.settings.display_wide %}row{% endunless %} custom-liquid custom-liquid--{{ section.id }} homepage-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="custom-liquid">

  {{ section.settings.liquid }}

</section>


{% schema %}
  {
    "name": "Richtext Custom liquid",
    "settings": [
      {
        "type": "range",
        "id": "padding",
        "min": 30,
        "max": 100,
        "step": 10,
        "unit": "px",
        "label": "Section padding",
        "default": 60
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background",
        "default": "#ffffff"
      },
      {
        "type": "liquid",
        "id": "liquid",
        "label": "Custom liquid",
        "info": "Add app snippets or other Liquid code to create advanced customizations."
      },
      {
        "type": "checkbox",
        "id": "display_wide",
        "label": "Full width",
        "default": false
      },
      {
      "type": "text",
      "id": "comman_data_id",
      "label": "Comman Data Id",
      "info": "Do not remove that"
    }
    ],
    "blocks": [
     {
      "type": "text_block",
      "name": "Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Welcome"
        },
        {
          "type": "checkbox",
          "id": "title_heading",
          "label": "H1 Header"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add some text blocks to your page with editable widths for a single or multi-column display</p>"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Show content from a page",
          "info": "Overrides any text entered"
        },
        {
          "type": "checkbox",
          "id": "center",
          "label": "Center align"
        },
        {
          "type": "range",
          "id": "block_width",
          "min": 25,
          "max": 100,
          "step": 25,
          "unit": "%",
          "label": "Block width",
          "default": 100
        }
      ]
    }
  ],
    "presets": [
      {
        "name": "Richtext Custom liquid"
      }
    ]
  }
{% endschema %}