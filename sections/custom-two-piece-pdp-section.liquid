              {%- when 'product_description' -%}
                <div class="product__section--desc product__description-container rte" {{ block.shopify_attributes }}>                  
                  {% if block.settings.show_as_accordion %}
                    {% capture accordion_heading_capture %}
                      {{ 'products.product.details' | t }}
                    {% endcapture %}
                    {% capture accordion_content_capture %}
                      {{ product.description | split: '<!-- split -->' | first }}
                    {% endcapture %}
                    {%
                      render 'accordion-item',
                      accordion_heading_capture: accordion_heading_capture,
                      accordion_content_capture: accordion_content_capture,
                      default_open: block.settings.default_open_accordion,
                      unique_id: block.id,
                      forloop_index: forloop.index
                    %}
                  {% else %}
                    {{ product.description }}
                  {% endif %}
                </div>

              {%- when 'accordion_content' -%}

                <div class="product__section--accordion" {{ block.shopify_attributes }}>
                  {% capture accordion_heading_capture %}
                    {{ block.settings.title }}
                  {% endcapture %}
                  {% capture accordion_content_capture %}

                    {% if block.settings.title == 'SIZE Guide' %}
                      {%- if size_popup == true -%}
                        {{ block.settings.text }}
                        <span class="popup_content_link size-guide-trigger" style="padding: 10px 0;margin: 0 0 10px 0;">
                            Head to our <button class="product__contact-trigger button-as-link js-modal-open js-contact-trigger" type="button" name="button" data-wau-modal-target="popup-content" style="margin: 0;">SIZE GUIDE</button> to find your perfect fit.
                        </span>
                      {% else %}
                        {{ block.settings.text }}
                        <p>Head to our <a href="{% if block.settings.page != blank %} {{ block.settings.page.url }} {% else %} /pages/size-guide {% endif %}" target="_blank" title="SIZE GUIDE">Size Guide</a> to find your perfect fit.</p>
                      {% endif %}
                    {% else %}
                      {% if block.settings.page != blank %}
                          {{ block.settings.page.content }}
                        {% else %}
                          {{ block.settings.text }}
                        {% endif %}
                    {% endif %}
                    
                  {% endcapture %}
                  {%
                    render 'accordion-item',
                    accordion_heading_capture: accordion_heading_capture,
                    accordion_content_capture: accordion_content_capture,
                    default_open: block.settings.default_open_accordion,
                    unique_id: block.id,
                    forloop_index: forloop.index
