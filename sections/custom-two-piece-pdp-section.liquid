    $('body').addClass('after_popup');
    $('.modal_drawer').addClass('active')
  })
  $('.modal_drawer_title span').click(function(){
    $('body').removeClass('after_popup');
    $('.modal_drawer').removeClass('active')
  });
  $('.popup_content_link').click(function(){
    $('#modal-popup-content').addClass('modal--active')
    $('body').addClass('modal--open modal-popup-content--open')
  })
  $('.slideout__trigger-popup-content').click(function(){
    $('#modal-popup-content').removeClass('modal--active')
    $('body').addClass('modal--closed')
