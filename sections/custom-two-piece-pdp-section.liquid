<script>

const checkCondition = setInterval(() => {
    const variantId = document.querySelector('.formVariantId').value;
    const variantElements = document.querySelectorAll('.variant_pre_order .varint-loop');  
    var variantTrue = false;
    var datazeroTrue = false;
    const itemsLeftPretextElement = document.querySelector('.items_left_pre_order');
    const itemsLeftTextElement = document.querySelector('.items_left_main');
    const addToCartButton = document.querySelector('#addToCart');
    variantElements.forEach((element) => {
      const dataId = element.getAttribute('data-id');
      const metaTag = element.getAttribute('meta-tag');
      if (dataId == variantId && metaTag == "true") {
        variantTrue = true;        
      }else{
        const datainv = element.getAttribute('data-inventory');
        if(dataId == variantId && datainv <= 0){
          datazeroTrue = true;
        }
      }
    });

    var productform = document.querySelector('.product__form-buttons');
    var inputvalue = '<input id="pre_order" type="hidden" name="properties[Pre-order]" value="Pre Order">';
    var othertext = '<input id="ship_text" type="hidden" name="properties[Note]" value="Ships as soon as delivery is received">';
  
    if(variantTrue){
       if (!document.querySelector('#pre_order')) {
        productform.insertAdjacentHTML('beforeend', inputvalue);
       productform.insertAdjacentHTML('beforeend', othertext);
      }
      const addToCartText = document.querySelector('#addToCart .add_to_cart_text');
      addToCartButton.setAttribute('data-property', 'Pre-Order'); 
      addToCartText.textContent = "Pre-Order ";
      itemsLeftPretextElement.style.display = "block";
      itemsLeftTextElement.style.display = "none";
      
    }else{
      const existingInput = document.querySelector('#pre_order');
      if (existingInput) {
        existingInput.remove();
      }
      addToCartButton.removeAttribute('data-property');
      itemsLeftPretextElement.style.display = "none";
      if (datazeroTrue ){
        itemsLeftTextElement.style.display = "none";
      }else{
        itemsLeftTextElement.style.display = "flex";
      }
    }
  
}, 10);

  var swatches = document.querySelectorAll('.swatch-element');  
  swatches.forEach(function(swatch) {
    swatch.addEventListener('click', function() {
    var intervalId = setInterval(function() {
      var button = document.getElementById('addToCart');
      var dataProperty = button.getAttribute('data-property');
      var buttondisabled = button.disabled;
        if (dataProperty == null && !buttondisabled) {
            var dataValue = button.getAttribute('value');
            if(dataValue != ''){
              button.querySelector('.add_to_cart_text').textContent = dataValue;
              clearInterval(intervalId);
            }
        }else{
          var dataValue = "SOLD OUT";
          if(dataValue != ''){
            button.querySelector('.add_to_cart_text').textContent = dataValue;        
            clearInterval(intervalId);
          }
        }
    }, 1000);      
  });
});

  document.addEventListener("DOMContentLoaded", function() {
    const slider = document.querySelector(".slider");
    const slides = document.querySelectorAll(".slide");
    const prevButton = document.querySelector(".prev-button");
    const nextButton = document.querySelector(".next-button");
    let slideIndex = 0;

    const slideWidth = slides[0].clientWidth; // Adjust if slide width is different

    prevButton.addEventListener("click", function() {
        if (slideIndex > 0) {
            slideIndex--;
            slider.style.transform = `translateX(-${slideIndex * slideWidth}px)`;
        }
    });

    nextButton.addEventListener("click", function() {
        if (slideIndex < slides.length - 1) {
            slideIndex++;
            slider.style.transform = `translateX(-${slideIndex * slideWidth}px)`;
        }
    });
});

  
</script>                        

