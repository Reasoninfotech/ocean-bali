function extractAndPrintNumber() {
    const itemsLeftDiv = document.querySelector('.items_left');  
    const itemsLeftText = itemsLeftDiv.textContent;
    const numberPattern = /\d+/;
    const extractedNumber = parseInt(itemsLeftText.match(numberPattern)[0]);
    let outputString = "";
    const itemsLeftMain = document.querySelector('.items_left_main');
    if (extractedNumber <= 7 && extractedNumber > 0) {
        outputString = extractedNumber + " items left";
        itemsLeftMain.classList.add('lowe_value');
    } else if (extractedNumber === 0 ) {
        itemsLeftMain.style.display = "none";
        itemsLeftMain.classList.remove('lowe_value');
        return;
    } else {
        outputString = "In Stock";
        itemsLeftMain.classList.remove('lowe_value');
    }
    const itemsLeftTextElement = document.querySelector('.items_left_text');
    itemsLeftTextElement.textContent = outputString;
}

extractAndPrintNumber();

var variantContainers = document.querySelectorAll('.click_function_value');

variantContainers.forEach(function(container) {
    var variantChild = container.querySelectorAll('.swatch-element');
    variantChild.forEach(function(child) {
        child.addEventListener('click', function() {
            setTimeout(function() {
                extractAndPrintNumber();
            }, 500);
        });
    });
});

