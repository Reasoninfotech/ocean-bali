{%- liquid

assign current_variant = product.selected_or_first_available_variant
assign thumbnail_position = section.settings.thumbnail_position
assign click_to_enlarge = section.settings.click_to_enlarge
assign enable_video_looping = section.settings.enable_video_looping

assign form_grid = 'span-6'

case section.settings.media_size
  when 'small'
    assign media_grid = 'span-4 push-1'
  when 'medium'
    assign media_grid = 'span-6'
  when 'large'
    assign media_grid = 'span-7'
    assign form_grid = 'span-5'
endcase

assign description_active = false
for block in section.blocks
  if block.type == 'product_description'
    assign description_active = true
  endif
endfor

if product.template_suffix == 'pre-order'
  assign button_text = 'products.product.pre_order' | t
else
  assign button_text = 'products.product.add_to_cart' | t
endif

assign size_popup = false

-%}
{% style %}
.template-product-cust-sleeveless-one-piec p.swatches__option-name.h5.Size strong{
    display: block!important;
}

.template-product-cust-sleeveless-one-piec .product__variants-swatches .click_function_value .swatches__option-name .size-guide-trigger{
  display: none!important;
}
.template-product-cust-sleeveless-one-piec  .product_top_description_meta .metafield-rich_text_field ul li{font-size: var(--font-size);}

.template-product-cust-sleeveless-one-piec  .new_cus_size_guide_trigger{margin-top: 10px;}

.template-product-cust-sleeveless-one-piec  .price_after_main_block {display: flex;flex-wrap: wrap;align-items: center;justify-content: space-between;margin-top: 10px;gap: 10px;}

.template-product-cust-sleeveless-one-piec  .price__pricing-group{margin-bottom: 0;}

.template-product-cust-sleeveless-one-piec  #product-price .price-item{font-size: 20px;display: block;}
.template-product-cust-sleeveless-one-piec  .product__section-stockLevels{margin-top: 0px;margin-bottom: 0px;}
.template-product-cust-sleeveless-one-piec  .after_pay_row{margin-bottom: 0;}

.template-product-cust-sleeveless-one-piec  .product_btn_cart .stocke_lavel_aftre_pay{justify-content: center;margin-bottom: 10px;}
.template-product-cust-sleeveless-one-piec  .product_btn_cart .stocke_lavel_aftre_pay .items_left_main {margin-bottom: 0!important;}


.template-product-cust-sleeveless-one-piec  see-it-on-you.see-it-on-you{margin-top: -32px!important;}
{% endstyle %}

<section
  id="product-{{ product.id }}"
  class="product__section section-{{ section.id }} product-{{ product.id }} main__section"
  data-product-id="{{ product.id }}"
  data-section-id="{{ section.id }}"
  data-url="{{ product.url }}"
  data-section-type="product__section"
  data-sale-format="{{ settings.sale_items }}"
  data-initial-variant="{{ current_variant.featured_media.id }}">

  {% render 'product-json', product: product %}

  {% capture product_gallery_config %}{
    "thumbPosition": {{ section.settings.thumbnail_position | json }},
    "enableVideoLooping": {{ section.settings.enable_video_looping | json }},
    "mainSlider": {% if product.media.size <= 1 %}false{% else %}true{% endif %},
    "thumbSlider": {% if product.media.size >= 4 %}true{% else %}false{% endif %},
    "productId": {{ product.id | json }},
    "thumbsShown": 4,
    "clickToEnlarge": {{ click_to_enlarge | json }},
    "isQuick": false
 }{% endcapture %}

{% capture product_form_config %}
 { "money_format": {{ shop.money_format | json }},
   "enable_history": true,
   "sold_out": {{ "products.product.sold_out" | t | json }},
   "button": {{ button_text | json }},
   "unavailable": {{ 'products.product.unavailable' | t | json }},
   "savings": {{ 'products.general.savings' | t | json }},
   "quickview": false,
   "featured_product": false,
   "swatches": {{ settings.product_variants | json }},
   "only_left": {
    "one": {{ 'products.product.only_left.one' | t | json }},
    "other": {{ 'products.product.only_left.other' | t | json }}
   }
 }
{% endcapture %}

  <div class="product__section-container row grid__wrapper">
    <div class="product__section-images ddd product__section-image--{{ thumbnail_position }} carousel-container {{ media_grid }} md-span-12 sm-span-12 auto js-product-gallery"
      data-product-gallery
      data-product-single-media-group
      data-gallery-config='{{ product_gallery_config }}'>
        {%- if product.featured_media -%}
          {% render 'product-image-gallery',
            product: product,
            thumbnail_position: thumbnail_position,
            click_to_enlarge: click_to_enlarge,
            enable_video_looping: enable_video_looping,
            product_gallery_config: product_gallery_config %}
        {%- else -%}
          {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
          {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
    </div>
    <div class="product__section-contentWrapper {{ form_grid }} md-span-12 sm-span-12 auto">
      <div class="product__section-content">
        <div class="product__section-details">
          <div class="product__section--header">            
            {% if settings.vendor %}
              <h3>{{ product.vendor }}</h3>
            {% endif %}
            <h1 class="product__section-title product-title">{{ product.title }}</h1>
            {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', jm_style: '', concierge_install: true, product: product %}
            
            
           {%comment %}
              {% if product.metafields.custom.product_top_description != blank %}
                <div class="product_top_description_meta" style="display: block;">{{ product.metafields.custom.product_top_description }}</div>
              {% endif %}
            {%endcomment %}
              {% if product.metafields.custom.product_top_description_with_bullets != blank %}
                <div class="product_top_description_meta" style="display: block;">
                  {{ product.metafields.custom.product_top_description_with_bullets | metafield_tag }}
                </div>

              {% elsif product.metafields.custom.product_top_description != blank %}
                <div class="product_top_description_meta" style="display: block;">
                  {{ product.metafields.custom.product_top_description }}
                </div>
              {% endif %}
          
            {%- if section.settings.show_tax_notice -%}
              {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                <div class="product__policies rte" data-product-policies>
                  {%- if cart.taxes_included -%}
                    {{ 'products.product.include_taxes' | t }}
                  {%- endif -%}
                  {%- if shop.shipping_policy.body != blank -%}
                    {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endif -%}

            {%- form 'product', product, id: 'product-form-installment' -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <select style="display:none;" name='id'>
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% if variant == current_variant %}selected="selected"{% endif %}></option>
                {% endfor %}
              </select>
              <div class="spi-banner">
                {{ form | payment_terms }}
              </div><!-- /#spi-banner -->
            {%- endform -%}
          </div>
          {%- assign product_buttons_form_id = 'product-form-buttons-' | append: section.id -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'product_variants' -%}
                {%- assign product_form_id = 'product-form-' | append: section.id -%}
                {% form 'product', product,
                   id: product_form_id,
                   class: "product__form-container product_form relative",
                   data-product-form: product_form_config,
                   data-product-id: product.id %}

                  {%- unless product.has_only_default_variant -%}
                   {%- if settings.product_variants == 'swatches' -%}
                     <div class="product__variants-swatches mt4 mb6 no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}">
                       {% for option in product.options_with_values %}
                         {% render "swatch",
                           option: option,
                           current_variant: current_variant,
                           product: product,
                           show_color_swatches: settings.show_color_swatches,
                           color_swatch_shape: settings.color_swatch_shape,
                           color_swatch_style: settings.color_swatch_style %}
                       {% endfor %}
                     </div>
                   {%- else -%}
                     <div class="product__variants-select no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}">
                       {%- for option in product.options_with_values -%}
                         <div class="product-form__input product-form__input--dropdown">
                           <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                             {{ option.name }}  
                           </label>
                           <div class="select">
                             <select id="Option-{{ section.id }}-{{ forloop.index0 }}"
                               class="js-variant-selector styled-select"
                               name="options[{{ option.name | escape }}]"
                               form="product-form-{{ section.id }}"
                             >
                               {%- for value in option.values -%}
                                 <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                                   {{ value }}
                                 </option>
                               {%- endfor -%}
                             </select>
                           </div>
                         </div>
                       {%- endfor -%}
                     </div>
                   {%- endif -%}
                  {%- endunless -%}

                  <noscript class="product__variants-select product-form__noscript-wrapper-{{ section.id }}">
                    <div class="product-form__input product-form__input--dropdown{% if product.has_only_default_variant %} hidden{% endif %}">
                      <label class="form__label" for="Variants-{{ section.id }}">{{ 'products.product.select_option' | t }}</label>
                      <div class="select">
                        <select name="id" id="Variants-{{ section.id }}" class="styled-select">
                          {%- for variant in product.variants -%}
                            <option
                              {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}
                              {% if variant.available == false %}disabled{% endif %}
                              value="{{ variant.id }}"
                            >
                              {{ variant.title }}
                              {%- if variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
                              - {{ variant.price | money | strip_html }}
                            </option>
                          {%- endfor -%}
                        </select>
                      </div>
                    </div>
                  </noscript>

                  <input class="formVariantId" name="" type="hidden" value="{{ product.selected_or_first_available_variant.id }}">
                {% endform %}

              {%- when 'product_availability' -%}
              <div class="product-single__store-availability-container"
                data-variant-id="{{ current_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                style="visibility:hidden; min-height: 120px;" data-store-availability-container>
              </div>

              {%- when 'product_quantity' -%}
                <div class="product__section--qty qty-selection hide" data-product-qty {{ block.shopify_attributes }}>
                  {%
                    render 'product-quantity',
                    product: product
                  %}
                </div>

              {%- when 'product_sku' -%}
                <div class="product__section--sku sku" {{ block.shopify_attributes }}>
                  <label for="variantSku" style="line-height: 1.6em; display: inline-block;">{{ 'customer.order.details.sku' | t }}:</label>
                  <span id="variantSku" class="variant_sku">{{ current_variant.sku }}</span>
                </div>

                <div class="clear"></div>

	            {% when 'stock_levels' %}
                <div class="price_after_main_block"> 
                     {% render 'product-price', variant: current_variant, product: product %}
                <div class="product__section-stockLevels" {{ block.shopify_attributes }}>
                  <div class="stocke_lavel_aftre_pay">
                   <div class="after_pay_row">
              {% assign product_main = product.price | money_without_currency %}
              {% assign price_split = product_main | split: '.' | first %}
              {% assign price_com = price_split | replace: ",", "" %}
              {% assign product_pr = price_com | divided_by: 4 | floor %}
              {% assign product_aed = product_pr | times: 100 %}
                <div class="after_pay_col">
                  <span class="after_pay_row_inner">
                    {{ 'cout_text.pay' | t }} 
                    <strong>
                      {{ product_aed | money_without_trailing_zeros }}
                    </strong>
                    {{ 'cout_text.with' | t }}
                  </span>
                  <span class="after_pay_icon" onclick="jQuery('.after_pay_img').show();jQuery('body').addClass('after_popup');">
                    <svg xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" width="98" height="36" class="compact-badge-logo" viewBox="0 0 100 21">
                        <path class="afterpay-logo-badge-background" fill="#b2fce4" d="M89.85 20.92h-78.9a10.42 10.42 0 110-20.82h78.89a10.42 10.42 0 010 20.83v-.01z"></path>
                        <g class="afterpay-logo-badge-lockup">
                          <path d="M85.05 6.37L82.88 5.1l-2.2-1.27a2.2 2.2 0 00-3.3 1.9v.29c0 .16.08.3.22.38l1.03.58c.28.16.63-.04.63-.37v-.67c0-.34.36-.54.65-.38l2.02 1.16 2 1.15c.3.16.3.58 0 .75l-2 1.15-2.02 1.16a.43.43 0 01-.65-.38v-.33a2.2 2.2 0 00-3.28-1.9l-2.2 1.26-2.19 1.25a2.2 2.2 0 000 3.8l2.18 1.25 2.2 1.27a2.2 2.2 0 003.3-1.9v-.3c0-.15-.09-.3-.23-.37L78.02 14a.43.43 0 00-.64.37v.67c0 .34-.36.54-.65.38l-2-1.16-2-1.15a.43.43 0 010-.75l2-1.15 2-1.16c.3-.16.65.05.65.38v.33a2.2 2.2 0 003.3 1.9l2.2-1.26 2.17-1.25a2.2 2.2 0 000-3.8z"></path>
                          <path d="M70.77 6.78l-5.1 10.53h-2.12l1.91-3.93-3-6.6h2.17l1.93 4.42 2.1-4.42h2.11z"></path>
                          <path d="M19.8 10.5c0-1.24-.92-2.12-2.04-2.12s-2.03.9-2.03 2.14c0 1.23.91 2.14 2.03 2.14s2.03-.88 2.03-2.14m.02 3.74v-.97a3 3 0 01-2.36 1.09c-2.05 0-3.6-1.65-3.6-3.86 0-2.2 1.61-3.87 3.65-3.87.95 0 1.76.42 2.31 1.08v-.95h1.84v7.48h-1.84z"></path>
                          <path d="M30.6 12.6c-.65 0-.84-.24-.84-.87V8.4h1.2V6.78h-1.2V4.96h-1.88v1.82h-2.43v-.74c0-.63.24-.87.9-.87h.42V3.72h-.9c-1.56 0-2.3.5-2.3 2.07v1h-1.04V8.4h1.04v5.85h1.88V8.4h2.43v3.66c0 1.53.6 2.19 2.11 2.19h.97V12.6h-.37z"></path>
                          <path d="M37.35 9.85c-.13-.97-.93-1.56-1.86-1.56-.92 0-1.7.57-1.88 1.56h3.74zM33.6 11c.13 1.1.93 1.74 1.93 1.74.8 0 1.4-.37 1.76-.97h1.94c-.45 1.58-1.87 2.6-3.74 2.6a3.68 3.68 0 01-3.85-3.85 3.78 3.78 0 013.9-3.9 3.74 3.74 0 013.8 4.38H33.6z"></path>
                          <path d="M51.35 10.5c0-1.2-.9-2.12-2.03-2.12-1.12 0-2.03.9-2.03 2.14 0 1.23.9 2.14 2.03 2.14 1.12 0 2.03-.93 2.03-2.14m-5.92 6.79V6.78h1.84v.97a2.97 2.97 0 012.36-1.1c2.02 0 3.6 1.65 3.6 3.85s-1.6 3.87-3.65 3.87a2.9 2.9 0 01-2.26-1v3.93h-1.9.01z"></path>
                          <path d="M59.86 10.5c0-1.24-.9-2.12-2.03-2.12-1.12 0-2.04.9-2.04 2.14 0 1.23.92 2.14 2.04 2.14s2.03-.88 2.03-2.14m.02 3.74v-.97a3 3 0 01-2.36 1.09c-2.05 0-3.6-1.65-3.6-3.86 0-2.2 1.61-3.87 3.64-3.87.96 0 1.76.42 2.32 1.08v-.95h1.84v7.48h-1.84z"></path>
                          <path d="M42.11 7.5s.47-.86 1.62-.86c.5 0 .8.17.8.17v1.9s-.69-.42-1.32-.33c-.64.09-1.04.67-1.04 1.45v4.42h-1.9V6.78h1.84v.73z"></path>
                        </g>
                      </svg>
                  </span> 
                </div>
                <div class="after_pay_btn">
                  {% comment %}<button>{{ 'cout_text.btn' | t }}</button>{% endcomment %}
                  <button id="logo-link" class="afterpay-link" tabindex="0" aria-label="Learn More about Afterpay - Opens a dialog" title="Learn More about Afterpay - Opens a dialog">ⓘ</button>
                </div>
          
                <div class="after_pay_img" style="display: none;">
                  <div class="after_pay_img_inner">
                    <img src="{{ section.settings.pay_img | img_url:'master' }}" alt="" >
                    <span class="after_pay_close_icon">
                      <svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <g id="Menu / Close_MD">
                      <path id="Vector" d="M18 18L12 12M12 12L6 6M12 12L18 6M12 12L6 18" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </g>
                      </svg>
                    </span>
                  </div>
                </div>
                    </div>
              </div>
            </div>
             </div>
                          

              {%- when 'product_buttons' -%}
                <div class="product__section--buttons product-add" {{ block.shopify_attributes }}>
                  {% form 'product', product,
                     id: product_buttons_form_id,
                     class: "product__form-buttons js-prod-form-submit relative",
                     data-product-id: product.id %}

                    {%- liquid


                      if product.template_suffix == 'pre-order'
                        assign call_to_action = 'products.product.pre_order' | t
                        assign is_preorder = 'data-preorder'
                      else
                        assign call_to_action = 'products.product.add_to_cart' | t
                        assign is_preorder = ''
                      endif
                      unless current_variant.available
                        assign call_to_action = 'products.product.sold_out' | t
                        assign is_preorder = ''
                      endunless

                      assign product_form_id = 'product-form-' | append: section.id

                    -%}

                    <input class="formVariantId" name="id" type="hidden" value="{{ product.selected_or_first_available_variant.id }}">
                    <input class="formQty" type="hidden" name="quantity" value="1" />

                    
                    <div class="note note-success js-added-msg" style="display: none">
                      <b>{{ 'products.product.added' | t }}</b>&nbsp;&nbsp;&nbsp;<a class="underline" href="{{ routes.cart_url }}">{{ 'products.product.view_cart' | t }}</a> {{ 'products.product.or' | t }} <a class="underline" href="{{ routes.all_products_collection_url }}">{{ 'products.product.continue' | t }}</a>.
                    </div>
                    <div class="note note-error js-error-msg" style="display: none">
                      <b>{{ 'cart.general.cart_error' | t }}</b>&nbsp;&nbsp;&nbsp;{{ 'cart.general.update_qty_error' | t }}

                    </div>

                    <ul class="variant_pre_order" style="display:none;">
                       {% for variant in product.variants %}
                          <li class="varint-loop" data-id="{{ variant.id }}" data-inventory="{{ variant.inventory_quantity }}" meta-tag="{{ variant.metafields.custom.pre_order_on }}" ></li>
                       {% endfor %}
                    </ul>
                    
                    <div class="product_btn_cart">
                      
                      <button id="addToCart" type="submit" name="button" class="add clearfix AddtoCart js-ajax-submit {% if settings.show_payment_button and product.selling_plan_groups.size == 0 %} secondary-button{% endif %}" {{ is_preorder }} value="" {% unless current_variant.available %}disabled{% endunless %}>

                        {% comment %}
                        <ul style="display:none;">
                         {% for variant in product.variants %}
                            <li class="varint-loop"></li>
                          {% endfor %}
                        </ul>
                        {% endcomment %}
                        <span class="add_to_cart_text">{{ call_to_action }} </span>
                        
                        <span>- {{ product.price | money }}</span>
                    </button>
                    </div>

                    
                    <div class="klaviyo-btn_wrp {% if product.handle == 'sulawesi-midnight-t' %}notshow_notify{% endif %}" style="margin-bottom:5px;">
                      <a class="klaviyo-bis-trigger" style="display:none;" href="#">Notify Me When Available</a>
                    </div> 
                    
                    {% comment %}  
                    <div class="raflin-widget-button"></div>
                    <style>
                          .raflin-btn {
                              border-radius: 0px !important;
                          }
                    </style>
                    {% endcomment %}
                    
                    <div class="payment_icon_pro">
                      {% assign enabled_payment_types = 'visa,master,american_express,paypal,apple_pay,shopify_pay,google_pay,unionpay' | remove : ' ' | split : ',' %}
                      {% for type in enabled_payment_types %}
                        {{ type | payment_type_svg_tag: class:'payment-icon' }}
                      {% endfor %}
                      <svg class="payment-icon" xmlns="http://www.w3.org/2000/svg" width="38" height="24" viewBox="0 0 38 24" fill="none">
