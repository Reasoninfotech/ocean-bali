<script>
function waitForTolstoyAndClick() {
  const tolstoyBtn = $('[data-tolstoy-element*="tolstoy-stories-on-you-button"]');
  if (tolstoyBtn.length) {
    tolstoyBtn[0].click();
    console.log('Tolstoy button clicked.');
  } else {
    setTimeout(waitForTolstoyAndClick, 500); // Check again in 0.5 sec
  }
}

{% comment %} $(document).on('click', '.see_it_on_you_btn', function() {
  waitForTolstoyAndClick();
}); {% endcomment %}

