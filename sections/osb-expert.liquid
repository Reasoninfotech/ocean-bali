{% comment %}
  OSB - Expert Validation Section
  Section: osb-expert.liquid
{% endcomment %}

<style>
  .osb-expert-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_mobile }}px 5% {{ section.settings.padding_bottom_mobile }}px;
    text-align: center;
    border-top: 1px solid #d6e6f0;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-expert-{{ section.id }} .osb-circles {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .osb-expert-{{ section.id }} .osb-circle {
    width: {{ section.settings.circle_size_mobile }}px;
    height: {{ section.settings.circle_size_mobile }}px;
    border-radius: 50%;
    background: #eaf2f8;
    border: 3px solid #ffffff;
    box-shadow: 0 0 0 1px #d6e6f0;
    overflow: hidden;
    margin-left: -16px;
  }

  .osb-expert-{{ section.id }} .osb-circle:first-child {
    margin-left: 0;
  }

  .osb-expert-{{ section.id }} .osb-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .osb-expert-{{ section.id }} .osb-exp-h {
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .osb-expert-{{ section.id }} .osb-exp-p {
    font-size: {{ section.settings.body_size_mobile }}px;
    color: #606060;
    max-width: {{ section.settings.text_max_width }}px;
    margin: 0 auto 2rem;
    line-height: 1.85;
  }

  .osb-expert-{{ section.id }} .osb-btn {
    display: inline-block;
    background: {{ section.settings.btn_color }};
    color: #ffffff;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 16px 36px;
    border-radius: 3px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .osb-expert-{{ section.id }} .osb-btn:hover {
    background: #245578;
  }

  @media (min-width: 768px) {
    .osb-expert-{{ section.id }} {
      padding: {{ section.settings.padding_top_tablet }}px 5% {{ section.settings.padding_bottom_tablet }}px;
    }
    .osb-expert-{{ section.id }} .osb-exp-h {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-expert-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px 5% {{ section.settings.padding_bottom_desktop }}px;
    }
    .osb-expert-{{ section.id }} .osb-exp-h {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
    .osb-expert-{{ section.id }} .osb-circle {
      width: {{ section.settings.circle_size_desktop }}px;
      height: {{ section.settings.circle_size_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-expert-{{ section.id }}">
  {% if section.settings.show_circles %}
  <div class="osb-circles">
    {% if section.settings.circle_1 != blank %}
    <div class="osb-circle">{{ section.settings.circle_1 | image_url: width: 200 | image_tag: loading: 'lazy' }}</div>
    {% else %}
    <div class="osb-circle" style="background:#eaf2f8;"></div>
    {% endif %}
    {% if section.settings.circle_2 != blank %}
    <div class="osb-circle">{{ section.settings.circle_2 | image_url: width: 200 | image_tag: loading: 'lazy' }}</div>
    {% else %}
    <div class="osb-circle" style="background:#c5dcea;"></div>
    {% endif %}
    {% if section.settings.circle_3 != blank %}
    <div class="osb-circle">{{ section.settings.circle_3 | image_url: width: 200 | image_tag: loading: 'lazy' }}</div>
    {% else %}
    <div class="osb-circle" style="background:#f4f8fb;"></div>
    {% endif %}
  </div>
  {% endif %}

  <h2 class="osb-exp-h">{{ section.settings.heading }}</h2>
  <p class="osb-exp-p">{{ section.settings.body_text }}</p>
  {% if section.settings.btn_text != blank %}
  <a href="{{ section.settings.btn_url }}" class="osb-btn">{{ section.settings.btn_text }}</a>
  {% endif %}
</section>
{% endif %}

{% schema %}
{
  "name": "OSB Expert Validation",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built by ocean women, for ocean women."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Ocean Soul was founded in Canggu, Bali - where we live in the ocean. We spent years frustrated with swimwear that looked good in the shop but failed the moment we paddled out. The Sulawesi is the swimsuit we couldn't find, so we made it ourselves."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Shop The Sulawesi →"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Founder / Team Circles"
    },
    {
      "type": "checkbox",
      "id": "show_circles",
      "label": "Show Circles",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "circle_1",
      "label": "Circle 1 Image"
    },
    {
      "type": "image_picker",
      "id": "circle_2",
      "label": "Circle 2 Image"
    },
    {
      "type": "image_picker",
      "id": "circle_3",
      "label": "Circle 3 Image"
    },
    {
      "type": "range",
      "id": "circle_size_mobile",
      "min": 60,
      "max": 120,
      "step": 2,
      "label": "Circle Size Mobile (px)",
      "default": 80
    },
    {
      "type": "range",
      "id": "circle_size_desktop",
      "min": 70,
      "max": 140,
      "step": 2,
      "label": "Circle Size Desktop (px)",
      "default": 90
    },
    {
      "type": "header",
      "content": "Colors & Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#77A5C8"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Color",
      "default": "#2E6688"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "min": 400,
      "max": 800,
      "step": 20,
      "label": "Body Text Max Width (px)",
      "default": 580
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 32,
      "step": 1,
      "label": "Heading Size (Mobile)",
      "default": 22
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "min": 12,
      "max": 16,
      "step": 1,
      "label": "Body Font Size (Mobile)",
      "default": 13
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Mobile)",
      "default": 48
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 20,
      "max": 36,
      "step": 1,
      "label": "Heading Size (Tablet)",
      "default": 26
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Tablet)",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Tablet)",
      "default": 56
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 22,
      "max": 42,
      "step": 1,
      "label": "Heading Size (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Bottom Padding (Desktop)",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "OSB Expert Validation"
    }
  ]
}
{% endschema %}