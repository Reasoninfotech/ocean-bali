{% comment %}
  OSB - UGC / Instagram Photo Grid
  Section: osb-ugc-grid.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-ugc-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_mobile }}px 5% {{ section.settings.padding_bottom_mobile }}px;
    border-top: 1px solid #d6e6f0;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-ugc-{{ section.id }} .osb-ugc-h {
    text-align: center;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
  }

  .osb-ugc-{{ section.id }} .osb-ugc-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cols_mobile }}, 1fr);
    gap: {{ section.settings.gap_mobile }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .osb-ugc-{{ section.id }} .osb-ugc-item {
    aspect-ratio: 1;
    background: #eaf2f8;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
  }

  .osb-ugc-{{ section.id }} .osb-ugc-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .osb-ugc-{{ section.id }} .osb-ugc-item:hover img {
    transform: scale(1.04);
  }



  @media (min-width: 768px) {
    .osb-ugc-{{ section.id }} {
      padding: {{ section.settings.padding_top_tablet }}px 5% {{ section.settings.padding_bottom_tablet }}px;
    }
    .osb-ugc-{{ section.id }} .osb-ugc-h {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }
    .osb-ugc-{{ section.id }} .osb-ugc-grid {
      grid-template-columns: repeat({{ section.settings.cols_tablet }}, 1fr);
      gap: {{ section.settings.gap_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-ugc-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px 5% {{ section.settings.padding_bottom_desktop }}px;
    }
    .osb-ugc-{{ section.id }} .osb-ugc-h {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
    .osb-ugc-{{ section.id }} .osb-ugc-grid {
      grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
      gap: {{ section.settings.gap_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
  <section class="osb-ugc-{{ section.id }}">
    {% if section.settings.heading != blank %}
      <h2 class="osb-ugc-h">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="osb-ugc-grid">
      {% for block in section.blocks %}
        {% if block.type == 'photo' %}
          <div class="osb-ugc-item" {{ block.shopify_attributes }}>
            {% if block.settings.photo != blank %}
              {% assign photo_raw = block.settings.photo | image_url: width: 600 %}
              {% capture photo_src %}{% render 'imagekit', src: photo_raw %}{% endcapture %}
              {% assign photo_src = photo_src | strip %}

              {% if block.settings.link_url != blank %}
                <a href="{{ block.settings.link_url }}" target="_blank" rel="noopener">
                  <img src="{{ photo_src }}" loading="lazy" alt="{{ block.settings.photo.alt | escape }}">
                </a>
              {% else %}
                <img src="{{ photo_src }}" loading="lazy" alt="{{ block.settings.photo.alt | escape }}">
              {% endif %}

            {% else %}
              <div style="width:100%;height:100%;background:{{ block.settings.placeholder_color }};"></div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "OSB UGC Photo Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "The Ocean Soul Community"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 16,
      "step": 1,
      "label": "Image Border Radius",
      "default": 3
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f8fb"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#77A5C8"
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "cols_mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (Mobile)",
      "default": 3
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Gap (Mobile)",
      "default": 6
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 30,
      "step": 1,
      "label": "Heading Size (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "cols_tablet",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Columns (Tablet)",
      "default": 4
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Gap (Tablet)",
      "default": 8
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 18,
      "max": 34,
      "step": 1,
      "label": "Heading Size (Tablet)",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Tablet)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Tablet)",
      "default": 40
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "min": 4,
      "max": 8,
      "step": 1,
      "label": "Columns (Desktop)",
      "default": 6
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Gap (Desktop)",
      "default": 8
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 20,
      "max": 38,
      "step": 1,
      "label": "Heading Size (Desktop)",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 32,
      "max": 100,
      "step": 4,
      "label": "Top Padding (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 32,
      "max": 100,
      "step": 4,
      "label": "Bottom Padding (Desktop)",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (optional)"
        },
        {
          "type": "color",
          "id": "placeholder_color",
          "label": "Placeholder Color (if no image)",
          "default": "#ccd8e4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OSB UGC Photo Grid",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
