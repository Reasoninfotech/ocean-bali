{% comment %}
  OSB - Announcement Bar with Countdown Timer
  Section: osb-announcement-bar.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-ann-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_mobile }}px 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: 'Montserrat', sans-serif;
    font-size: {{ section.settings.font_size_mobile }}px;
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  .osb-ann-{{ section.id }} .osb-cd {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .osb-ann-{{ section.id }} .osb-cd-u {
    background: rgba(255,255,255,0.2);
    padding: 2px 8px;
    border-radius: 3px;
    font-size: {{ section.settings.timer_font_size_mobile }}px;
    font-weight: 700;
    min-width: 34px;
    text-align: center;
  }

  .osb-ann-{{ section.id }} .osb-cd-l {
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
    display: block;
    text-align: center;
    font-weight: 400;
  }

  .osb-ann-{{ section.id }} .osb-cd-sep {
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .osb-ann-{{ section.id }} {
      padding: {{ section.settings.padding_tablet }}px 1rem;
      font-size: {{ section.settings.font_size_tablet }}px;
    }
    .osb-ann-{{ section.id }} .osb-cd-u {
      font-size: {{ section.settings.timer_font_size_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-ann-{{ section.id }} {
      padding: {{ section.settings.padding_desktop }}px 1rem;
      font-size: {{ section.settings.font_size_desktop }}px;
    }
    .osb-ann-{{ section.id }} .osb-cd-u {
      font-size: {{ section.settings.timer_font_size_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-ann-{{ section.id }}">
  {% if section.settings.show_countdown %}
  <div class="osb-cd">
    <div>
      <div class="osb-cd-u" id="cd-h-{{ section.id }}">{{ section.settings.default_hours | prepend: '0' | slice: -2, 2 }}</div>
      <span class="osb-cd-l">Hours</span>
    </div>
    <span class="osb-cd-sep">:</span>
    <div>
      <div class="osb-cd-u" id="cd-m-{{ section.id }}">{{ section.settings.default_mins | prepend: '0' | slice: -2, 2 }}</div>
      <span class="osb-cd-l">Mins</span>
    </div>
    <span class="osb-cd-sep">:</span>
    <div>
      <div class="osb-cd-u" id="cd-s-{{ section.id }}">59</div>
      <span class="osb-cd-l">Secs</span>
    </div>
  </div>
  {% endif %}
  <span>{{ section.settings.message }}</span>
</section>

<script>
(function(){
  var end = new Date();
  end.setHours(end.getHours() + {{ section.settings.default_hours }}, end.getMinutes() + {{ section.settings.default_mins }}, end.getSeconds() + 59);
  function pad(n){ return String(n).padStart(2,'0'); }
  function tick(){
    var d = Math.max(0, end - new Date());
    var hE = document.getElementById('cd-h-{{ section.id }}');
    var mE = document.getElementById('cd-m-{{ section.id }}');
    var sE = document.getElementById('cd-s-{{ section.id }}');
    if(hE) hE.textContent = pad(Math.floor(d/3600000));
    if(mE) mE.textContent = pad(Math.floor((d%3600000)/60000));
    if(sE) sE.textContent = pad(Math.floor((d%60000)/1000));
    if(d > 0) setTimeout(tick, 1000);
  }
  tick();
})();
</script>
{% endif %}

{% schema %}
{
  "name": "OSB Announcement Bar",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Announcement Message",
      "default": "Offer ends soon - 20% off your first order with code <strong>FB20</strong>"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show Countdown Timer",
      "default": true
    },
    {
      "type": "range",
      "id": "default_hours",
      "min": 0,
      "max": 23,
      "step": 1,
      "label": "Countdown Hours",
      "default": 4
    },
    {
      "type": "range",
      "id": "default_mins",
      "min": 0,
      "max": 59,
      "step": 1,
      "label": "Countdown Minutes",
      "default": 47
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2E6688"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 18,
      "step": 1,
      "label": "Font Size (Mobile)",
      "default": 11
    },
    {
      "type": "range",
      "id": "timer_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "label": "Timer Font Size (Mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Vertical Padding (Mobile)",
      "default": 10
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "font_size_tablet",
      "min": 10,
      "max": 18,
      "step": 1,
      "label": "Font Size (Tablet)",
      "default": 12
    },
    {
      "type": "range",
      "id": "timer_font_size_tablet",
      "min": 12,
      "max": 24,
      "step": 1,
      "label": "Timer Font Size (Tablet)",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_tablet",
      "min": 4,
      "max": 24,
      "step": 1,
      "label": "Vertical Padding (Tablet)",
      "default": 12
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 18,
      "step": 1,
      "label": "Font Size (Desktop)",
      "default": 12
    },
    {
      "type": "range",
      "id": "timer_font_size_desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "label": "Timer Font Size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "min": 4,
      "max": 24,
      "step": 1,
      "label": "Vertical Padding (Desktop)",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "OSB Announcement Bar"
    }
  ]
}
{% endschema %}
