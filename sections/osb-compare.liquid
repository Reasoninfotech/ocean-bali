{% comment %}
  OSB - Comparison Table (Us vs Them)
  Section: osb-compare.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-cmp-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_mobile }}px 5% {{ section.settings.padding_bottom_mobile }}px;
    border-top: 1px solid #d6e6f0;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-cmp-{{ section.id }} .osb-sec-title {
    text-align: center;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 3rem;
    letter-spacing: -0.01em;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-hd {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    gap: 0.8rem;
    padding: 0 1rem 0.8rem;
    border-bottom: 2px solid {{ section.settings.heading_color }};
    max-width: 900px;
    margin: 0 auto;
    align-items: center;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .osb-cmp-{{ section.id }} .osb-logo-mark {
    width: 28px;
    height: 28px;
    background: {{ section.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .osb-cmp-{{ section.id }} .osb-logo-mark svg {
    width: 14px;
    height: 14px;
    fill: white;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-brand span {
    font-size: 13px;
    font-weight: 700;
    color: #2a2a2a;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-col {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #909090;
    text-align: center;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-col.us {
    color: {{ section.settings.accent_color }};
  }

  .osb-cmp-{{ section.id }} .osb-cmp-rows {
    max-width: 900px;
    margin: 0 auto;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-row {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    align-items: center;
    padding: 0.85rem 1rem;
    gap: 0.8rem;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-row:nth-child(odd) {
    background: {{ section.settings.row_alt_bg }};
    border-radius: 3px;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-txt {
    font-size: {{ section.settings.row_font_size }}px;
    color: #606060;
  }

  .osb-cmp-{{ section.id }} .osb-cmp-tick {
    text-align: center;
    font-size: {{ section.settings.tick_size }}px;
    font-weight: 700;
  }

  .osb-cmp-{{ section.id }} .osb-tick {
    color: {{ section.settings.accent_color }};
  }

  .osb-cmp-{{ section.id }} .osb-cross {
    color: #c8c8c8;
  }

  @media (min-width: 768px) {
    .osb-cmp-{{ section.id }} {
      padding: {{ section.settings.padding_top_tablet }}px 5% {{ section.settings.padding_bottom_tablet }}px;
    }
    .osb-cmp-{{ section.id }} .osb-sec-title {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }
    .osb-cmp-{{ section.id }} .osb-cmp-hd,
    .osb-cmp-{{ section.id }} .osb-cmp-row {
      grid-template-columns: 1fr 100px 100px;
    }
  }

  @media (min-width: 1024px) {
    .osb-cmp-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px 5% {{ section.settings.padding_bottom_desktop }}px;
    }
    .osb-cmp-{{ section.id }} .osb-sec-title {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-cmp-{{ section.id }}">
  <h2 class="osb-sec-title">{{ section.settings.heading }}</h2>

  <div class="osb-cmp-hd">
    <div class="osb-cmp-brand">
      <div class="osb-logo-mark">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" fill="white"/></svg>
      </div>
      <span>{{ section.settings.brand_name }}</span>
    </div>
    <span class="osb-cmp-col us">{{ section.settings.col_us_label }}</span>
    <span class="osb-cmp-col">{{ section.settings.col_them_label }}</span>
  </div>

  <div class="osb-cmp-rows">
    {% for block in section.blocks %}
      {% if block.type == 'row' %}
      <div class="osb-cmp-row" {{ block.shopify_attributes }}>
        <span class="osb-cmp-txt">{{ block.settings.feature }}</span>
        <span class="osb-cmp-tick {% if block.settings.we_have %}osb-tick{% else %}osb-cross{% endif %}">
          {% if block.settings.we_have %}✓{% else %}✗{% endif %}
        </span>
        <span class="osb-cmp-tick {% if block.settings.they_have %}osb-tick{% else %}osb-cross{% endif %}">
          {% if block.settings.they_have %}✓{% else %}✗{% endif %}
        </span>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "OSB Compare Table",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "The Sulawesi vs Other Brands"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Your Brand Name",
      "default": "Ocean Soul Bali"
    },
    {
      "type": "text",
      "id": "col_us_label",
      "label": "Our Column Label",
      "default": "Us ✓"
    },
    {
      "type": "text",
      "id": "col_them_label",
      "label": "Others Column Label",
      "default": "Others ✗"
    },
    {
      "type": "range",
      "id": "row_font_size",
      "min": 11,
      "max": 16,
      "step": 1,
      "label": "Row Text Size",
      "default": 13
    },
    {
      "type": "range",
      "id": "tick_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "label": "Tick / Cross Size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f8fb"
    },
    {
      "type": "color",
      "id": "row_alt_bg",
      "label": "Alternating Row Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#77A5C8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Tick / Accent Color",
      "default": "#2E6688"
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 32,
      "step": 1,
      "label": "Heading Size (Mobile)",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Mobile)",
      "default": 48
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 20,
      "max": 36,
      "step": 1,
      "label": "Heading Size (Tablet)",
      "default": 26
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Tablet)",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Tablet)",
      "default": 56
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 22,
      "max": 42,
      "step": 1,
      "label": "Heading Size (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Bottom Padding (Desktop)",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature Description",
          "default": "UPF 50+ long-sleeve sun protection"
        },
        {
          "type": "checkbox",
          "id": "we_have",
          "label": "We Have It (✓)",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "they_have",
          "label": "Others Have It (✓)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OSB Compare Table",
      "blocks": [
        { "type": "row", "settings": { "feature": "UPF 50+ long-sleeve sun protection", "we_have": true, "they_have": false } },
        { "type": "row", "settings": { "feature": "Stays on through surf and ocean swimming", "we_have": true, "they_have": false } },
        { "type": "row", "settings": { "feature": "Sculpting cinched-waist panelled design", "we_have": true, "they_have": false } },
        { "type": "row", "settings": { "feature": "Recycled ECONYL® Italian fabric", "we_have": true, "they_have": false } },
        { "type": "row", "settings": { "feature": "Ethically made with fair wages", "we_have": true, "they_have": false } },
        { "type": "row", "settings": { "feature": "Chlorine & fade resistant - lasts 2× longer", "we_have": true, "they_have": false } },
        { "type": "row", "settings": { "feature": "12-month manufacturer warranty", "we_have": true, "they_have": false } }
      ]
    }
  ]
}
{% endschema %}
