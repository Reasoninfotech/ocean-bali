<section class="global__section rich__text-section--{{ section.id }} mt0" data-section-id="{{ section.id }}" style="padding-bottom:0;">
  <div class="row">
    <div class="rich__text-container desktop-12 tablet-6 mobile-3 padded">
      <div class="rich__text-content">
        {% for block in section.blocks %}
          {% if block.type == "text_block" %}
          {% assign page = pages[block.settings.page] %}
          <div class="rich__text-column{% if block.settings.center %} center{% endif %} block-{{ block.id }}">
            {% if block.settings.title != blank %}
              {% if block.settings.title_heading %}
                <h1>{{ block.settings.title | escape }}</h1>
              {% else %}
                <h2>{{ block.settings.title | escape }}</h2>
              {% endif %}
              <div class="clear"></div>
            {% endif %}
            {% if page != blank %}
              {{ page.content }}
            {% else %}
            <div class="rte">
              {{ block.settings.text }}
            </div>
            {% endif %}

            {%- liquid

              assign width = block.settings.block_width
              case block.settings.block_width
                when 25
                  assign span = 'span_1'
                when 50
                  assign span = 'span_2'
                when 75
                  assign span = 'span_3'
                when 100
                  assign span = 'span_4'
              endcase

            -%}

            <style>
              .rich__text-column.block-{{ block.id }} {
                {% if section.blocks.size == 1 %}
                width: {{ width }}%;
                justify-self: center;
                {% else %}
                grid-column: auto / {{ span | replace: '_', ' ' }};
                {% endif %}
              }
            </style>
          </div>
          {% endif %}  
        {% endfor %}
      </div>
    </div>
  </div>
  <style>
    {% if section.blocks.size > 1 %}
    .rich__text-section--{{ section.id }} .rich__text-content {
      grid-template-columns:repeat(4, 1fr);
      justify-content: center;
    }
    {% endif %}
    .rich__text-section--{{ section.id }} {
      padding: {{ section.settings.padding }}px 0;
    }
    .rich__text-section--{{ section.id }} {
      background: {{ section.settings.background_color }};
    }
    .rich__text-section--{{ section.id }} h3,
    .rich__text-section--{{ section.id }} p,
    .rich__text-section--{{ section.id }} a {
      color: {{ section.settings.text_color }};
    }
  </style>
</section>

{%- liquid

  assign section_space = section.settings.section_space
  assign section_space_class = ''

  if section_space == 'top'
    assign section_space_class = ' pb0'
  elsif section_space == 'bottom'
    assign section_space_class = ' mt0'
  elsif section_space == 'none'
    assign section_space_class = ' mt0 pb0'
  endif

  assign is_fixed = false
  if section.settings.image_height == 'fixed'
    assign is_fixed = true
  endif

  assign desktop_fixed_height = section.settings.desktop_fixed_height
  assign mobile_fixed_height = section.settings.mobile_fixed_height

-%}
{% style %}
  .imageText__column-section.section-{{ section.id }} {
    --desktop-section-height: {{ desktop_fixed_height }}px;
    --mobile-section-height: {{ mobile_fixed_height }}px;
  }

  .imageText__column-section .row.grid__wrapper{
    display:flex;
    flex-wrap: wrap;
    gap: 30px;
  }

  .imageText__column-section .imageText__column-container{
    margin: 0!important;
    width: calc(20% - 24px);
  }

  .imageText__column-section .imageText__column-caption h3{
    font-size: 16px;
  }

  .imageText__column-btn-wrapper a{
    padding: 7px 20px;
    font-size: 12px;
  }

  @media screen and (max-width: 991px){

    .imageText__column-section .row.grid__wrapper{
        gap: 28px;
    }

    .imageText__column-section .imageText__column-caption h3{
        font-size: 14px;
    }
    
    .imageText__column-section .imageText__column-container{
        width: calc(25% - 21px)!important;
    }
  }

  @media screen and (max-width: 768px){

    .imageText__column-section .row.grid__wrapper{
        gap: 15px;
    }
    
    .imageText__column-section .imageText__column-container{
        width: calc(33.33% - 10px)!important;
    }
  }
   
  @media screen and (max-width: 575px){

    .imageText__column-section .row.grid__wrapper{
        gap: 10px;
    }
    
    .imageText__column-section .imageText__column-container{
        width: calc(50% - 5px)!important;
    }
  }
  
{% endstyle %}
<section class="imageText__column-section section-{{ section.id }} global__section{{ section_space_class }} {% if is_fixed %}{% endif %}" data-section-id="{{ section.id }}">

  <div class="row grid__wrapper">
    {% if section.settings.title != blank %}
    <div class="section-title {% if settings.section_titles == 'lines' %}lines {% elsif settings.section_titles == 'btm_border' %}btm_border {% endif %} span-12 auto"><h2>{{ section.settings.title | escape }}</h2></div>
    {% endif %}

    {% for block in section.blocks %}
      {% if block.type == 'editorial_block' %}
      <div class="imageText__column-container{% if section.settings.center_align %} center{% endif %} {{ column_width }} mobile-3 text-promo-{{ block.id }}" {{ block.shopify_attributes }}>        
        {% if block.settings.image != blank %}
          {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" aria-label="{{ block.settings.button_text | append:' Read more'  }}"><span class="visually-hidden-span">{{ block.settings.button_text }}</span>{% endif %}
            <div class="imageText__column-image {% if is_fixed %}is-fixed_height{% endif %}">
              {%
                render 'basic-responsive-image',
                type: block.settings.image,
                width: 1200,
                lg_render: lg_render,
                md_render: md_render,
              %}
            </div>
          {% if block.settings.link != blank %}</a>{% endif %}
          {% endif %}
          <div class="imageText__column-caption">
          {% if block.settings.title_text != blank %}
            <h3>{{ block.settings.title_text | escape }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="rte">
              {{ block.settings.text }}
            </div>
          {% endif %}
          {% if block.settings.link != blank and block.settings.button_text != blank %}
            <div class="imageText__column-btn-wrapper">
              <a href="{{ block.settings.link }}" aria-label="{{ block.settings.button_text }}">{{ block.settings.button_text | escape }}</a>
            </div>
          {% endif %}
          </div>
      </div>  
      {% endif %}
    {% endfor %}
  </div>

  {% if section.blocks.size == 0 %}
    {% render 'no-blocks' %}
  {% endif %}

</section>

<div class="clear"></div>


{% schema %}
  {
    "name": "Richtext Editorial",
    "settings": [
      {
        "type": "range",
        "id": "padding",
        "min": 30,
        "max": 100,
        "step": 10,
        "unit": "px",
        "label": "Section padding",
        "default": 60
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background",
        "default": "#ffffff"
      },
      {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Editorial column"
    },
    {
      "type": "checkbox",
      "id": "center_align",
      "label": "Center align text",
      "default": false
    },
    {
      "type": "radio",
      "id": "image_height",
      "label": "Image height",
      "default": "none",
      "options":
      [
        {
          "value": "none",
          "label": "Natural"
        },
        {
          "value": "fixed",
          "label": "Fixed"
        }
      ]
    },
    {
      "type": "range",
      "id": "desktop_fixed_height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Desktop fixed height",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_fixed_height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Mobile fixed height",
      "default": 250
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section spacing",
      "default": "top_and_bottom",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "top_and_bottom",
          "label": "Top and bottom"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    }
    ],
     "blocks": [
    {
      "type": "text_block",
      "name": "Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Welcome"
        },
        {
          "type": "checkbox",
          "id": "title_heading",
          "label": "H1 Header"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add some text blocks to your page with editable widths for a single or multi-column display</p>"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Show content from a page",
          "info": "Overrides any text entered"
        },
        {
          "type": "checkbox",
          "id": "center",
          "label": "Center align"
        },
        {
          "type": "range",
          "id": "block_width",
          "min": 25,
          "max": 100,
          "step": 25,
          "unit": "%",
          "label": "Block width",
          "default": 100
        }
      ]
    },
    {
      "type": "editorial_block",
      "name": "Size Guide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "800px x 800px recommended"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional"
        },
        {
          "type": "text",
          "id": "title_text",
          "label": "Heading",
          "default": "Our collections"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add text with images to give and content and editorial feel. Drive traffic to key areas of your store</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button",
          "default": "Button"
        }
      ]
    }
  ],
  "presets": [
    {
     "name": "Richtext Editorial" 
    }
  ]
}
{% endschema %}