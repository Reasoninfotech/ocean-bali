{% comment %}
  OSB - Icon Trust Strip
  Section: osb-icon-strip.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-icons-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_mobile }}px 5%;
    border-top: 1px solid #d6e6f0;
    border-bottom: 1px solid #d6e6f0;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-icons-{{ section.id }} .osb-icon-lbl {
    text-align: center;
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #909090;
    margin-bottom: 1.5rem;
  }

  .osb-icons-{{ section.id }} .osb-icon-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .osb-icons-{{ section.id }} .osb-icon-scroll::-webkit-scrollbar {
    display: none;
  }

  .osb-icons-{{ section.id }} .osb-icon-track {
    display: flex;
    gap: {{ section.settings.gap_mobile }}px;
    padding: 4px 0 8px;
    width: max-content;
    margin: 0 auto;
  }

  .osb-icons-{{ section.id }} .osb-chip {
    background: {{ section.settings.chip_bg }};
    border: 1px solid #d6e6f0;
    padding: {{ section.settings.chip_padding }}px {{ section.settings.chip_padding_h }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    min-width: {{ section.settings.chip_width_mobile }}px;
    border-radius: {{ section.settings.chip_radius }}px;
    transition: box-shadow 0.2s;
  }

  .osb-icons-{{ section.id }} .osb-chip:hover {
    box-shadow: 0 2px 8px rgba(46,102,136,0.1);
  }

  .osb-icons-{{ section.id }} .osb-chip svg {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    stroke: {{ section.settings.icon_color }};
    fill: none;
    stroke-width: 1.5;
  }

  .osb-icons-{{ section.id }} .osb-chip-lbl {
    font-size: {{ section.settings.chip_label_size }}px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #606060;
    text-align: center;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .osb-icons-{{ section.id }} {
      padding: {{ section.settings.padding_tablet }}px 5%;
    }
    .osb-icons-{{ section.id }} .osb-icon-track {
      gap: {{ section.settings.gap_tablet }}px;
      width: auto;
      flex-wrap: wrap;
      justify-content: center;
    }
    .osb-icons-{{ section.id }} .osb-chip {
      min-width: {{ section.settings.chip_width_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-icons-{{ section.id }} {
      padding: {{ section.settings.padding_desktop }}px 5%;
    }
    .osb-icons-{{ section.id }} .osb-chip {
      min-width: {{ section.settings.chip_width_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-icons-{{ section.id }}">
  {% if section.settings.label_text != blank %}
  <p class="osb-icon-lbl">{{ section.settings.label_text }}</p>
  {% endif %}

  <div class="osb-icon-scroll">
    <div class="osb-icon-track">
      {% for block in section.blocks %}
        {% if block.type == 'chip' %}
        <div class="osb-chip" {{ block.shopify_attributes }}>
          {% case block.settings.icon %}
            {% when 'shield' %}
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% when 'return' %}
            <svg viewBox="0 0 24 24"><polyline points="9 10 4 15 9 20"/><path d="M20 4v7a4 4 0 0 1-4 4H4"/></svg>
            {% when 'clock' %}
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {% when 'heart' %}
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {% when 'home' %}
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {% when 'trending' %}
            <svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            {% when 'lock' %}
            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            {% when 'activity' %}
            <svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            {% when 'star' %}
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% when 'truck' %}
            <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          {% endcase %}
          <span class="osb-chip-lbl">{{ block.settings.label }}</span>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "OSB Icon Trust Strip",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Section Label",
      "default": "Why You Can Trust Us"
    },
    {
      "type": "header",
      "content": "Chip Styling"
    },
    {
      "type": "range",
      "id": "chip_padding",
      "min": 8,
      "max": 24,
      "step": 1,
      "label": "Chip Vertical Padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "chip_padding_h",
      "min": 8,
      "max": 28,
      "step": 1,
      "label": "Chip Horizontal Padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "chip_radius",
      "min": 0,
      "max": 16,
      "step": 1,
      "label": "Chip Border Radius",
      "default": 4
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "label": "Icon Size",
      "default": 20
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 8,
      "max": 14,
      "step": 1,
      "label": "Section Label Size",
      "default": 10
    },
    {
      "type": "range",
      "id": "chip_label_size",
      "min": 8,
      "max": 13,
      "step": 1,
      "label": "Chip Label Size",
      "default": 10
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "chip_bg",
      "label": "Chip Background",
      "default": "#f4f8fb"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#2E6688"
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Gap Between Chips (Mobile)",
      "default": 10
    },
    {
      "type": "range",
      "id": "chip_width_mobile",
      "min": 72,
      "max": 130,
      "step": 2,
      "label": "Chip Min Width (Mobile)",
      "default": 92
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "label": "Vertical Padding (Mobile)",
      "default": 24
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Gap Between Chips (Tablet)",
      "default": 10
    },
    {
      "type": "range",
      "id": "chip_width_tablet",
      "min": 80,
      "max": 140,
      "step": 4,
      "label": "Chip Min Width (Tablet)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_tablet",
      "min": 16,
      "max": 60,
      "step": 4,
      "label": "Vertical Padding (Tablet)",
      "default": 28
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "chip_width_desktop",
      "min": 88,
      "max": 150,
      "step": 2,
      "label": "Chip Min Width (Desktop)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "min": 16,
      "max": 60,
      "step": 4,
      "label": "Vertical Padding (Desktop)",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Trust Chip",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield / Warranty" },
            { "value": "return", "label": "Return Arrow" },
            { "value": "clock", "label": "Clock / Time" },
            { "value": "heart", "label": "Heart" },
            { "value": "home", "label": "Home / Factory" },
            { "value": "trending", "label": "Trending / Growth" },
            { "value": "lock", "label": "Lock / Secure" },
            { "value": "activity", "label": "Activity / Resistant" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck / Shipping" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "12-Month\nWarranty"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OSB Icon Trust Strip",
      "blocks": [
        { "type": "chip", "settings": { "icon": "shield", "label": "12-Month\nWarranty" } },
        { "type": "chip", "settings": { "icon": "return", "label": "Easy\nReturns" } },
        { "type": "chip", "settings": { "icon": "clock", "label": "Lasts 2×\nLonger" } },
        { "type": "chip", "settings": { "icon": "shield", "label": "UPF 50+\nProtection" } },
        { "type": "chip", "settings": { "icon": "heart", "label": "Made in\nBali" } },
        { "type": "chip", "settings": { "icon": "home", "label": "Ethical\nFactory" } },
        { "type": "chip", "settings": { "icon": "trending", "label": "ECONYL®\nRecycled" } },
        { "type": "chip", "settings": { "icon": "lock", "label": "Secure\nCheckout" } },
        { "type": "chip", "settings": { "icon": "activity", "label": "Chlorine\nResistant" } }
      ]
    }
  ]
}
{% endschema %}