{% comment %}
  OSB - Customer Reviews Grid
  Section: osb-reviews.liquid
  Supports: Mobile / Tablet / Desktop customization
{% endcomment %}

<style>
  .osb-reviews-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_mobile }}px 5% {{ section.settings.padding_bottom_mobile }}px;
    font-family: 'Montserrat', sans-serif;
  }

  .osb-reviews-{{ section.id }} .osb-sec-title {
    text-align: center;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: {% if section.settings.show_review_count %}1rem{% else %}3rem{% endif %};
    letter-spacing: -0.01em;
  }

  .osb-reviews-{{ section.id }} .osb-rev-count {
    text-align: center;
    font-size: 13px;
    color: #909090;
    margin-bottom: 2.5rem;
    display: {{ section.settings.show_review_count | ternary: 'block', 'none' }};
  }

  .osb-reviews-{{ section.id }} .osb-rev-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .osb-reviews-{{ section.id }} .osb-rev-card {
    border: 1px solid #d6e6f0;
    padding: {{ section.settings.card_padding_mobile }}px;
    border-radius: {{ section.settings.card_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: {{ section.settings.card_bg }};
  }

  .osb-reviews-{{ section.id }} .osb-rev-stars {
    color: {{ section.settings.star_color }};
    font-size: {{ section.settings.star_size }}px;
    letter-spacing: 2px;
    text-align: center;
  }

  .osb-reviews-{{ section.id }} .osb-rev-text {
    font-size: {{ section.settings.review_font_size }}px;
    font-style: italic;
    color: #606060;
    line-height: 1.8;
    text-align: center;
  }

  .osb-reviews-{{ section.id }} .osb-rev-auth {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #2a2a2a;
  }

  .osb-reviews-{{ section.id }} .osb-rev-ver {
    font-size: 11px;
    font-style: italic;
    color: {{ section.settings.heading_color }};
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
    display: block;
  }

  @media (min-width: 768px) {
    .osb-reviews-{{ section.id }} {
      padding: {{ section.settings.padding_top_tablet }}px 5% {{ section.settings.padding_bottom_tablet }}px;
    }
    .osb-reviews-{{ section.id }} .osb-sec-title {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }
    .osb-reviews-{{ section.id }} .osb-rev-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .osb-reviews-{{ section.id }} .osb-rev-card {
      padding: {{ section.settings.card_padding_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .osb-reviews-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px 5% {{ section.settings.padding_bottom_desktop }}px;
    }
    .osb-reviews-{{ section.id }} .osb-sec-title {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
    .osb-reviews-{{ section.id }} .osb-rev-grid {
      grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
    }
    .osb-reviews-{{ section.id }} .osb-rev-card {
      padding: {{ section.settings.card_padding_desktop }}px;
    }
  }
</style>

{% if section.settings.show_section %}
<section class="osb-reviews-{{ section.id }}">
  <h2 class="osb-sec-title">{{ section.settings.heading }}</h2>
  {% if section.settings.show_review_count %}
  <p class="osb-rev-count">{{ section.settings.review_count_text }}</p>
  {% endif %}

  <div class="osb-rev-grid">
    {% for block in section.blocks %}
      {% if block.type == 'review' %}
      <div class="osb-rev-card" {{ block.shopify_attributes }}>
        <div class="osb-rev-stars">
          {% assign star_count = block.settings.stars %}
          {% for i in (1..star_count) %}★{% endfor %}
        </div>
        <p class="osb-rev-text">"{{ block.settings.review_text }}"</p>
        <div class="osb-rev-auth">
          {{ block.settings.author_name }}
          <span class="osb-rev-ver">{{ block.settings.verified_label }}</span>
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "OSB Reviews Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Our Customers Are Saying"
    },
    {
      "type": "checkbox",
      "id": "show_review_count",
      "label": "Show Review Count",
      "default": true
    },
    {
      "type": "text",
      "id": "review_count_text",
      "label": "Review Count Text",
      "default": "800+ five-star reviews"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "range",
      "id": "review_font_size",
      "min": 11,
      "max": 16,
      "step": 1,
      "label": "Review Text Font Size",
      "default": 13
    },
    {
      "type": "range",
      "id": "star_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "label": "Star Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 16,
      "step": 1,
      "label": "Card Border Radius",
      "default": 6
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#77A5C8"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#77A5C8"
    },
    {
      "type": "header",
      "content": "📱 Mobile Settings"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 32,
      "step": 1,
      "label": "Heading Size (Mobile)",
      "default": 22
    },
    {
      "type": "range",
      "id": "card_padding_mobile",
      "min": 12,
      "max": 36,
      "step": 2,
      "label": "Card Padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Mobile)",
      "default": 48
    },
    {
      "type": "header",
      "content": "📲 Tablet Settings"
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 18,
      "max": 36,
      "step": 1,
      "label": "Heading Size (Tablet)",
      "default": 26
    },
    {
      "type": "range",
      "id": "card_padding_tablet",
      "min": 14,
      "max": 40,
      "step": 2,
      "label": "Card Padding (Tablet)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Top Padding (Tablet)",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 24,
      "max": 80,
      "step": 4,
      "label": "Bottom Padding (Tablet)",
      "default": 56
    },
    {
      "type": "header",
      "content": "🖥️ Desktop Settings"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (Desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 22,
      "max": 42,
      "step": 1,
      "label": "Heading Size (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_padding_desktop",
      "min": 16,
      "max": 48,
      "step": 2,
      "label": "Card Padding (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 40,
      "max": 120,
      "step": 4,
      "label": "Bottom Padding (Desktop)",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "This product is amazing!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "Verified Label",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "OSB Reviews Grid",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "I've never worn a swimsuit that actually stays in place like this. I surf, dive, swim - and I never have to adjust it.",
            "author_name": "Sarah M.",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "No slipping, no riding up - just confidence. I can finally focus on the water instead of my body.",
            "author_name": "Jessica L.",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "I feel like a Bond girl when I wear it. Best swimsuit I've ever owned - I want one in every colour.",
            "author_name": "Ekaterina V.",
            "stars": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
