                  <p>{{ 'cout_text.btn' | t }}</p>   
                </div>
          
                <div class="after_pay_img" style="display: none;">
                  <div class="after_pay_img_inner">
                    <img src="{{ settings.pay_img | img_url:'master' }}" alt="" >
                    <span class="after_pay_close_icon">
                      <svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <g id="Menu / Close_MD">
                      <path id="Vector" d="M18 18L12 12M12 12L6 6M12 12L18 6M12 12L6 18" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </g>
                      </svg>
                    </span>
                  </div>
                </div> -->
                        
              </div>
      
      <div class="ajax-cart__buttons">

        <span style="position: relative;display:block;">
          <input class="ajax-cart__button-submit" type="submit" name="checkout" id="checkout" value="{{ 'cart.general.checkout' | t }}" style="padding-left: 20px;"/>
          <svg class="icon--testament-secure" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" height="{{ size }}" viewBox="0 0 16 21" xml:space="preserve" style="position: absolute; left: calc(50% - 62px); width: 20px; height: 20px; top: calc(50% - 18px);">
          <g class="hover-fill" fill="#ffffff">
            <path d="M13.7142856,7.33333334 L12.7619047,7.33333334 L12.7619047,5.42857143 C12.7619047,2.8 10.6285713,0.66666667 7.9999999,0.66666667 C5.37142847,0.66666667 3.23809513,2.8 3.23809513,5.42857143 L3.23809513,7.33333334 L2.28571418,7.33333334 C1.23809513,7.33333334 0.380952273,8.1904762 0.380952273,9.23809524 L0.380952273,18.7619048 C0.380952273,19.8095238 1.23809513,20.6666667 2.28571418,20.6666667 L13.7142856,20.6666667 C14.7619047,20.6666667 15.6190476,19.8095238 15.6190476,18.7619048 L15.6190476,9.23809524 C15.6190476,8.1904762 14.7619047,7.33333334 13.7142856,7.33333334 Z M5.14285704,5.42857143 C5.14285704,3.84761906 6.41904752,2.57142858 7.9999999,2.57142858 C9.58095224,2.57142858 10.8571428,3.84761906 10.8571428,5.42857143 L10.8571428,7.33333334 L5.14285704,7.33333334 L5.14285704,5.42857143 Z M13.7142856,18.7619048 L2.28571418,18.7619048 L2.28571418,9.23809524 L13.7142856,9.23809524 L13.7142856,18.7619048 Z M7.9999999,15.9047619 C9.04761898,15.9047619 9.90476184,15.0476191 9.90476184,14 C9.90476184,12.9523809 9.04761898,12.0952381 7.9999999,12.0952381 C6.95238084,12.0952381 6.09523799,12.9523809 6.09523799,14 C6.09523799,15.0476191 6.95238084,15.9047619 7.9999999,15.9047619 Z" fill-rule="nonzero"></path>
          </g>
          <style>{{ wrapper }} .icon--testament-secure:hover .hover-fill { fill: {{ hover }};}</style>
        </svg>
        </span>
        
        
        <a class="ajax-cart__button-view_cart button secondary-button" href="{{ routes.cart_url }}">{{ 'products.product.view_cart' | t }}</a>
       
        {%- unless request.design_mode -%}
          {% if no_js_cart %}
          {% if additional_checkout_buttons %}
            <p class="sm-caps or-divider mt2 mb2 a-center"><span>Or</span></p>
            <div class="ajax-cart__buttons-additional">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {% endif %}
          {% endif %}
        {%- endunless -%}

        {% if settings.bottomText != blank %}
          <div class="ajax-cart__buttons_dis">
            {{ settings.bottomText }}
          </div>
        {% endif %}
        
        <div id="payment" class="credit desktop-12 tablet-6 mobile-3">
          {% assign enabled_payment_types = 'visa,master,american_express,paypal,apple_pay,shopify_pay,google_pay,unionpay' | remove : ' ' | split : ',' %}
          {% for type in enabled_payment_types %}
            {{ type | payment_type_svg_tag: class:'payment-icon' }}
          {% endfor %}
        </div>
      </div>
    </div>
  </form>

<script>

</script>